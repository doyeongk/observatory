<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>double</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0f; 
  overflow: hidden; 
  font-family: monospace;
}
canvas { display: block; }
#info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  color: rgba(255, 100, 200, 0.6);
  font-size: 12px;
  pointer-events: none;
}
</style>
</head>
<body>
<canvas id="canvas"></canvas>
<div id="info">click to spawn · drag to disturb</div>
<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');

let W, H, cx, cy;
const g = 9.81;
const dt = 0.016;
const substeps = 8;

// Audio context
let audioCtx = null;
let oscillators = [];
let gainNodes = [];

function initAudio() {
  if (audioCtx) return;
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  
  // Create oscillators for each pendulum
  for (let i = 0; i < 4; i++) {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    const filter = audioCtx.createBiquadFilter();
    
    osc.type = 'sine';
    osc.frequency.value = 100 + i * 50;
    filter.type = 'lowpass';
    filter.frequency.value = 400;
    filter.Q.value = 2;
    gain.gain.value = 0;
    
    osc.connect(filter);
    filter.connect(gain);
    gain.connect(audioCtx.destination);
    osc.start();
    
    oscillators.push(osc);
    gainNodes.push(gain);
  }
}

class DoublePendulum {
  constructor(x, y, l1, l2, m1, m2, a1, a2, hue) {
    this.ox = x;
    this.oy = y;
    this.l1 = l1;
    this.l2 = l2;
    this.m1 = m1;
    this.m2 = m2;
    this.a1 = a1;
    this.a2 = a2;
    this.v1 = 0;
    this.v2 = 0;
    this.hue = hue;
    this.trail = [];
    this.maxTrail = 800;
  }

  update() {
    for (let i = 0; i < substeps; i++) {
      const subDt = dt / substeps;
      
      // Double pendulum equations of motion
      const { l1, l2, m1, m2, a1, a2, v1, v2 } = this;
      
      const num1 = -g * (2 * m1 + m2) * Math.sin(a1);
      const num2 = -m2 * g * Math.sin(a1 - 2 * a2);
      const num3 = -2 * Math.sin(a1 - a2) * m2;
      const num4 = v2 * v2 * l2 + v1 * v1 * l1 * Math.cos(a1 - a2);
      const den = l1 * (2 * m1 + m2 - m2 * Math.cos(2 * a1 - 2 * a2));
      const acc1 = (num1 + num2 + num3 * num4) / den;

      const num5 = 2 * Math.sin(a1 - a2);
      const num6 = v1 * v1 * l1 * (m1 + m2);
      const num7 = g * (m1 + m2) * Math.cos(a1);
      const num8 = v2 * v2 * l2 * m2 * Math.cos(a1 - a2);
      const den2 = l2 * (2 * m1 + m2 - m2 * Math.cos(2 * a1 - 2 * a2));
      const acc2 = (num5 * (num6 + num7 + num8)) / den2;

      this.v1 += acc1 * subDt;
      this.v2 += acc2 * subDt;
      this.a1 += this.v1 * subDt;
      this.a2 += this.v2 * subDt;

      // Damping
      this.v1 *= 0.9999;
      this.v2 *= 0.9999;
    }

    // Calculate end positions
    const x1 = this.ox + this.l1 * Math.sin(this.a1);
    const y1 = this.oy + this.l1 * Math.cos(this.a1);
    const x2 = x1 + this.l2 * Math.sin(this.a2);
    const y2 = y1 + this.l2 * Math.cos(this.a2);

    this.x1 = x1;
    this.y1 = y1;
    this.x2 = x2;
    this.y2 = y2;

    // Add to trail
    this.trail.push({ x: x2, y: y2, v: Math.abs(this.v2) });
    if (this.trail.length > this.maxTrail) {
      this.trail.shift();
    }
  }

  draw() {
    // Draw trail with gradient based on velocity and age
    if (this.trail.length > 1) {
      for (let i = 1; i < this.trail.length; i++) {
        const p1 = this.trail[i - 1];
        const p2 = this.trail[i];
        const age = i / this.trail.length;
        const vel = Math.min(p2.v * 0.1, 1);
        
        ctx.beginPath();
        ctx.moveTo(p1.x, p1.y);
        ctx.lineTo(p2.x, p2.y);
        
        // Color shifts based on velocity and hue
        const h = (this.hue + vel * 60) % 360;
        const alpha = age * 0.8 * (0.3 + vel * 0.7);
        ctx.strokeStyle = `hsla(${h}, 100%, 65%, ${alpha})`;
        ctx.lineWidth = 1 + vel * 2;
        ctx.stroke();
      }
    }

    // Draw arms
    ctx.beginPath();
    ctx.moveTo(this.ox, this.oy);
    ctx.lineTo(this.x1, this.y1);
    ctx.lineTo(this.x2, this.y2);
    ctx.strokeStyle = `hsla(${this.hue}, 60%, 50%, 0.4)`;
    ctx.lineWidth = 2;
    ctx.stroke();

    // Draw pivot
    ctx.beginPath();
    ctx.arc(this.ox, this.oy, 4, 0, Math.PI * 2);
    ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, 0.8)`;
    ctx.fill();

    // Draw joints with glow
    ctx.shadowBlur = 15;
    ctx.shadowColor = `hsla(${this.hue}, 100%, 60%, 0.8)`;
    
    ctx.beginPath();
    ctx.arc(this.x1, this.y1, 6, 0, Math.PI * 2);
    ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, 0.9)`;
    ctx.fill();

    ctx.beginPath();
    ctx.arc(this.x2, this.y2, 8, 0, Math.PI * 2);
    ctx.fillStyle = `hsla(${(this.hue + 30) % 360}, 100%, 70%, 1)`;
    ctx.fill();
    
    ctx.shadowBlur = 0;
  }

  perturb(mx, my, strength) {
    const dx1 = this.x1 - mx;
    const dy1 = this.y1 - my;
    const dx2 = this.x2 - mx;
    const dy2 = this.y2 - my;
    const d1 = Math.sqrt(dx1 * dx1 + dy1 * dy1);
    const d2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);
    
    if (d1 < 150) {
      this.v1 += (Math.random() - 0.5) * strength * (1 - d1 / 150);
    }
    if (d2 < 150) {
      this.v2 += (Math.random() - 0.5) * strength * (1 - d2 / 150);
    }
  }
}

let pendulums = [];

function spawnPendulum(x, y) {
  const scale = Math.min(W, H) * 0.15;
  const l1 = scale * (0.8 + Math.random() * 0.4);
  const l2 = scale * (0.8 + Math.random() * 0.4);
  const a1 = Math.PI * (0.5 + Math.random());
  const a2 = Math.PI * (0.5 + Math.random());
  
  // Palette: cyan (180), pink (320), purple (280)
  const hues = [180, 300, 320, 260];
  const hue = hues[pendulums.length % hues.length];
  
  const p = new DoublePendulum(x, y, l1, l2, 10, 10, a1, a2, hue);
  pendulums.push(p);
  
  if (pendulums.length > 6) {
    pendulums.shift();
  }
}

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  cx = W / 2;
  cy = H / 2;
}

function updateAudio() {
  if (!audioCtx || pendulums.length === 0) return;
  
  pendulums.forEach((p, i) => {
    if (i >= gainNodes.length) return;
    
    // Map angular velocity to pitch and volume
    const energy = Math.abs(p.v1) + Math.abs(p.v2);
    const freq = 80 + energy * 30;
    const vol = Math.min(energy * 0.02, 0.08);
    
    oscillators[i].frequency.setTargetAtTime(freq, audioCtx.currentTime, 0.1);
    gainNodes[i].gain.setTargetAtTime(vol, audioCtx.currentTime, 0.1);
  });
}

let mouseX = 0, mouseY = 0, mouseDown = false;

function animate() {
  // Fade trail
  ctx.fillStyle = 'rgba(10, 10, 15, 0.08)';
  ctx.fillRect(0, 0, W, H);

  // Update and draw pendulums
  pendulums.forEach(p => {
    if (mouseDown) {
      p.perturb(mouseX, mouseY, 0.3);
    }
    p.update();
    p.draw();
  });

  updateAudio();
  requestAnimationFrame(animate);
}

// Event listeners
window.addEventListener('resize', resize);

canvas.addEventListener('click', (e) => {
  initAudio();
  spawnPendulum(e.clientX, e.clientY);
});

canvas.addEventListener('mousedown', (e) => {
  initAudio();
  mouseDown = true;
  mouseX = e.clientX;
  mouseY = e.clientY;
});

canvas.addEventListener('mouseup', () => mouseDown = false);
canvas.addEventListener('mouseleave', () => mouseDown = false);

canvas.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
});

// Touch support
canvas.addEventListener('touchstart', (e) => {
  e.preventDefault();
  initAudio();
  const touch = e.touches[0];
  spawnPendulum(touch.clientX, touch.clientY);
  mouseDown = true;
  mouseX = touch.clientX;
  mouseY = touch.clientY;
});

canvas.addEventListener('touchmove', (e) => {
  const touch = e.touches[0];
  mouseX = touch.clientX;
  mouseY = touch.clientY;
});

canvas.addEventListener('touchend', () => mouseDown = false);

// Initialize
resize();

// Spawn initial pendulums showing chaos divergence
setTimeout(() => {
  const baseAngle = Math.PI * 0.75;
  for (let i = 0; i < 3; i++) {
    const scale = Math.min(W, H) * 0.18;
    const offset = (i - 1) * 80;
    // Tiny differences in initial angle
    const a1 = baseAngle + i * 0.001;
    const a2 = baseAngle + i * 0.001;
    const hues = [180, 300, 320];
    const p = new DoublePendulum(cx + offset, cy - 100, scale, scale, 10, 10, a1, a2, hues[i]);
    pendulums.push(p);
  }
}, 100);

animate();
</script>
</body>
</html>
