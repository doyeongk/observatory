<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>pulse</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0a; 
  overflow: hidden; 
  cursor: crosshair;
}
canvas { display: block; }
#start-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(10, 10, 10, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  cursor: pointer;
}
#start-overlay span {
  color: #ff66b2;
  font-family: monospace;
  font-size: 14px;
  letter-spacing: 2px;
  opacity: 0.7;
  animation: pulse-text 2s ease-in-out infinite;
}
@keyframes pulse-text {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.9; }
}
</style>
</head>
<body>
<div id="start-overlay"><span>click to feel the pulse</span></div>
<canvas id="canvas"></canvas>
<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
const overlay = document.getElementById('start-overlay');

let width, height, centerX, centerY;
let audioCtx, gainNode;
let heartRate = 72; // BPM
let lastBeat = 0;
let beatPhase = 0;
let mouseX = 0, mouseY = 0;
let audioStarted = false;

// Arterial network
let arteries = [];
let pulseWaves = [];

function resize() {
  width = canvas.width = window.innerWidth;
  height = canvas.height = window.innerHeight;
  centerX = width / 2;
  centerY = height / 2;
  generateArteries();
}

// Generate branching arterial tree
function generateArteries() {
  arteries = [];
  const numBranches = 6;
  
  for (let i = 0; i < numBranches; i++) {
    const angle = (i / numBranches) * Math.PI * 2 + Math.random() * 0.3;
    generateBranch(centerX, centerY, angle, 180, 8, 0);
  }
}

function generateBranch(x, y, angle, length, thickness, depth) {
  if (depth > 6 || length < 15) return;
  
  const segments = [];
  let cx = x, cy = y;
  const segmentLength = length / 8;
  
  for (let i = 0; i < 8; i++) {
    const wobble = (Math.random() - 0.5) * 0.15;
    cx += Math.cos(angle + wobble) * segmentLength;
    cy += Math.sin(angle + wobble) * segmentLength;
    segments.push({ x: cx, y: cy });
  }
  
  arteries.push({
    startX: x,
    startY: y,
    segments,
    thickness,
    depth,
    pulseOffset: Math.random() * Math.PI * 2,
    hue: depth < 2 ? 330 : (depth < 4 ? 280 : 190) // pink -> purple -> cyan
  });
  
  // Branch
  const endX = segments[segments.length - 1].x;
  const endY = segments[segments.length - 1].y;
  
  if (Math.random() > 0.3) {
    generateBranch(endX, endY, angle + 0.4 + Math.random() * 0.3, length * 0.7, thickness * 0.7, depth + 1);
  }
  if (Math.random() > 0.3) {
    generateBranch(endX, endY, angle - 0.4 - Math.random() * 0.3, length * 0.7, thickness * 0.7, depth + 1);
  }
}

// Audio synthesis for heartbeat
function initAudio() {
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  gainNode = audioCtx.createGain();
  gainNode.connect(audioCtx.destination);
  gainNode.gain.value = 0;
}

function playHeartbeat() {
  if (!audioCtx) return;
  
  const now = audioCtx.currentTime;
  
  // First thump (lub)
  createThump(now, 55, 0.12, 0.4);
  
  // Second thump (dub) - slightly higher, quieter
  createThump(now + 0.12, 45, 0.08, 0.25);
}

function createThump(time, freq, duration, volume) {
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  const filter = audioCtx.createBiquadFilter();
  
  osc.type = 'sine';
  osc.frequency.setValueAtTime(freq, time);
  osc.frequency.exponentialRampToValueAtTime(freq * 0.5, time + duration);
  
  filter.type = 'lowpass';
  filter.frequency.value = 150;
  
  gain.gain.setValueAtTime(0, time);
  gain.gain.linearRampToValueAtTime(volume, time + 0.015);
  gain.gain.exponentialRampToValueAtTime(0.001, time + duration);
  
  osc.connect(filter);
  filter.connect(gain);
  gain.connect(audioCtx.destination);
  
  osc.start(time);
  osc.stop(time + duration + 0.1);
}

function update(time) {
  // Mouse distance from center affects heart rate
  const dx = mouseX - centerX;
  const dy = mouseY - centerY;
  const dist = Math.sqrt(dx * dx + dy * dy);
  const maxDist = Math.min(width, height) / 2;
  
  // Close to center = calm (60 BPM), far = anxious (120 BPM)
  const targetRate = 60 + (dist / maxDist) * 60;
  heartRate += (targetRate - heartRate) * 0.02;
  
  const beatInterval = 60000 / heartRate;
  
  if (time - lastBeat > beatInterval) {
    lastBeat = time;
    beatPhase = 1;
    
    if (audioStarted) {
      playHeartbeat();
    }
    
    // Spawn pulse wave
    pulseWaves.push({
      radius: 0,
      maxRadius: maxDist * 1.5,
      alpha: 1,
      birth: time
    });
  }
  
  // Decay beat phase
  beatPhase *= 0.92;
  
  // Update pulse waves
  pulseWaves = pulseWaves.filter(wave => {
    wave.radius += 8 + heartRate / 20;
    wave.alpha = 1 - (wave.radius / wave.maxRadius);
    return wave.alpha > 0;
  });
}

function draw(time) {
  // Dark fade with slight persistence
  ctx.fillStyle = 'rgba(10, 10, 10, 0.15)';
  ctx.fillRect(0, 0, width, height);
  
  // Draw pulse waves
  pulseWaves.forEach(wave => {
    const gradient = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, wave.radius);
    gradient.addColorStop(0, `rgba(255, 102, 178, 0)`);
    gradient.addColorStop(0.7, `rgba(255, 102, 178, ${wave.alpha * 0.05})`);
    gradient.addColorStop(1, `rgba(255, 102, 178, 0)`);
    
    ctx.beginPath();
    ctx.arc(centerX, centerY, wave.radius, 0, Math.PI * 2);
    ctx.fillStyle = gradient;
    ctx.fill();
  });
  
  // Draw arteries
  arteries.forEach(artery => {
    const pulseProgress = Math.sin(time * 0.003 * (heartRate / 72) + artery.pulseOffset);
    const expansion = 1 + beatPhase * 0.4 * (1 - artery.depth / 7);
    const thickness = artery.thickness * expansion;
    
    // Blood flow glow
    const flowIntensity = 0.3 + beatPhase * 0.7;
    
    ctx.beginPath();
    ctx.moveTo(artery.startX, artery.startY);
    
    artery.segments.forEach((seg, i) => {
      const wobble = Math.sin(time * 0.002 + i + artery.pulseOffset) * (2 - artery.depth * 0.2);
      ctx.lineTo(seg.x + wobble, seg.y + wobble);
    });
    
    // Outer glow
    ctx.strokeStyle = `hsla(${artery.hue}, 100%, 60%, ${flowIntensity * 0.3})`;
    ctx.lineWidth = thickness * 3;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.stroke();
    
    // Core
    ctx.strokeStyle = `hsla(${artery.hue}, 100%, 70%, ${flowIntensity * 0.8})`;
    ctx.lineWidth = thickness;
    ctx.stroke();
    
    // Bright center
    ctx.strokeStyle = `hsla(${artery.hue}, 50%, 90%, ${flowIntensity * 0.5})`;
    ctx.lineWidth = thickness * 0.3;
    ctx.stroke();
  });
  
  // Central heart
  const heartSize = 30 + beatPhase * 25;
  const heartGlow = 60 + beatPhase * 40;
  
  // Outer glow
  const gradient = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, heartGlow);
  gradient.addColorStop(0, `rgba(255, 102, 178, ${0.4 + beatPhase * 0.4})`);
  gradient.addColorStop(0.5, `rgba(180, 50, 180, ${0.2 + beatPhase * 0.2})`);
  gradient.addColorStop(1, 'rgba(100, 0, 100, 0)');
  
  ctx.beginPath();
  ctx.arc(centerX, centerY, heartGlow, 0, Math.PI * 2);
  ctx.fillStyle = gradient;
  ctx.fill();
  
  // Heart core
  ctx.beginPath();
  ctx.arc(centerX, centerY, heartSize, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(255, 102, 178, ${0.8 + beatPhase * 0.2})`;
  ctx.fill();
  
  // Inner bright spot
  ctx.beginPath();
  ctx.arc(centerX, centerY, heartSize * 0.4, 0, Math.PI * 2);
  ctx.fillStyle = `rgba(255, 200, 230, ${0.6 + beatPhase * 0.4})`;
  ctx.fill();
  
  // BPM display
  ctx.font = '12px monospace';
  ctx.fillStyle = `rgba(0, 255, 255, ${0.3 + beatPhase * 0.3})`;
  ctx.textAlign = 'center';
  ctx.fillText(`${Math.round(heartRate)} BPM`, centerX, height - 30);
}

function animate(time) {
  update(time);
  draw(time);
  requestAnimationFrame(animate);
}

// Event listeners
window.addEventListener('resize', resize);

document.addEventListener('mousemove', e => {
  mouseX = e.clientX;
  mouseY = e.clientY;
});

document.addEventListener('click', () => {
  if (!audioStarted) {
    overlay.style.display = 'none';
    initAudio();
    audioStarted = true;
    // Force immediate beat
    lastBeat = 0;
  }
});

// Touch support
document.addEventListener('touchmove', e => {
  if (e.touches.length > 0) {
    mouseX = e.touches[0].clientX;
    mouseY = e.touches[0].clientY;
  }
});

document.addEventListener('touchstart', () => {
  if (!audioStarted) {
    overlay.style.display = 'none';
    initAudio();
    audioStarted = true;
    lastBeat = 0;
  }
});

// Initialize
resize();
mouseX = centerX;
mouseY = centerY;
requestAnimationFrame(animate);
</script>
</body>
</html>
