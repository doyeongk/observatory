<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>murmuration</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0f; 
  overflow: hidden; 
  cursor: none;
}
canvas { display: block; }
#info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  color: rgba(255, 100, 200, 0.3);
  font-family: monospace;
  font-size: 11px;
  pointer-events: none;
}
</style>
</head>
<body>
<canvas id="canvas"></canvas>
<div id="info">move to guide · click to scatter</div>
<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');

let W, H;
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// Mouse state
const mouse = { x: W/2, y: H/2, active: false, scary: false };
canvas.addEventListener('mousemove', e => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
  mouse.active = true;
});
canvas.addEventListener('mouseleave', () => mouse.active = false);
canvas.addEventListener('mousedown', () => mouse.scary = true);
canvas.addEventListener('mouseup', () => mouse.scary = false);

// Boid class
class Boid {
  constructor() {
    this.x = Math.random() * W;
    this.y = Math.random() * H;
    this.vx = (Math.random() - 0.5) * 4;
    this.vy = (Math.random() - 0.5) * 4;
    this.history = [];
    this.maxHistory = 8;
  }
  
  update(boids) {
    // Flocking forces
    let alignX = 0, alignY = 0, alignCount = 0;
    let cohesionX = 0, cohesionY = 0, cohesionCount = 0;
    let separationX = 0, separationY = 0;
    
    const perceptionRadius = 80;
    const separationRadius = 25;
    
    for (const other of boids) {
      if (other === this) continue;
      
      const dx = other.x - this.x;
      const dy = other.y - this.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      
      if (dist < perceptionRadius) {
        // Alignment
        alignX += other.vx;
        alignY += other.vy;
        alignCount++;
        
        // Cohesion
        cohesionX += other.x;
        cohesionY += other.y;
        cohesionCount++;
      }
      
      if (dist < separationRadius && dist > 0) {
        // Separation
        separationX -= dx / dist;
        separationY -= dy / dist;
      }
    }
    
    // Apply alignment
    if (alignCount > 0) {
      alignX /= alignCount;
      alignY /= alignCount;
      const alignMag = Math.sqrt(alignX * alignX + alignY * alignY);
      if (alignMag > 0) {
        alignX = (alignX / alignMag) * 3 - this.vx;
        alignY = (alignY / alignMag) * 3 - this.vy;
      }
    }
    
    // Apply cohesion
    if (cohesionCount > 0) {
      cohesionX = cohesionX / cohesionCount - this.x;
      cohesionY = cohesionY / cohesionCount - this.y;
      const cohMag = Math.sqrt(cohesionX * cohesionX + cohesionY * cohesionY);
      if (cohMag > 0) {
        cohesionX = (cohesionX / cohMag) * 3 - this.vx;
        cohesionY = (cohesionY / cohMag) * 3 - this.vy;
      }
    }
    
    // Weight the forces
    this.vx += alignX * 0.05 + cohesionX * 0.03 + separationX * 0.15;
    this.vy += alignY * 0.05 + cohesionY * 0.03 + separationY * 0.15;
    
    // Mouse interaction
    if (mouse.active) {
      const mdx = mouse.x - this.x;
      const mdy = mouse.y - this.y;
      const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
      
      if (mDist < 200) {
        const force = (200 - mDist) / 200;
        if (mouse.scary) {
          // Flee!
          this.vx -= (mdx / mDist) * force * 2;
          this.vy -= (mdy / mDist) * force * 2;
        } else {
          // Gentle attraction
          this.vx += (mdx / mDist) * force * 0.3;
          this.vy += (mdy / mDist) * force * 0.3;
        }
      }
    }
    
    // Speed limits
    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
    const maxSpeed = 5;
    const minSpeed = 1.5;
    if (speed > maxSpeed) {
      this.vx = (this.vx / speed) * maxSpeed;
      this.vy = (this.vy / speed) * maxSpeed;
    } else if (speed < minSpeed) {
      this.vx = (this.vx / speed) * minSpeed;
      this.vy = (this.vy / speed) * minSpeed;
    }
    
    // Update position
    this.x += this.vx;
    this.y += this.vy;
    
    // Wrap around edges (with soft margin)
    const margin = 50;
    if (this.x < -margin) this.x = W + margin;
    if (this.x > W + margin) this.x = -margin;
    if (this.y < -margin) this.y = H + margin;
    if (this.y > H + margin) this.y = -margin;
    
    // Store history for trails
    this.history.push({ x: this.x, y: this.y });
    if (this.history.length > this.maxHistory) {
      this.history.shift();
    }
  }
  
  draw() {
    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
    const angle = Math.atan2(this.vy, this.vx);
    
    // Color based on direction
    const hueBase = (angle + Math.PI) / (Math.PI * 2);
    // Map to cyan-pink-purple range
    const hue = 280 + hueBase * 100; // 280-380 (wraps to pink-purple-cyan)
    
    // Draw trail
    if (this.history.length > 1) {
      ctx.beginPath();
      ctx.moveTo(this.history[0].x, this.history[0].y);
      for (let i = 1; i < this.history.length; i++) {
        ctx.lineTo(this.history[i].x, this.history[i].y);
      }
      ctx.strokeStyle = `hsla(${hue}, 80%, 60%, ${0.1 + speed * 0.02})`;
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    
    // Draw boid as small triangle
    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.rotate(angle);
    
    ctx.beginPath();
    ctx.moveTo(6, 0);
    ctx.lineTo(-4, 3);
    ctx.lineTo(-4, -3);
    ctx.closePath();
    
    ctx.fillStyle = `hsl(${hue}, 80%, ${55 + speed * 5}%)`;
    ctx.fill();
    
    ctx.restore();
  }
}

// Create flock
const boids = [];
const numBoids = Math.min(250, Math.floor((W * H) / 8000)); // Scale with screen
for (let i = 0; i < numBoids; i++) {
  boids.push(new Boid());
}

// Background fade canvas
const fadeCanvas = document.createElement('canvas');
const fadeCtx = fadeCanvas.getContext('2d');
fadeCanvas.width = W;
fadeCanvas.height = H;

window.addEventListener('resize', () => {
  fadeCanvas.width = W;
  fadeCanvas.height = H;
});

// Animation loop
function animate() {
  // Subtle fade for motion blur
  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';
  ctx.fillRect(0, 0, W, H);
  
  // Update and draw all boids
  for (const boid of boids) {
    boid.update(boids);
  }
  for (const boid of boids) {
    boid.draw();
  }
  
  // Draw mouse glow when active
  if (mouse.active) {
    const gradient = ctx.createRadialGradient(
      mouse.x, mouse.y, 0,
      mouse.x, mouse.y, mouse.scary ? 100 : 60
    );
    if (mouse.scary) {
      gradient.addColorStop(0, 'rgba(255, 50, 100, 0.2)');
      gradient.addColorStop(1, 'rgba(255, 50, 100, 0)');
    } else {
      gradient.addColorStop(0, 'rgba(0, 255, 255, 0.15)');
      gradient.addColorStop(1, 'rgba(0, 255, 255, 0)');
    }
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, W, H);
  }
  
  requestAnimationFrame(animate);
}

// Initial background
ctx.fillStyle = '#0a0a0f';
ctx.fillRect(0, 0, W, H);

animate();
</script>
</body>
</html>
