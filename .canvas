<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>tension</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0f; 
  overflow: hidden; 
  cursor: crosshair;
}
canvas { display: block; }
#info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  color: rgba(255,100,180,0.6);
  font: 12px/1.4 'Courier New', monospace;
  pointer-events: none;
  text-shadow: 0 0 10px rgba(255,100,180,0.3);
}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="info">hold still to build tension<br>move to release<br>click to force snap</div>
<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

let W, H;
const GRID = 24;
let cols, rows;
let tension = [];
let velocity = [];
let mouse = { x: -1000, y: -1000, px: -1000, py: -1000 };
let mouseStill = 0;
let globalTension = 0;

// Web Audio
let audioCtx, masterGain, droneOsc, droneGain, noiseNode, noiseGain;
let audioStarted = false;

function initAudio() {
  if (audioStarted) return;
  audioStarted = true;
  
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  masterGain = audioCtx.createGain();
  masterGain.gain.value = 0.3;
  masterGain.connect(audioCtx.destination);
  
  // Tension drone - low rumbling
  droneOsc = audioCtx.createOscillator();
  droneOsc.type = 'sawtooth';
  droneOsc.frequency.value = 55;
  droneGain = audioCtx.createGain();
  droneGain.gain.value = 0;
  
  const droneFilter = audioCtx.createBiquadFilter();
  droneFilter.type = 'lowpass';
  droneFilter.frequency.value = 200;
  
  droneOsc.connect(droneFilter);
  droneFilter.connect(droneGain);
  droneGain.connect(masterGain);
  droneOsc.start();
  
  // Second drone for thickness
  const droneOsc2 = audioCtx.createOscillator();
  droneOsc2.type = 'sawtooth';
  droneOsc2.frequency.value = 55.5; // slight detune
  droneOsc2.connect(droneFilter);
  droneOsc2.start();
  
  // Noise for texture
  const bufferSize = audioCtx.sampleRate * 2;
  const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
  const output = noiseBuffer.getChannelData(0);
  for (let i = 0; i < bufferSize; i++) {
    output[i] = Math.random() * 2 - 1;
  }
  noiseNode = audioCtx.createBufferSource();
  noiseNode.buffer = noiseBuffer;
  noiseNode.loop = true;
  
  noiseGain = audioCtx.createGain();
  noiseGain.gain.value = 0;
  
  const noiseFilter = audioCtx.createBiquadFilter();
  noiseFilter.type = 'bandpass';
  noiseFilter.frequency.value = 400;
  noiseFilter.Q.value = 2;
  
  noiseNode.connect(noiseFilter);
  noiseFilter.connect(noiseGain);
  noiseGain.connect(masterGain);
  noiseNode.start();
}

function playRelease(intensity) {
  if (!audioCtx) return;
  
  // Release whoosh
  const osc = audioCtx.createOscillator();
  osc.type = 'sine';
  osc.frequency.value = 300 + intensity * 200;
  
  const gain = audioCtx.createGain();
  gain.gain.value = Math.min(0.4, intensity * 0.3);
  
  const filter = audioCtx.createBiquadFilter();
  filter.type = 'lowpass';
  filter.frequency.value = 800;
  
  osc.connect(filter);
  filter.connect(gain);
  gain.connect(masterGain);
  
  osc.frequency.exponentialRampToValueAtTime(80, audioCtx.currentTime + 0.3);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.5);
  
  osc.start();
  osc.stop(audioCtx.currentTime + 0.5);
  
  // Snap click
  const click = audioCtx.createOscillator();
  click.type = 'square';
  click.frequency.value = 1200;
  const clickGain = audioCtx.createGain();
  clickGain.gain.value = intensity * 0.2;
  click.connect(clickGain);
  clickGain.connect(masterGain);
  clickGain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
  click.start();
  click.stop(audioCtx.currentTime + 0.05);
}

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  cols = Math.ceil(W / GRID) + 1;
  rows = Math.ceil(H / GRID) + 1;
  
  // Initialize/resize arrays
  tension = [];
  velocity = [];
  for (let i = 0; i < cols * rows; i++) {
    tension[i] = tension[i] || 0;
    velocity[i] = velocity[i] || 0;
  }
}

function idx(x, y) {
  return y * cols + x;
}

function update() {
  // Check mouse movement
  const dx = mouse.x - mouse.px;
  const dy = mouse.y - mouse.py;
  const movement = Math.sqrt(dx * dx + dy * dy);
  
  if (movement < 2) {
    mouseStill = Math.min(mouseStill + 1, 300);
  } else {
    // Movement releases tension around mouse
    const mx = Math.floor(mouse.x / GRID);
    const my = Math.floor(mouse.y / GRID);
    const releaseRadius = 4 + movement * 0.1;
    
    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        const dist = Math.sqrt((x - mx) ** 2 + (y - my) ** 2);
        if (dist < releaseRadius) {
          const factor = 1 - dist / releaseRadius;
          const released = tension[idx(x, y)] * factor * 0.3;
          tension[idx(x, y)] -= released;
          if (released > 0.1) {
            velocity[idx(x, y)] -= released * 0.5;
          }
        }
      }
    }
    mouseStill = Math.max(0, mouseStill - 10);
  }
  
  mouse.px = mouse.x;
  mouse.py = mouse.y;
  
  // Build tension where mouse hovers (when still)
  if (mouseStill > 30 && mouse.x > 0) {
    const mx = Math.floor(mouse.x / GRID);
    const my = Math.floor(mouse.y / GRID);
    const buildRadius = 3 + mouseStill * 0.02;
    const buildRate = 0.01 + mouseStill * 0.0005;
    
    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        const dist = Math.sqrt((x - mx) ** 2 + (y - my) ** 2);
        if (dist < buildRadius) {
          const factor = 1 - dist / buildRadius;
          tension[idx(x, y)] += buildRate * factor;
        }
      }
    }
  }
  
  // Natural tension diffusion and buildup
  const newTension = [...tension];
  globalTension = 0;
  
  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {
      const i = idx(x, y);
      
      // Slight ambient tension buildup
      tension[i] += 0.0003;
      
      // Apply velocity
      tension[i] += velocity[i];
      velocity[i] *= 0.95;
      
      // Diffuse to neighbors
      let sum = 0;
      let count = 0;
      if (x > 0) { sum += tension[idx(x-1, y)]; count++; }
      if (x < cols-1) { sum += tension[idx(x+1, y)]; count++; }
      if (y > 0) { sum += tension[idx(x, y-1)]; count++; }
      if (y < rows-1) { sum += tension[idx(x, y+1)]; count++; }
      
      const avg = sum / count;
      newTension[i] = tension[i] * 0.98 + avg * 0.02;
      
      // Check for snap
      if (tension[i] > 1) {
        const excess = tension[i] - 0.2;
        newTension[i] = 0.2;
        velocity[i] = -excess * 0.3;
        
        // Propagate release to neighbors
        if (x > 0) velocity[idx(x-1, y)] -= excess * 0.1;
        if (x < cols-1) velocity[idx(x+1, y)] -= excess * 0.1;
        if (y > 0) velocity[idx(x, y-1)] -= excess * 0.1;
        if (y < rows-1) velocity[idx(x, y+1)] -= excess * 0.1;
        
        playRelease(excess);
      }
      
      // Clamp
      newTension[i] = Math.max(0, Math.min(1.5, newTension[i]));
      globalTension += tension[i];
    }
  }
  
  tension = newTension;
  globalTension /= (cols * rows);
  
  // Update audio based on global tension
  if (audioCtx && droneGain) {
    droneGain.gain.value = globalTension * 0.4;
    noiseGain.gain.value = globalTension * 0.15;
    droneOsc.frequency.value = 55 + globalTension * 30;
  }
}

function draw() {
  // Clear with subtle fade for trails
  ctx.fillStyle = 'rgba(10, 10, 15, 0.3)';
  ctx.fillRect(0, 0, W, H);
  
  // Draw tension field
  for (let y = 0; y < rows - 1; y++) {
    for (let x = 0; x < cols - 1; x++) {
      const t = tension[idx(x, y)];
      const t_right = tension[idx(x + 1, y)];
      const t_down = tension[idx(x, y + 1)];
      const t_diag = tension[idx(x + 1, y + 1)];
      const avgT = (t + t_right + t_down + t_diag) / 4;
      
      if (avgT > 0.05) {
        const px = x * GRID;
        const py = y * GRID;
        
        // Color based on tension level
        const r = Math.floor(80 + avgT * 175);
        const g = Math.floor(20 + avgT * 30);
        const b = Math.floor(120 + avgT * 80);
        const a = Math.min(1, avgT * 1.5);
        
        // Draw cell
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${a * 0.6})`;
        ctx.fillRect(px, py, GRID, GRID);
        
        // Draw stress lines where tension is high
        if (avgT > 0.4) {
          ctx.strokeStyle = `rgba(${r + 50}, ${g + 50}, ${b + 50}, ${a * 0.8})`;
          ctx.lineWidth = avgT * 2;
          
          // Connect to neighbors with visible tension
          ctx.beginPath();
          ctx.moveTo(px + GRID/2, py + GRID/2);
          
          if (t_right > 0.3) {
            ctx.lineTo(px + GRID * 1.5, py + GRID/2);
            ctx.moveTo(px + GRID/2, py + GRID/2);
          }
          if (t_down > 0.3) {
            ctx.lineTo(px + GRID/2, py + GRID * 1.5);
          }
          ctx.stroke();
        }
        
        // Critical tension glow
        if (avgT > 0.7) {
          const glow = ctx.createRadialGradient(
            px + GRID/2, py + GRID/2, 0,
            px + GRID/2, py + GRID/2, GRID * (avgT + 0.5)
          );
          glow.addColorStop(0, `rgba(255, 100, 200, ${(avgT - 0.7) * 2})`);
          glow.addColorStop(0.5, `rgba(180, 50, 255, ${(avgT - 0.7)})`);
          glow.addColorStop(1, 'rgba(100, 200, 255, 0)');
          ctx.fillStyle = glow;
          ctx.fillRect(px - GRID, py - GRID, GRID * 3, GRID * 3);
        }
      }
    }
  }
  
  // Draw release ripples (negative velocity = release)
  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {
      const v = velocity[idx(x, y)];
      if (v < -0.05) {
        const px = x * GRID + GRID/2;
        const py = y * GRID + GRID/2;
        const intensity = Math.abs(v);
        
        ctx.beginPath();
        ctx.arc(px, py, GRID * intensity * 3, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(100, 220, 255, ${intensity})`;
        ctx.lineWidth = 2;
        ctx.stroke();
      }
    }
  }
  
  // Mouse indicator when building tension
  if (mouseStill > 30 && mouse.x > 0) {
    const radius = 10 + mouseStill * 0.1;
    const glow = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, radius);
    glow.addColorStop(0, `rgba(255, 100, 180, ${mouseStill / 300})`);
    glow.addColorStop(1, 'rgba(255, 100, 180, 0)');
    ctx.fillStyle = glow;
    ctx.beginPath();
    ctx.arc(mouse.x, mouse.y, radius, 0, Math.PI * 2);
    ctx.fill();
    
    // Pulsing ring
    const pulse = Math.sin(Date.now() * 0.01) * 5;
    ctx.beginPath();
    ctx.arc(mouse.x, mouse.y, radius + pulse, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(180, 50, 255, ${mouseStill / 400})`;
    ctx.lineWidth = 1;
    ctx.stroke();
  }
  
  // Global tension indicator
  const barWidth = 100;
  const barHeight = 4;
  const barX = W - barWidth - 20;
  const barY = 20;
  
  ctx.fillStyle = 'rgba(50, 30, 60, 0.5)';
  ctx.fillRect(barX, barY, barWidth, barHeight);
  
  const tensionColor = globalTension < 0.3 ? 'rgba(100, 200, 220, 0.8)' : 
                       globalTension < 0.6 ? 'rgba(180, 100, 220, 0.8)' : 
                       'rgba(255, 100, 180, 0.8)';
  ctx.fillStyle = tensionColor;
  ctx.fillRect(barX, barY, barWidth * Math.min(1, globalTension / 0.8), barHeight);
}

function forceSnap() {
  // Find highest tension point and trigger snap
  let maxT = 0;
  let maxI = 0;
  for (let i = 0; i < tension.length; i++) {
    if (tension[i] > maxT) {
      maxT = tension[i];
      maxI = i;
    }
  }
  
  if (maxT > 0.2) {
    tension[maxI] = 1.2; // Force it over threshold
  } else {
    // Add tension at mouse position
    const mx = Math.floor(mouse.x / GRID);
    const my = Math.floor(mouse.y / GRID);
    if (mx >= 0 && mx < cols && my >= 0 && my < rows) {
      tension[idx(mx, my)] = 1.2;
    }
  }
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

// Events
window.addEventListener('resize', resize);

canvas.addEventListener('mousemove', e => {
  initAudio();
  mouse.x = e.clientX;
  mouse.y = e.clientY;
});

canvas.addEventListener('touchmove', e => {
  initAudio();
  e.preventDefault();
  mouse.x = e.touches[0].clientX;
  mouse.y = e.touches[0].clientY;
});

canvas.addEventListener('click', () => {
  initAudio();
  forceSnap();
});

canvas.addEventListener('touchstart', e => {
  initAudio();
  mouse.x = e.touches[0].clientX;
  mouse.y = e.touches[0].clientY;
});

// Init
resize();
loop();
</script>
</body>
</html>
