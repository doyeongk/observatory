<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>fracture</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      background: #0a0a0f; 
      overflow: hidden; 
      cursor: crosshair;
    }
    canvas { display: block; }
    #hint {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255, 0, 127, 0.4);
      font-family: 'Courier New', monospace;
      font-size: 12px;
      letter-spacing: 2px;
      pointer-events: none;
      transition: opacity 2s;
    }
  </style>
</head>
<body>
  <canvas id="canvas"></canvas>
  <div id="hint">click to fracture</div>
  <script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const hint = document.getElementById('hint');
    
    let W, H;
    const cracks = [];
    const maxDepth = 7;
    let clickCount = 0;
    
    // Colors from palette
    const colors = {
      cyan: '#00ffff',
      pink: '#ff0080',
      purple: '#8b00ff',
      white: '#ffffff'
    };
    
    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
      redraw();
    }
    
    class Crack {
      constructor(x, y, angle, depth, parent) {
        this.x = x;
        this.y = y;
        this.angle = angle;
        this.depth = depth;
        this.parent = parent;
        this.length = 0;
        this.maxLength = (80 + Math.random() * 120) * Math.pow(0.7, depth);
        this.speed = (3 + Math.random() * 4) * Math.pow(0.85, depth);
        this.branched = false;
        this.done = false;
        this.segments = [{x, y}];
        this.branchChance = 0.02 + depth * 0.005;
        this.wobble = (Math.random() - 0.5) * 0.3;
        
        // Color based on depth
        const t = depth / maxDepth;
        if (t < 0.3) {
          this.color = colors.cyan;
          this.glow = colors.cyan;
        } else if (t < 0.6) {
          this.color = colors.pink;
          this.glow = colors.pink;
        } else {
          this.color = colors.purple;
          this.glow = colors.purple;
        }
        this.alpha = 1 - (depth * 0.1);
      }
      
      update() {
        if (this.done) return;
        
        // Grow
        const prevX = this.segments[this.segments.length - 1].x;
        const prevY = this.segments[this.segments.length - 1].y;
        
        // Slight angle wobble
        this.angle += (Math.random() - 0.5) * 0.15 + this.wobble * 0.02;
        
        const newX = prevX + Math.cos(this.angle) * this.speed;
        const newY = prevY + Math.sin(this.angle) * this.speed;
        
        this.segments.push({x: newX, y: newY});
        this.length += this.speed;
        
        // Branch chance increases as we grow
        if (!this.branched && this.depth < maxDepth && this.length > 20) {
          if (Math.random() < this.branchChance) {
            this.branch();
          }
        }
        
        // Done conditions
        if (this.length >= this.maxLength || 
            newX < -50 || newX > W + 50 || 
            newY < -50 || newY > H + 50) {
          this.done = true;
        }
      }
      
      branch() {
        this.branched = true;
        const lastSeg = this.segments[this.segments.length - 1];
        
        // Create 1-2 branches
        const numBranches = Math.random() < 0.4 ? 2 : 1;
        
        for (let i = 0; i < numBranches; i++) {
          const branchAngle = this.angle + (Math.random() - 0.5) * Math.PI * 0.8;
          cracks.push(new Crack(
            lastSeg.x, 
            lastSeg.y, 
            branchAngle, 
            this.depth + 1,
            this
          ));
        }
        
        // Maybe branch again later
        if (Math.random() < 0.3) {
          this.branched = false;
        }
      }
      
      draw() {
        if (this.segments.length < 2) return;
        
        const lineWidth = Math.max(0.5, 3 - this.depth * 0.4);
        
        // Glow layer
        ctx.save();
        ctx.strokeStyle = this.glow;
        ctx.lineWidth = lineWidth + 4;
        ctx.globalAlpha = this.alpha * 0.15;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.shadowColor = this.glow;
        ctx.shadowBlur = 15;
        
        ctx.beginPath();
        ctx.moveTo(this.segments[0].x, this.segments[0].y);
        for (let i = 1; i < this.segments.length; i++) {
          ctx.lineTo(this.segments[i].x, this.segments[i].y);
        }
        ctx.stroke();
        ctx.restore();
        
        // Main line
        ctx.save();
        ctx.strokeStyle = this.color;
        ctx.lineWidth = lineWidth;
        ctx.globalAlpha = this.alpha * 0.9;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        
        ctx.beginPath();
        ctx.moveTo(this.segments[0].x, this.segments[0].y);
        for (let i = 1; i < this.segments.length; i++) {
          ctx.lineTo(this.segments[i].x, this.segments[i].y);
        }
        ctx.stroke();
        ctx.restore();
        
        // Bright core for fresh segments
        if (!this.done && this.segments.length > 1) {
          const tip = this.segments[this.segments.length - 1];
          ctx.save();
          ctx.fillStyle = '#ffffff';
          ctx.globalAlpha = 0.8;
          ctx.shadowColor = this.color;
          ctx.shadowBlur = 10;
          ctx.beginPath();
          ctx.arc(tip.x, tip.y, lineWidth * 0.8, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }
      }
    }
    
    function spawnFracture(x, y) {
      // Spawn 3-5 initial cracks from impact point
      const numCracks = 3 + Math.floor(Math.random() * 3);
      const baseAngle = Math.random() * Math.PI * 2;
      
      for (let i = 0; i < numCracks; i++) {
        const angle = baseAngle + (i / numCracks) * Math.PI * 2 + (Math.random() - 0.5) * 0.5;
        cracks.push(new Crack(x, y, angle, 0, null));
      }
      
      // Impact flash
      ctx.save();
      ctx.fillStyle = colors.cyan;
      ctx.globalAlpha = 0.6;
      ctx.shadowColor = colors.cyan;
      ctx.shadowBlur = 30;
      ctx.beginPath();
      ctx.arc(x, y, 8, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
      
      clickCount++;
      if (clickCount === 1) {
        hint.style.opacity = '0';
      }
    }
    
    function redraw() {
      // Clear with slight trail
      ctx.fillStyle = 'rgba(10, 10, 15, 1)';
      ctx.fillRect(0, 0, W, H);
      
      // Draw all cracks
      for (const crack of cracks) {
        crack.draw();
      }
    }
    
    function animate() {
      // Very subtle fade for the growing tips
      ctx.fillStyle = 'rgba(10, 10, 15, 0.03)';
      ctx.fillRect(0, 0, W, H);
      
      // Redraw all (cracks are permanent)
      for (const crack of cracks) {
        crack.draw();
      }
      
      // Update growing cracks
      let anyActive = false;
      for (const crack of cracks) {
        if (!crack.done) {
          crack.update();
          anyActive = true;
        }
      }
      
      requestAnimationFrame(animate);
    }
    
    // Auto-spawn initial fractures for visual interest
    function autoSpawn() {
      if (cracks.length === 0) {
        // First auto-spawn after 3 seconds if no clicks
        setTimeout(() => {
          if (clickCount === 0) {
            spawnFracture(W * 0.3 + Math.random() * W * 0.4, H * 0.3 + Math.random() * H * 0.4);
          }
        }, 3000);
      }
    }
    
    // Events
    window.addEventListener('resize', resize);
    
    canvas.addEventListener('click', (e) => {
      spawnFracture(e.clientX, e.clientY);
    });
    
    canvas.addEventListener('touchstart', (e) => {
      e.preventDefault();
      const touch = e.touches[0];
      spawnFracture(touch.clientX, touch.clientY);
    }, { passive: false });
    
    // Keyboard: spacebar to clear and restart
    window.addEventListener('keydown', (e) => {
      if (e.code === 'Space') {
        cracks.length = 0;
        redraw();
      }
    });
    
    // Init
    resize();
    autoSpawn();
    animate();
  </script>
</body>
</html>
