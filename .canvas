<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>supernova</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #000; overflow: hidden; cursor: crosshair; }
    canvas { display: block; }
    #hint {
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255,100,180,0.4);
      font-family: monospace;
      font-size: 12px;
      pointer-events: none;
      transition: opacity 2s;
    }
  </style>
</head>
<body>
  <canvas id="c"></canvas>
  <div id="hint">click to collapse</div>
  <script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
let W, H, cx, cy;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  cx = W / 2;
  cy = H / 2;
}
resize();
window.addEventListener('resize', resize);

// Audio context
let audioCtx = null;
function initAudio() {
  if (audioCtx) return;
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
}

function playRumble(duration, intensity) {
  if (!audioCtx) return;
  const bufferSize = audioCtx.sampleRate * duration;
  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
  const data = buffer.getChannelData(0);
  for (let i = 0; i < bufferSize; i++) {
    const t = i / bufferSize;
    const env = Math.sin(t * Math.PI) * intensity;
    data[i] = (Math.random() * 2 - 1) * env * 0.3;
  }
  const source = audioCtx.createBufferSource();
  source.buffer = buffer;
  const filter = audioCtx.createBiquadFilter();
  filter.type = 'lowpass';
  filter.frequency.value = 150;
  const gain = audioCtx.createGain();
  gain.gain.value = 0.5;
  source.connect(filter);
  filter.connect(gain);
  gain.connect(audioCtx.destination);
  source.start();
}

function playBoom() {
  if (!audioCtx) return;
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(80, audioCtx.currentTime);
  osc.frequency.exponentialRampToValueAtTime(20, audioCtx.currentTime + 1.5);
  gain.gain.setValueAtTime(0.6, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 2);
  osc.connect(gain);
  gain.connect(audioCtx.destination);
  osc.start();
  osc.stop(audioCtx.currentTime + 2);
  
  // noise burst
  const bufferSize = audioCtx.sampleRate * 0.5;
  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
  const data = buffer.getChannelData(0);
  for (let i = 0; i < bufferSize; i++) {
    const t = i / bufferSize;
    data[i] = (Math.random() * 2 - 1) * Math.exp(-t * 8) * 0.4;
  }
  const noise = audioCtx.createBufferSource();
  noise.buffer = buffer;
  const noiseGain = audioCtx.createGain();
  noiseGain.gain.value = 0.7;
  noise.connect(noiseGain);
  noiseGain.connect(audioCtx.destination);
  noise.start();
}

// Star state
const STATES = { STABLE: 0, UNSTABLE: 1, COLLAPSE: 2, EXPLODE: 3, DEBRIS: 4, REFORM: 5 };
let state = STATES.STABLE;
let stateTime = 0;
let starRadius = 60;
let pulsePhase = 0;
let instability = 0;
let mouseX = cx, mouseY = cy;

// Debris particles
let debris = [];
let shockwave = { radius: 0, active: false, alpha: 0 };
let protoStars = [];

class Debris {
  constructor(x, y, vx, vy, size, hue) {
    this.x = x;
    this.y = y;
    this.vx = vx;
    this.vy = vy;
    this.size = size;
    this.hue = hue;
    this.life = 1;
    this.decay = 0.002 + Math.random() * 0.003;
    this.rotation = Math.random() * Math.PI * 2;
    this.rotSpeed = (Math.random() - 0.5) * 0.1;
  }
  
  update() {
    this.x += this.vx;
    this.y += this.vy;
    this.vx *= 0.995;
    this.vy *= 0.995;
    this.rotation += this.rotSpeed;
    this.life -= this.decay;
  }
  
  draw() {
    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.rotate(this.rotation);
    ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, ${this.life * 0.8})`;
    ctx.shadowColor = `hsla(${this.hue}, 100%, 60%, ${this.life})`;
    ctx.shadowBlur = this.size * 2;
    ctx.fillRect(-this.size/2, -this.size/2, this.size, this.size);
    ctx.restore();
  }
}

class ProtoStar {
  constructor(x, y) {
    this.x = x;
    this.y = y;
    this.radius = 0;
    this.targetRadius = 5 + Math.random() * 15;
    this.hue = 280 + Math.random() * 60; // purple to pink
    this.pulse = Math.random() * Math.PI * 2;
    this.life = 1;
  }
  
  update() {
    this.radius += (this.targetRadius - this.radius) * 0.02;
    this.pulse += 0.05;
  }
  
  draw() {
    const r = this.radius + Math.sin(this.pulse) * this.radius * 0.1;
    const gradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, r * 2);
    gradient.addColorStop(0, `hsla(${this.hue}, 100%, 90%, 0.9)`);
    gradient.addColorStop(0.3, `hsla(${this.hue}, 100%, 70%, 0.6)`);
    gradient.addColorStop(0.7, `hsla(${this.hue + 30}, 100%, 50%, 0.2)`);
    gradient.addColorStop(1, 'transparent');
    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.arc(this.x, this.y, r * 2, 0, Math.PI * 2);
    ctx.fill();
  }
}

// Background stars
const bgStars = [];
for (let i = 0; i < 200; i++) {
  bgStars.push({
    x: Math.random() * 2000 - 500,
    y: Math.random() * 2000 - 500,
    size: Math.random() * 1.5 + 0.5,
    twinkle: Math.random() * Math.PI * 2
  });
}

function drawBackground() {
  ctx.fillStyle = '#000';
  ctx.fillRect(0, 0, W, H);
  
  // Stars
  for (const star of bgStars) {
    star.twinkle += 0.02;
    const alpha = 0.3 + Math.sin(star.twinkle) * 0.2;
    ctx.fillStyle = `rgba(200, 180, 255, ${alpha})`;
    ctx.beginPath();
    ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
    ctx.fill();
  }
}

function drawStar() {
  const pulseAmount = state === STATES.UNSTABLE ? instability * 20 : 5;
  const currentRadius = starRadius + Math.sin(pulsePhase) * pulseAmount;
  
  // Core glow layers
  const layers = [
    { radius: currentRadius * 3, color: 'rgba(255, 50, 150, 0.05)' },
    { radius: currentRadius * 2, color: 'rgba(255, 100, 200, 0.1)' },
    { radius: currentRadius * 1.5, color: 'rgba(255, 150, 220, 0.2)' },
    { radius: currentRadius, color: 'rgba(255, 200, 240, 0.5)' },
    { radius: currentRadius * 0.7, color: 'rgba(255, 255, 255, 0.8)' },
  ];
  
  // Instability color shift
  const hueShift = state === STATES.UNSTABLE ? Math.sin(pulsePhase * 3) * 30 : 0;
  
  for (const layer of layers) {
    const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, layer.radius);
    gradient.addColorStop(0, layer.color);
    gradient.addColorStop(1, 'transparent');
    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.arc(cx, cy, layer.radius, 0, Math.PI * 2);
    ctx.fill();
  }
  
  // Corona flares
  if (state <= STATES.UNSTABLE) {
    ctx.save();
    ctx.translate(cx, cy);
    const flareCount = 8;
    for (let i = 0; i < flareCount; i++) {
      const angle = (i / flareCount) * Math.PI * 2 + pulsePhase * 0.2;
      const length = currentRadius * (1.5 + Math.sin(pulsePhase + i) * 0.5 * (1 + instability));
      
      ctx.save();
      ctx.rotate(angle);
      const gradient = ctx.createLinearGradient(0, 0, length, 0);
      gradient.addColorStop(0, `hsla(${320 + hueShift}, 100%, 80%, 0.6)`);
      gradient.addColorStop(1, 'transparent');
      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.moveTo(currentRadius * 0.8, 0);
      ctx.lineTo(length, -3 - instability * 5);
      ctx.lineTo(length, 3 + instability * 5);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    }
    ctx.restore();
  }
}

function drawCollapse() {
  const progress = Math.min(stateTime / 60, 1);
  const collapseRadius = starRadius * (1 - progress * 0.9);
  
  // Imploding glow
  const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, collapseRadius * 2);
  gradient.addColorStop(0, `rgba(255, 255, 255, ${0.9 + progress * 0.1})`);
  gradient.addColorStop(0.5, `rgba(200, 100, 255, ${0.5 - progress * 0.3})`);
  gradient.addColorStop(1, 'transparent');
  ctx.fillStyle = gradient;
  ctx.beginPath();
  ctx.arc(cx, cy, collapseRadius * 2, 0, Math.PI * 2);
  ctx.fill();
  
  // Inward streaks
  for (let i = 0; i < 20; i++) {
    const angle = (i / 20) * Math.PI * 2 + stateTime * 0.1;
    const innerR = collapseRadius;
    const outerR = starRadius * 2 * (1 - progress * 0.5);
    
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(angle);
    ctx.strokeStyle = `rgba(0, 255, 255, ${0.3 * (1 - progress)})`;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(innerR, 0);
    ctx.lineTo(outerR, 0);
    ctx.stroke();
    ctx.restore();
  }
  
  if (progress >= 1) {
    state = STATES.EXPLODE;
    stateTime = 0;
    triggerExplosion();
  }
}

function triggerExplosion() {
  playBoom();
  shockwave = { radius: 0, active: true, alpha: 1 };
  
  // Create debris
  const debrisCount = 150;
  for (let i = 0; i < debrisCount; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 3 + Math.random() * 8;
    const hue = Math.random() < 0.5 ? 320 + Math.random() * 40 : 180 + Math.random() * 30;
    debris.push(new Debris(
      cx, cy,
      Math.cos(angle) * speed,
      Math.sin(angle) * speed,
      3 + Math.random() * 8,
      hue
    ));
  }
}

function drawExplosion() {
  const progress = Math.min(stateTime / 30, 1);
  
  // Central flash
  if (progress < 0.3) {
    const flashAlpha = 1 - progress / 0.3;
    const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, 200 * progress * 3);
    gradient.addColorStop(0, `rgba(255, 255, 255, ${flashAlpha})`);
    gradient.addColorStop(0.5, `rgba(255, 200, 255, ${flashAlpha * 0.5})`);
    gradient.addColorStop(1, 'transparent');
    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.arc(cx, cy, 200 * progress * 3, 0, Math.PI * 2);
    ctx.fill();
  }
  
  if (progress >= 1) {
    state = STATES.DEBRIS;
    stateTime = 0;
  }
}

function drawShockwave() {
  if (!shockwave.active) return;
  
  shockwave.radius += 8;
  shockwave.alpha *= 0.985;
  
  if (shockwave.alpha < 0.01) {
    shockwave.active = false;
    return;
  }
  
  // Double ring
  ctx.strokeStyle = `rgba(0, 255, 255, ${shockwave.alpha})`;
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.arc(cx, cy, shockwave.radius, 0, Math.PI * 2);
  ctx.stroke();
  
  ctx.strokeStyle = `rgba(255, 100, 200, ${shockwave.alpha * 0.7})`;
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(cx, cy, shockwave.radius - 15, 0, Math.PI * 2);
  ctx.stroke();
  
  // Spawn proto-stars at shockwave edge occasionally
  if (state === STATES.DEBRIS && Math.random() < 0.03 && protoStars.length < 12) {
    const angle = Math.random() * Math.PI * 2;
    const dist = shockwave.radius + (Math.random() - 0.5) * 50;
    protoStars.push(new ProtoStar(
      cx + Math.cos(angle) * dist,
      cy + Math.sin(angle) * dist
    ));
  }
}

function drawDebris() {
  debris = debris.filter(d => d.life > 0);
  for (const d of debris) {
    d.update();
    d.draw();
  }
  
  // After debris fades, reform
  if (stateTime > 300 && debris.length < 20) {
    state = STATES.REFORM;
    stateTime = 0;
  }
}

function drawProtoStars() {
  for (const ps of protoStars) {
    ps.update();
    ps.draw();
  }
}

function drawReform() {
  const progress = Math.min(stateTime / 180, 1);
  
  // New star forming at center
  const newRadius = starRadius * progress * 0.7;
  const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, newRadius * 2);
  gradient.addColorStop(0, `rgba(200, 150, 255, ${progress * 0.8})`);
  gradient.addColorStop(0.5, `rgba(150, 100, 200, ${progress * 0.4})`);
  gradient.addColorStop(1, 'transparent');
  ctx.fillStyle = gradient;
  ctx.beginPath();
  ctx.arc(cx, cy, newRadius * 2, 0, Math.PI * 2);
  ctx.fill();
  
  if (progress >= 1) {
    state = STATES.STABLE;
    stateTime = 0;
    instability = 0;
    protoStars = [];
    document.getElementById('hint').style.opacity = '1';
  }
}

function update() {
  stateTime++;
  pulsePhase += 0.05;
  
  // Mouse proximity affects instability when stable
  if (state === STATES.STABLE) {
    const dx = mouseX - cx;
    const dy = mouseY - cy;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const maxDist = Math.min(W, H) / 2;
    const targetInstability = Math.max(0, 1 - dist / maxDist) * 0.5;
    instability += (targetInstability - instability) * 0.02;
    
    if (instability > 0.3) {
      state = STATES.UNSTABLE;
      playRumble(2, instability);
    }
  }
  
  // Unstable star grows more chaotic
  if (state === STATES.UNSTABLE) {
    const dx = mouseX - cx;
    const dy = mouseY - cy;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const maxDist = Math.min(W, H) / 2;
    instability += (1 - dist / maxDist) * 0.01;
    instability = Math.min(instability, 1.5);
    
    if (dist > maxDist * 0.8) {
      instability -= 0.01;
      if (instability < 0.1) {
        state = STATES.STABLE;
        instability = 0;
      }
    }
  }
}

function draw() {
  drawBackground();
  
  switch (state) {
    case STATES.STABLE:
    case STATES.UNSTABLE:
      drawStar();
      break;
    case STATES.COLLAPSE:
      drawCollapse();
      break;
    case STATES.EXPLODE:
      drawExplosion();
      drawShockwave();
      drawDebris();
      break;
    case STATES.DEBRIS:
      drawShockwave();
      drawDebris();
      drawProtoStars();
      break;
    case STATES.REFORM:
      drawProtoStars();
      drawReform();
      break;
  }
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

canvas.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
});

canvas.addEventListener('click', () => {
  initAudio();
  if (state === STATES.STABLE || state === STATES.UNSTABLE) {
    state = STATES.COLLAPSE;
    stateTime = 0;
    document.getElementById('hint').style.opacity = '0';
    playRumble(1, 1);
  }
});

// Hide hint after a while
setTimeout(() => {
  if (state === STATES.STABLE) {
    document.getElementById('hint').style.opacity = '0.2';
  }
}, 5000);

loop();
  </script>
</body>
</html>
