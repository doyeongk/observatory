<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>automaton</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0f; 
  overflow: hidden; 
  font-family: monospace;
}
canvas { display: block; }
#info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  color: #00ffff;
  font-size: 14px;
  opacity: 0.7;
  text-shadow: 0 0 10px #00ffff;
  pointer-events: none;
  z-index: 10;
}
#rule-display {
  position: fixed;
  top: 20px;
  right: 20px;
  color: #ff66b2;
  font-size: 24px;
  font-weight: bold;
  text-shadow: 0 0 20px #ff66b2;
  pointer-events: none;
  z-index: 10;
}
</style>
</head>
<body>
<canvas id="canvas"></canvas>
<div id="info">click: mutate · space: new rule · ←→: browse rules</div>
<div id="rule-display">RULE <span id="rule-num">110</span></div>

<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
const ruleNumEl = document.getElementById('rule-num');

let W, H, cellSize, cols, rows;
let currentRule = 110;
let ruleSet = [];
let grid = [];
let generation = 0;
let scrollOffset = 0;
let mouseX = 0, mouseY = 0;
let audioCtx = null;
let lastSoundTime = 0;

// Interesting rules to cycle through
const interestingRules = [30, 45, 54, 60, 73, 90, 105, 110, 150, 182, 225];

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  cellSize = Math.max(2, Math.floor(Math.min(W, H) / 200));
  cols = Math.floor(W / cellSize);
  rows = Math.floor(H / cellSize) + 50; // buffer for scrolling
  initGrid();
}

function initGrid() {
  grid = [];
  for (let y = 0; y < rows; y++) {
    grid[y] = new Array(cols).fill(0);
  }
  // Start with single cell in center
  grid[0][Math.floor(cols / 2)] = 1;
  // Add some random seeds for visual interest
  for (let i = 0; i < 5; i++) {
    grid[0][Math.floor(Math.random() * cols)] = 1;
  }
  generation = 0;
  scrollOffset = 0;
  computeRuleSet(currentRule);
}

function computeRuleSet(ruleNumber) {
  ruleSet = [];
  for (let i = 0; i < 8; i++) {
    ruleSet[i] = (ruleNumber >> i) & 1;
  }
  ruleNumEl.textContent = ruleNumber;
}

function applyRule(left, center, right) {
  const index = (left << 2) | (center << 1) | right;
  return ruleSet[index];
}

function nextGeneration() {
  if (generation >= rows - 1) {
    // Scroll everything up
    for (let y = 0; y < rows - 1; y++) {
      grid[y] = grid[y + 1].slice();
    }
    grid[rows - 1] = new Array(cols).fill(0);
    scrollOffset++;
  } else {
    generation++;
  }
  
  const y = Math.min(generation, rows - 1);
  const prevY = y - 1;
  
  if (prevY >= 0) {
    for (let x = 0; x < cols; x++) {
      const left = grid[prevY][(x - 1 + cols) % cols];
      const center = grid[prevY][x];
      const right = grid[prevY][(x + 1) % cols];
      grid[y][x] = applyRule(left, center, right);
    }
  }
  
  // Count alive cells for sound
  let alive = 0;
  for (let x = 0; x < cols; x++) {
    if (grid[y][x]) alive++;
  }
  
  // Occasional click sounds based on pattern density
  if (audioCtx && Date.now() - lastSoundTime > 50) {
    const density = alive / cols;
    if (Math.random() < density * 0.3) {
      playTick(density);
      lastSoundTime = Date.now();
    }
  }
}

function playTick(density) {
  if (!audioCtx) return;
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  
  osc.type = 'sine';
  osc.frequency.value = 200 + density * 800 + Math.random() * 200;
  
  gain.gain.setValueAtTime(0.03, audioCtx.currentTime);
  gain.gain.exponentialDecayTo?.(0.001, audioCtx.currentTime + 0.1) ||
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
  
  osc.connect(gain);
  gain.connect(audioCtx.destination);
  
  osc.start();
  osc.stop(audioCtx.currentTime + 0.1);
}

function getColor(x, y, alive) {
  if (!alive) return null;
  
  // Age-based coloring (newer = cyan, older = pink)
  const age = (generation + scrollOffset) - (y + scrollOffset);
  const normalizedAge = Math.min(age / 30, 1);
  
  // Distance from mouse affects brightness
  const dx = (x * cellSize) - mouseX;
  const dy = (y * cellSize) - mouseY;
  const dist = Math.sqrt(dx * dx + dy * dy);
  const mouseFactor = Math.max(0, 1 - dist / 300);
  
  const r = Math.floor(100 + normalizedAge * 155 + mouseFactor * 50);
  const g = Math.floor(255 - normalizedAge * 155);
  const b = Math.floor(255 - normalizedAge * 77 + mouseFactor * 50);
  
  return `rgb(${Math.min(255, r)}, ${Math.min(255, g)}, ${Math.min(255, b)})`;
}

function draw() {
  // Slight fade for trail effect
  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';
  ctx.fillRect(0, 0, W, H);
  
  // Draw cells
  for (let y = 0; y < Math.min(generation + 1, rows); y++) {
    for (let x = 0; x < cols; x++) {
      if (grid[y][x]) {
        const color = getColor(x, y, true);
        if (color) {
          ctx.fillStyle = color;
          
          // Glow effect near mouse
          const dx = (x * cellSize) - mouseX;
          const dy = (y * cellSize) - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          
          if (dist < 100) {
            ctx.shadowColor = '#00ffff';
            ctx.shadowBlur = 10 * (1 - dist / 100);
          } else {
            ctx.shadowBlur = 0;
          }
          
          ctx.fillRect(x * cellSize, y * cellSize, cellSize - 1, cellSize - 1);
        }
      }
    }
  }
  ctx.shadowBlur = 0;
  
  // Draw rule visualization at top
  drawRuleViz();
}

function drawRuleViz() {
  const vizSize = 20;
  const startX = 20;
  const startY = 20;
  
  ctx.globalAlpha = 0.5;
  for (let i = 7; i >= 0; i--) {
    const pattern = i;
    const result = ruleSet[i];
    const x = startX + (7 - i) * (vizSize * 4 + 10);
    
    // Draw input pattern
    for (let j = 2; j >= 0; j--) {
      const bit = (pattern >> j) & 1;
      ctx.fillStyle = bit ? '#ff66b2' : '#1a1a2e';
      ctx.fillRect(x + (2 - j) * vizSize, startY, vizSize - 2, vizSize - 2);
    }
    
    // Draw output
    ctx.fillStyle = result ? '#00ffff' : '#1a1a2e';
    ctx.fillRect(x + vizSize, startY + vizSize + 5, vizSize - 2, vizSize - 2);
  }
  ctx.globalAlpha = 1;
}

function mutate(x, y) {
  const gridX = Math.floor(x / cellSize);
  const gridY = Math.floor(y / cellSize);
  
  // Flip cells in a small radius
  for (let dy = -2; dy <= 2; dy++) {
    for (let dx = -2; dx <= 2; dx++) {
      const gx = (gridX + dx + cols) % cols;
      const gy = gridY + dy;
      if (gy >= 0 && gy < rows && Math.random() < 0.5) {
        grid[gy][gx] = grid[gy][gx] ? 0 : 1;
      }
    }
  }
  
  // Play mutation sound
  if (audioCtx) {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = 'square';
    osc.frequency.value = 150;
    gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.2);
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.start();
    osc.stop(audioCtx.currentTime + 0.2);
  }
}

function changeRule(delta) {
  const currentIndex = interestingRules.indexOf(currentRule);
  let newIndex;
  
  if (currentIndex === -1) {
    newIndex = 0;
  } else {
    newIndex = (currentIndex + delta + interestingRules.length) % interestingRules.length;
  }
  
  currentRule = interestingRules[newIndex];
  computeRuleSet(currentRule);
  
  // Don't reset - let the new rule propagate from current state
  // This creates interesting transitions
}

function randomRule() {
  currentRule = Math.floor(Math.random() * 256);
  initGrid();
  
  // Dramatic sound for rule change
  if (audioCtx) {
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = 'sawtooth';
    osc.frequency.setValueAtTime(400, audioCtx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 0.3);
    gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    osc.start();
    osc.stop(audioCtx.currentTime + 0.3);
  }
}

// Event listeners
window.addEventListener('resize', resize);

canvas.addEventListener('mousemove', (e) => {
  mouseX = e.clientX;
  mouseY = e.clientY;
});

canvas.addEventListener('click', (e) => {
  // Init audio on first click
  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  mutate(e.clientX, e.clientY);
});

window.addEventListener('keydown', (e) => {
  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  
  if (e.code === 'Space') {
    e.preventDefault();
    randomRule();
  } else if (e.code === 'ArrowLeft') {
    changeRule(-1);
  } else if (e.code === 'ArrowRight') {
    changeRule(1);
  }
});

// Animation loop
let frameCount = 0;
function animate() {
  frameCount++;
  
  // Advance generation every few frames for readable speed
  if (frameCount % 3 === 0) {
    nextGeneration();
  }
  
  draw();
  requestAnimationFrame(animate);
}

// Start
resize();
animate();
</script>
</body>
</html>
