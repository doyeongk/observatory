<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>chladni</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0f; 
  overflow: hidden; 
  cursor: crosshair;
}
canvas { display: block; }
#info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  color: rgba(0, 255, 255, 0.4);
  font: 12px monospace;
  pointer-events: none;
  text-transform: lowercase;
}
</style>
</head>
<body>
<canvas id="canvas"></canvas>
<div id="info">drag to change frequency · click to strike plate · space for random mode</div>
<script>
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');

let W, H, centerX, centerY, plateRadius;
const particles = [];
const NUM_PARTICLES = 8000;

// Chladni parameters
let m = 3, n = 2; // mode numbers
let targetM = m, targetN = n;
let frequency = 440;
let amplitude = 0;
let maxAmplitude = 1;
let decayRate = 0.985;

// Audio
let audioCtx = null;
let oscillator = null;
let gainNode = null;

function initAudio() {
  if (audioCtx) return;
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  oscillator = audioCtx.createOscillator();
  gainNode = audioCtx.createGain();
  
  oscillator.type = 'sine';
  oscillator.frequency.value = frequency;
  gainNode.gain.value = 0;
  
  oscillator.connect(gainNode);
  gainNode.connect(audioCtx.destination);
  oscillator.start();
}

function playTone(freq, amp) {
  if (!audioCtx) return;
  oscillator.frequency.setTargetAtTime(freq, audioCtx.currentTime, 0.1);
  gainNode.gain.setTargetAtTime(amp * 0.15, audioCtx.currentTime, 0.02);
}

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
  centerX = W / 2;
  centerY = H / 2;
  plateRadius = Math.min(W, H) * 0.42;
}

// Chladni equation: amplitude at point (x, y) for mode (m, n)
// Using the classic square plate equation adapted to circle
function chladniAmplitude(x, y, m, n) {
  // Normalize to -1 to 1
  const nx = (x - centerX) / plateRadius;
  const ny = (y - centerY) / plateRadius;
  
  // Distance from center
  const r = Math.sqrt(nx * nx + ny * ny);
  if (r > 1) return 0;
  
  // Angle
  const theta = Math.atan2(ny, nx);
  
  // Circular Chladni pattern (Bessel-like)
  // Combine angular and radial modes
  const angular = Math.cos(m * theta);
  const radial = Math.cos(n * Math.PI * r);
  
  return angular * radial;
}

// Get force pushing particle toward nodal lines (where amplitude = 0)
function getNodalForce(x, y, m, n) {
  const amp = chladniAmplitude(x, y, m, n);
  const absAmp = Math.abs(amp);
  
  // Gradient approximation
  const dx = 2;
  const ampX = Math.abs(chladniAmplitude(x + dx, y, m, n));
  const ampY = Math.abs(chladniAmplitude(x, y + dx, m, n));
  
  // Move toward lower absolute amplitude (nodal lines)
  const gradX = (ampX - absAmp) / dx;
  const gradY = (ampY - absAmp) / dx;
  
  return { fx: -gradX, fy: -gradY, amp: amp };
}

class Particle {
  constructor() {
    this.reset();
  }
  
  reset() {
    // Random position on plate
    const angle = Math.random() * Math.PI * 2;
    const r = Math.sqrt(Math.random()) * plateRadius * 0.95;
    this.x = centerX + Math.cos(angle) * r;
    this.y = centerY + Math.sin(angle) * r;
    this.vx = 0;
    this.vy = 0;
    this.settled = 0;
  }
  
  update() {
    const dx = this.x - centerX;
    const dy = this.y - centerY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    
    // Keep on plate
    if (dist > plateRadius * 0.98) {
      const angle = Math.atan2(dy, dx);
      this.x = centerX + Math.cos(angle) * plateRadius * 0.97;
      this.y = centerY + Math.sin(angle) * plateRadius * 0.97;
      this.vx *= -0.5;
      this.vy *= -0.5;
    }
    
    // Get nodal force
    const { fx, fy, amp } = getNodalForce(this.x, this.y, m, n);
    
    // Vibration kicks particles off high-amplitude areas
    const kick = amplitude * Math.abs(amp) * 0.8;
    const kickAngle = Math.random() * Math.PI * 2;
    
    // Apply forces
    const forceMult = amplitude * 2.5;
    this.vx += fx * forceMult + Math.cos(kickAngle) * kick;
    this.vy += fy * forceMult + Math.sin(kickAngle) * kick;
    
    // Small random jitter when vibrating
    if (amplitude > 0.1) {
      this.vx += (Math.random() - 0.5) * amplitude * 0.3;
      this.vy += (Math.random() - 0.5) * amplitude * 0.3;
    }
    
    // Damping
    this.vx *= 0.92;
    this.vy *= 0.92;
    
    // Update position
    this.x += this.vx;
    this.y += this.vy;
    
    // Track how settled
    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
    if (speed < 0.1 && Math.abs(amp) < 0.15) {
      this.settled = Math.min(1, this.settled + 0.02);
    } else {
      this.settled = Math.max(0, this.settled - 0.05);
    }
  }
  
  draw() {
    const dx = this.x - centerX;
    const dy = this.y - centerY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist > plateRadius) return;
    
    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
    
    // Color based on movement and position
    const hue = this.settled > 0.5 ? 300 + this.settled * 20 : 180 + speed * 30; // cyan when moving, pink when settled
    const sat = 80 + this.settled * 20;
    const light = 50 + speed * 20 + amplitude * 20;
    const alpha = 0.6 + this.settled * 0.3;
    
    ctx.fillStyle = `hsla(${hue}, ${sat}%, ${Math.min(80, light)}%, ${alpha})`;
    const size = 1.5 + this.settled * 1;
    ctx.fillRect(this.x - size/2, this.y - size/2, size, size);
  }
}

function init() {
  resize();
  particles.length = 0;
  for (let i = 0; i < NUM_PARTICLES; i++) {
    particles.push(new Particle());
  }
}

function drawPlate() {
  // Plate edge glow
  const gradient = ctx.createRadialGradient(centerX, centerY, plateRadius * 0.9, centerX, centerY, plateRadius * 1.05);
  gradient.addColorStop(0, 'rgba(138, 43, 226, 0)');
  gradient.addColorStop(0.7, 'rgba(138, 43, 226, 0.1)');
  gradient.addColorStop(1, 'rgba(138, 43, 226, 0)');
  
  ctx.fillStyle = gradient;
  ctx.beginPath();
  ctx.arc(centerX, centerY, plateRadius * 1.05, 0, Math.PI * 2);
  ctx.fill();
  
  // Plate surface (subtle)
  ctx.strokeStyle = `rgba(0, 255, 255, ${0.1 + amplitude * 0.2})`;
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.arc(centerX, centerY, plateRadius, 0, Math.PI * 2);
  ctx.stroke();
  
  // Vibration visualization - concentric rings when active
  if (amplitude > 0.05) {
    const time = Date.now() / 100;
    for (let i = 1; i <= 3; i++) {
      const r = plateRadius * (0.3 + i * 0.2);
      const a = amplitude * 0.15 * (1 - i * 0.2);
      ctx.strokeStyle = `rgba(255, 105, 180, ${a})`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(centerX, centerY, r + Math.sin(time * 2 + i) * 3 * amplitude, 0, Math.PI * 2);
      ctx.stroke();
    }
  }
}

function drawModeIndicator() {
  ctx.fillStyle = `rgba(0, 255, 255, 0.5)`;
  ctx.font = '14px monospace';
  ctx.fillText(`mode (${Math.round(m)}, ${Math.round(n)})`, 20, 30);
  ctx.fillText(`${Math.round(frequency)} Hz`, 20, 50);
}

function animate() {
  // Fade
  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';
  ctx.fillRect(0, 0, W, H);
  
  // Smoothly transition modes
  m += (targetM - m) * 0.05;
  n += (targetN - n) * 0.05;
  
  // Decay amplitude
  amplitude *= decayRate;
  if (amplitude < 0.001) amplitude = 0;
  
  // Update audio
  if (audioCtx && amplitude > 0) {
    playTone(frequency, amplitude);
  } else if (audioCtx) {
    gainNode.gain.setTargetAtTime(0, audioCtx.currentTime, 0.1);
  }
  
  drawPlate();
  
  // Update and draw particles
  for (const p of particles) {
    p.update();
    p.draw();
  }
  
  drawModeIndicator();
  
  requestAnimationFrame(animate);
}

// Strike the plate
function strike(intensity = 1) {
  initAudio();
  amplitude = maxAmplitude * intensity;
  
  // Calculate frequency based on mode (simplified)
  frequency = 110 * Math.sqrt(m * m + n * n);
  
  // Add some chaos to particles
  for (const p of particles) {
    const dist = Math.sqrt((p.x - centerX) ** 2 + (p.y - centerY) ** 2);
    if (dist < plateRadius) {
      p.vx += (Math.random() - 0.5) * 5 * intensity;
      p.vy += (Math.random() - 0.5) * 5 * intensity;
      p.settled = 0;
    }
  }
}

// Mouse controls
let isDragging = false;
let lastX, lastY;

canvas.addEventListener('mousedown', (e) => {
  isDragging = true;
  lastX = e.clientX;
  lastY = e.clientY;
  strike(0.8);
});

canvas.addEventListener('mousemove', (e) => {
  if (!isDragging) return;
  
  const dx = e.clientX - lastX;
  const dy = e.clientY - lastY;
  
  // Change mode based on drag
  targetM = Math.max(1, Math.min(8, targetM + dx * 0.02));
  targetN = Math.max(1, Math.min(8, targetN + dy * 0.02));
  
  // Keep vibrating while dragging
  amplitude = Math.max(amplitude, 0.5);
  frequency = 110 * Math.sqrt(targetM * targetM + targetN * targetN);
  
  lastX = e.clientX;
  lastY = e.clientY;
});

canvas.addEventListener('mouseup', () => {
  isDragging = false;
});

canvas.addEventListener('mouseleave', () => {
  isDragging = false;
});

// Keyboard
document.addEventListener('keydown', (e) => {
  if (e.code === 'Space') {
    e.preventDefault();
    // Random mode
    targetM = 1 + Math.floor(Math.random() * 7);
    targetN = 1 + Math.floor(Math.random() * 7);
    strike(1);
  }
});

// Touch support
canvas.addEventListener('touchstart', (e) => {
  e.preventDefault();
  const touch = e.touches[0];
  lastX = touch.clientX;
  lastY = touch.clientY;
  isDragging = true;
  strike(0.8);
});

canvas.addEventListener('touchmove', (e) => {
  e.preventDefault();
  if (!isDragging) return;
  const touch = e.touches[0];
  const dx = touch.clientX - lastX;
  const dy = touch.clientY - lastY;
  targetM = Math.max(1, Math.min(8, targetM + dx * 0.02));
  targetN = Math.max(1, Math.min(8, targetN + dy * 0.02));
  amplitude = Math.max(amplitude, 0.5);
  frequency = 110 * Math.sqrt(targetM * targetM + targetN * targetN);
  lastX = touch.clientX;
  lastY = touch.clientY;
});

canvas.addEventListener('touchend', () => {
  isDragging = false;
});

window.addEventListener('resize', resize);

init();
animate();

// Initial gentle strike after a moment
setTimeout(() => strike(0.6), 500);
</script>
</body>
</html>
