<!DOCTYPE html>
<html>
<head>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      background: #0a0a0a;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      font-family: 'Share Tech Mono', monospace;
    }
    
    .board {
      position: relative;
      width: 100vmin;
      height: 100vmin;
      background: 
        linear-gradient(90deg, rgba(0,40,30,0.3) 1px, transparent 1px),
        linear-gradient(rgba(0,40,30,0.3) 1px, transparent 1px),
        radial-gradient(circle at 30% 70%, #0d1a15 0%, #050505 100%);
      background-size: 20px 20px, 20px 20px, 100% 100%;
    }
    
    /* PCB traces as SVG paths */
    .traces {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    
    .trace {
      fill: none;
      stroke-width: 3;
      stroke-linecap: round;
      stroke-linejoin: round;
      filter: drop-shadow(0 0 3px currentColor);
    }
    
    .trace-cyan { stroke: #0ff; color: #0ff; }
    .trace-pink { stroke: #ff2d95; color: #ff2d95; }
    .trace-teal { stroke: #00ffa3; color: #00ffa3; }
    
    /* Current flow animation */
    .trace {
      stroke-dasharray: 20 80;
      stroke-dashoffset: 100;
      animation: flow 3s linear infinite;
    }
    
    .trace:nth-child(2) { animation-delay: -0.5s; stroke-dasharray: 15 85; }
    .trace:nth-child(3) { animation-delay: -1s; stroke-dasharray: 25 75; }
    .trace:nth-child(4) { animation-delay: -1.5s; stroke-dasharray: 10 90; }
    .trace:nth-child(5) { animation-delay: -2s; stroke-dasharray: 30 70; }
    .trace:nth-child(6) { animation-delay: -0.3s; stroke-dasharray: 18 82; }
    .trace:nth-child(7) { animation-delay: -2.2s; stroke-dasharray: 22 78; }
    .trace:nth-child(8) { animation-delay: -1.8s; stroke-dasharray: 12 88; }
    
    @keyframes flow {
      to { stroke-dashoffset: 0; }
    }
    
    /* Components */
    .chip {
      position: absolute;
      background: #111;
      border: 2px solid #222;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 8px;
      color: #444;
      box-shadow: 
        inset 0 1px 0 rgba(255,255,255,0.05),
        0 4px 8px rgba(0,0,0,0.5);
    }
    
    .chip::before {
      content: '';
      position: absolute;
      top: 4px;
      left: 50%;
      transform: translateX(-50%);
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: radial-gradient(circle, #1a1a1a 40%, #0a0a0a 100%);
    }
    
    .chip-main {
      width: 80px;
      height: 80px;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }
    
    .chip-main .label {
      font-size: 10px;
      color: #0ff;
      text-shadow: 0 0 10px #0ff;
      animation: pulse 2s ease-in-out infinite;
    }
    
    .chip-sm {
      width: 40px;
      height: 25px;
    }
    
    .chip-1 { top: 20%; left: 15%; }
    .chip-2 { top: 15%; right: 20%; }
    .chip-3 { bottom: 25%; left: 20%; }
    .chip-4 { bottom: 20%; right: 15%; }
    
    /* Via holes */
    .via {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #0a0a0a;
      border: 2px solid;
      animation: via-glow 2s ease-in-out infinite;
    }
    
    .via-cyan { border-color: #0ff; animation-delay: 0s; }
    .via-pink { border-color: #ff2d95; animation-delay: 0.5s; }
    .via-teal { border-color: #00ffa3; animation-delay: 1s; }
    
    @keyframes via-glow {
      0%, 100% { box-shadow: 0 0 5px currentColor; }
      50% { box-shadow: 0 0 15px currentColor, 0 0 25px currentColor; }
    }
    
    @keyframes pulse {
      0%, 100% { opacity: 0.7; }
      50% { opacity: 1; }
    }
    
    /* Capacitors */
    .cap {
      position: absolute;
      width: 12px;
      height: 20px;
      background: linear-gradient(90deg, #1a1a1a 30%, #333 50%, #1a1a1a 70%);
      border-radius: 2px;
    }
    
    /* Resistors */
    .resistor {
      position: absolute;
      width: 24px;
      height: 8px;
      background: #2a1a1a;
      border-radius: 2px;
      display: flex;
      justify-content: space-around;
      align-items: center;
      padding: 0 2px;
    }
    
    .resistor span {
      width: 3px;
      height: 100%;
    }
    
    .band-gold { background: #ffd700; }
    .band-red { background: #ff4444; }
    .band-brown { background: #8b4513; }
    .band-orange { background: #ff8c00; }
    
    /* Spark effect on main chip */
    .spark {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 4px;
      height: 4px;
      background: #fff;
      border-radius: 50%;
      box-shadow: 0 0 10px #0ff, 0 0 20px #0ff, 0 0 40px #0ff;
      animation: spark-move 4s ease-in-out infinite;
    }
    
    @keyframes spark-move {
      0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
      10% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
      90% { transform: translate(calc(-50% + 200px), calc(-50% - 100px)) scale(0.5); opacity: 0.8; }
      100% { transform: translate(calc(-50% + 200px), calc(-50% - 100px)) scale(0); opacity: 0; }
    }
  </style>
</head>
<body>
  <div class="board">
    <svg class="traces" viewBox="0 0 100 100" preserveAspectRatio="none">
      <!-- Main traces from center chip -->
      <path class="trace trace-cyan" d="M50,50 L50,35 L25,35 L25,22"/>
      <path class="trace trace-pink" d="M50,50 L65,50 L65,30 L78,30 L78,18"/>
      <path class="trace trace-teal" d="M50,50 L50,65 L30,65 L30,78"/>
      <path class="trace trace-cyan" d="M50,50 L35,50 L35,70 L20,70 L20,82"/>
      <path class="trace trace-pink" d="M50,50 L60,60 L80,60 L80,78"/>
      
      <!-- Cross traces -->
      <path class="trace trace-teal" d="M25,22 L25,15 L75,15 L75,22"/>
      <path class="trace trace-cyan" d="M20,82 L20,90 L80,90 L80,78"/>
      <path class="trace trace-pink" d="M15,40 L15,60 L25,60"/>
      <path class="trace trace-teal" d="M85,35 L85,55 L75,55"/>
    </svg>
    
    <!-- Main processor chip -->
    <div class="chip chip-main">
      <span class="label">ψ-CORE</span>
    </div>
    
    <!-- Secondary chips -->
    <div class="chip chip-sm chip-1"></div>
    <div class="chip chip-sm chip-2"></div>
    <div class="chip chip-sm chip-3"></div>
    <div class="chip chip-sm chip-4"></div>
    
    <!-- Via holes scattered around -->
    <div class="via via-cyan" style="top: 30%; left: 40%;"></div>
    <div class="via via-pink" style="top: 45%; left: 65%;"></div>
    <div class="via via-teal" style="top: 60%; left: 35%;"></div>
    <div class="via via-cyan" style="top: 70%; left: 55%;"></div>
    <div class="via via-pink" style="top: 25%; left: 60%;"></div>
    <div class="via via-teal" style="top: 75%; left: 70%;"></div>
    
    <!-- Passive components -->
    <div class="cap" style="top: 40%; left: 12%;"></div>
    <div class="cap" style="top: 55%; right: 10%;"></div>
    
    <div class="resistor" style="top: 28%; left: 35%;">
      <span class="band-brown"></span>
      <span class="band-red"></span>
      <span class="band-orange"></span>
      <span class="band-gold"></span>
    </div>
    <div class="resistor" style="bottom: 32%; right: 30%;">
      <span class="band-red"></span>
      <span class="band-red"></span>
      <span class="band-brown"></span>
      <span class="band-gold"></span>
    </div>
    
    <!-- Spark traveling -->
    <div class="spark"></div>
  </div>
</body>
</html>