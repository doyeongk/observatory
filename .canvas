<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>strange loop</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { 
  background: #0a0a0f; 
  overflow: hidden; 
  font-family: monospace;
}
canvas { display: block; }
#info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  color: rgba(0, 255, 255, 0.4);
  font-size: 11px;
  pointer-events: none;
  text-transform: lowercase;
}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="info">click to perturb · drag to rotate</div>
<script>
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');

let W, H;
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// Lorenz system parameters
const sigma = 10;
const rho = 28;
const beta = 8/3;
const dt = 0.003;

// Multiple particles to show the butterfly effect
class Particle {
  constructor(x, y, z, hue) {
    this.x = x;
    this.y = y;
    this.z = z;
    this.hue = hue;
    this.trail = [];
    this.maxTrail = 400;
  }
  
  step() {
    const dx = sigma * (this.y - this.x);
    const dy = this.x * (rho - this.z) - this.y;
    const dz = this.x * this.y - beta * this.z;
    
    this.x += dx * dt;
    this.y += dy * dt;
    this.z += dz * dt;
    
    this.trail.push({ x: this.x, y: this.y, z: this.z });
    if (this.trail.length > this.maxTrail) {
      this.trail.shift();
    }
  }
}

// Create particles with tiny differences (butterfly effect)
let particles = [];
function initParticles() {
  particles = [];
  const baseX = 0.1 + Math.random() * 0.1;
  const baseY = 0.1 + Math.random() * 0.1;
  const baseZ = 0.1 + Math.random() * 0.1;
  
  // Cyan primary
  particles.push(new Particle(baseX, baseY, baseZ, 180));
  // Pink — nearly identical starting point
  particles.push(new Particle(baseX + 0.0001, baseY, baseZ, 320));
  // Purple — another tiny variation
  particles.push(new Particle(baseX, baseY + 0.0001, baseZ, 280));
}
initParticles();

// Camera rotation
let rotX = 0.3;
let rotY = 0;
let autoRotate = true;
let isDragging = false;
let lastMouse = { x: 0, y: 0 };

canvas.addEventListener('mousedown', (e) => {
  isDragging = true;
  autoRotate = false;
  lastMouse = { x: e.clientX, y: e.clientY };
});

canvas.addEventListener('mousemove', (e) => {
  if (isDragging) {
    const dx = e.clientX - lastMouse.x;
    const dy = e.clientY - lastMouse.y;
    rotY += dx * 0.005;
    rotX += dy * 0.005;
    lastMouse = { x: e.clientX, y: e.clientY };
  }
});

canvas.addEventListener('mouseup', () => {
  isDragging = false;
  setTimeout(() => { autoRotate = true; }, 3000);
});

canvas.addEventListener('click', (e) => {
  // Perturb — restart with new initial conditions
  initParticles();
  perturbFlash = 1;
});

// Touch support
canvas.addEventListener('touchstart', (e) => {
  isDragging = true;
  autoRotate = false;
  lastMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
});

canvas.addEventListener('touchmove', (e) => {
  if (isDragging && e.touches.length === 1) {
    const dx = e.touches[0].clientX - lastMouse.x;
    const dy = e.touches[0].clientY - lastMouse.y;
    rotY += dx * 0.005;
    rotX += dy * 0.005;
    lastMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
  }
});

canvas.addEventListener('touchend', () => {
  isDragging = false;
  setTimeout(() => { autoRotate = true; }, 3000);
});

let perturbFlash = 0;

// 3D to 2D projection with rotation
function project(x, y, z) {
  // Center the attractor (it orbits around ~0,0,25)
  const cx = x;
  const cy = y;
  const cz = z - 25;
  
  // Rotate around Y axis
  const x1 = cx * Math.cos(rotY) - cz * Math.sin(rotY);
  const z1 = cx * Math.sin(rotY) + cz * Math.cos(rotY);
  
  // Rotate around X axis
  const y2 = cy * Math.cos(rotX) - z1 * Math.sin(rotX);
  const z2 = cy * Math.sin(rotX) + z1 * Math.cos(rotX);
  
  // Perspective projection
  const scale = 12;
  const perspective = 200;
  const factor = perspective / (perspective + z2);
  
  return {
    x: W/2 + x1 * scale * factor,
    y: H/2 + y2 * scale * factor,
    z: z2,
    factor: factor
  };
}

// Web Audio — ethereal drone based on particle positions
let audioCtx, gainNode, oscillators = [];
let audioInitialized = false;

function initAudio() {
  if (audioInitialized) return;
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  gainNode = audioCtx.createGain();
  gainNode.gain.value = 0.03;
  gainNode.connect(audioCtx.destination);
  
  // Create oscillators for each particle
  for (let i = 0; i < 3; i++) {
    const osc = audioCtx.createOscillator();
    const oscGain = audioCtx.createGain();
    oscGain.gain.value = 0.3;
    osc.type = 'sine';
    osc.frequency.value = 200 + i * 50;
    osc.connect(oscGain);
    oscGain.connect(gainNode);
    osc.start();
    oscillators.push({ osc, gain: oscGain });
  }
  
  audioInitialized = true;
}

document.addEventListener('click', initAudio, { once: true });
document.addEventListener('touchstart', initAudio, { once: true });

function updateAudio() {
  if (!audioInitialized) return;
  
  particles.forEach((p, i) => {
    if (oscillators[i]) {
      // Map position to frequency (pentatonic-ish for pleasantness)
      const baseFreq = 100 + (p.z / 50) * 200;
      const freq = baseFreq * (1 + p.x / 100);
      oscillators[i].osc.frequency.setTargetAtTime(
        Math.max(50, Math.min(800, freq)), 
        audioCtx.currentTime, 
        0.1
      );
      
      // Map velocity to volume
      const speed = Math.sqrt(p.x*p.x + p.y*p.y) / 50;
      oscillators[i].gain.gain.setTargetAtTime(
        Math.min(0.4, speed * 0.2),
        audioCtx.currentTime,
        0.1
      );
    }
  });
}

function draw() {
  // Fade effect for trails
  ctx.fillStyle = 'rgba(10, 10, 15, 0.08)';
  ctx.fillRect(0, 0, W, H);
  
  // Flash on perturbation
  if (perturbFlash > 0) {
    ctx.fillStyle = `rgba(0, 255, 255, ${perturbFlash * 0.1})`;
    ctx.fillRect(0, 0, W, H);
    perturbFlash *= 0.9;
  }
  
  // Auto-rotate slowly
  if (autoRotate) {
    rotY += 0.002;
  }
  
  // Step the simulation multiple times per frame for smoothness
  for (let i = 0; i < 8; i++) {
    particles.forEach(p => p.step());
  }
  
  // Update audio
  updateAudio();
  
  // Draw trails
  particles.forEach((particle, pIdx) => {
    const trail = particle.trail;
    if (trail.length < 2) return;
    
    ctx.beginPath();
    
    for (let i = 1; i < trail.length; i++) {
      const p0 = project(trail[i-1].x, trail[i-1].y, trail[i-1].z);
      const p1 = project(trail[i].x, trail[i].y, trail[i].z);
      
      // Age-based alpha
      const age = i / trail.length;
      const alpha = age * 0.8 * p1.factor;
      
      // Depth-based lightness
      const lightness = 40 + p1.factor * 30;
      
      ctx.strokeStyle = `hsla(${particle.hue}, 80%, ${lightness}%, ${alpha})`;
      ctx.lineWidth = 1.5 * p1.factor;
      
      ctx.beginPath();
      ctx.moveTo(p0.x, p0.y);
      ctx.lineTo(p1.x, p1.y);
      ctx.stroke();
    }
    
    // Draw current position as a glowing point
    const current = trail[trail.length - 1];
    const pc = project(current.x, current.y, current.z);
    
    const gradient = ctx.createRadialGradient(pc.x, pc.y, 0, pc.x, pc.y, 8 * pc.factor);
    gradient.addColorStop(0, `hsla(${particle.hue}, 100%, 80%, 0.9)`);
    gradient.addColorStop(0.5, `hsla(${particle.hue}, 80%, 50%, 0.4)`);
    gradient.addColorStop(1, 'transparent');
    
    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.arc(pc.x, pc.y, 8 * pc.factor, 0, Math.PI * 2);
    ctx.fill();
  });
  
  // Draw faint attractor skeleton (the equilibrium points)
  const eq1 = project(Math.sqrt(beta * (rho - 1)), Math.sqrt(beta * (rho - 1)), rho - 1);
  const eq2 = project(-Math.sqrt(beta * (rho - 1)), -Math.sqrt(beta * (rho - 1)), rho - 1);
  
  ctx.fillStyle = 'rgba(255, 255, 255, 0.1)';
  ctx.beginPath();
  ctx.arc(eq1.x, eq1.y, 3, 0, Math.PI * 2);
  ctx.fill();
  ctx.beginPath();
  ctx.arc(eq2.x, eq2.y, 3, 0, Math.PI * 2);
  ctx.fill();
  
  requestAnimationFrame(draw);
}

draw();
</script>
</body>
</html>
