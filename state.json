  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>chladni</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  cursor: crosshair;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: rgba(0, 255, 255, 0.4);\n  font: 12px monospace;\n  pointer-events: none;\n  text-transform: lowercase;\n}\n</style>\n</head>\n<body>\n<canvas id=\"canvas\"></canvas>\n<div id=\"info\">drag to change frequency · click to strike plate · space for random mode</div>\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H, centerX, centerY, plateRadius;\nconst particles = [];\nconst NUM_PARTICLES = 8000;\n\n// Chladni parameters\nlet m = 3, n = 2; // mode numbers\nlet targetM = m, targetN = n;\nlet frequency = 440;\nlet amplitude = 0;\nlet maxAmplitude = 1;\nlet decayRate = 0.985;\n\n// Audio\nlet audioCtx = null;\nlet oscillator = null;\nlet gainNode = null;\n\nfunction initAudio() {\n  if (audioCtx) return;\n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  oscillator = audioCtx.createOscillator();\n  gainNode = audioCtx.createGain();\n  \n  oscillator.type = 'sine';\n  oscillator.frequency.value = frequency;\n  gainNode.gain.value = 0;\n  \n  oscillator.connect(gainNode);\n  gainNode.connect(audioCtx.destination);\n  oscillator.start();\n}\n\nfunction playTone(freq, amp) {\n  if (!audioCtx) return;\n  oscillator.frequency.setTargetAtTime(freq, audioCtx.currentTime, 0.1);\n  gainNode.gain.setTargetAtTime(amp * 0.15, audioCtx.currentTime, 0.02);\n}\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n  centerX = W / 2;\n  centerY = H / 2;\n  plateRadius = Math.min(W, H) * 0.42;\n}\n\n// Chladni equation: amplitude at point (x, y) for mode (m, n)\n// Using the classic square plate equation adapted to circle\nfunction chladniAmplitude(x, y, m, n) {\n  // Normalize to -1 to 1\n  const nx = (x - centerX) / plateRadius;\n  const ny = (y - centerY) / plateRadius;\n  \n  // Distance from center\n  const r = Math.sqrt(nx * nx + ny * ny);\n  if (r > 1) return 0;\n  \n  // Angle\n  const theta = Math.atan2(ny, nx);\n  \n  // Circular Chladni pattern (Bessel-like)\n  // Combine angular and radial modes\n  const angular = Math.cos(m * theta);\n  const radial = Math.cos(n * Math.PI * r);\n  \n  return angular * radial;\n}\n\n// Get force pushing particle toward nodal lines (where amplitude = 0)\nfunction getNodalForce(x, y, m, n) {\n  const amp = chladniAmplitude(x, y, m, n);\n  const absAmp = Math.abs(amp);\n  \n  // Gradient approximation\n  const dx = 2;\n  const ampX = Math.abs(chladniAmplitude(x + dx, y, m, n));\n  const ampY = Math.abs(chladniAmplitude(x, y + dx, m, n));\n  \n  // Move toward lower absolute amplitude (nodal lines)\n  const gradX = (ampX - absAmp) / dx;\n  const gradY = (ampY - absAmp) / dx;\n  \n  return { fx: -gradX, fy: -gradY, amp: amp };\n}\n\nclass Particle {\n  constructor() {\n    this.reset();\n  }\n  \n  reset() {\n    // Random position on plate\n    const angle = Math.random() * Math.PI * 2;\n    const r = Math.sqrt(Math.random()) * plateRadius * 0.95;\n    this.x = centerX + Math.cos(angle) * r;\n    this.y = centerY + Math.sin(angle) * r;\n    this.vx = 0;\n    this.vy = 0;\n    this.settled = 0;\n  }\n  \n  update() {\n    const dx = this.x - centerX;\n    const dy = this.y - centerY;\n    const dist = Math.sqrt(dx * dx + dy * dy);\n    \n    // Keep on plate\n    if (dist > plateRadius * 0.98) {\n      const angle = Math.atan2(dy, dx);\n      this.x = centerX + Math.cos(angle) * plateRadius * 0.97;\n      this.y = centerY + Math.sin(angle) * plateRadius * 0.97;\n      this.vx *= -0.5;\n      this.vy *= -0.5;\n    }\n    \n    // Get nodal force\n    const { fx, fy, amp } = getNodalForce(this.x, this.y, m, n);\n    \n    // Vibration kicks particles off high-amplitude areas\n    const kick = amplitude * Math.abs(amp) * 0.8;\n    const kickAngle = Math.random() * Math.PI * 2;\n    \n    // Apply forces\n    const forceMult = amplitude * 2.5;\n    this.vx += fx * forceMult + Math.cos(kickAngle) * kick;\n    this.vy += fy * forceMult + Math.sin(kickAngle) * kick;\n    \n    // Small random jitter when vibrating\n    if (amplitude > 0.1) {\n      this.vx += (Math.random() - 0.5) * amplitude * 0.3;\n      this.vy += (Math.random() - 0.5) * amplitude * 0.3;\n    }\n    \n    // Damping\n    this.vx *= 0.92;\n    this.vy *= 0.92;\n    \n    // Update position\n    this.x += this.vx;\n    this.y += this.vy;\n    \n    // Track how settled\n    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);\n    if (speed < 0.1 && Math.abs(amp) < 0.15) {\n      this.settled = Math.min(1, this.settled + 0.02);\n    } else {\n      this.settled = Math.max(0, this.settled - 0.05);\n    }\n  }\n  \n  draw() {\n    const dx = this.x - centerX;\n    const dy = this.y - centerY;\n    const dist = Math.sqrt(dx * dx + dy * dy);\n    if (dist > plateRadius) return;\n    \n    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);\n    \n    // Color based on movement and position\n    const hue = this.settled > 0.5 ? 300 + this.settled * 20 : 180 + speed * 30; // cyan when moving, pink when settled\n    const sat = 80 + this.settled * 20;\n    const light = 50 + speed * 20 + amplitude * 20;\n    const alpha = 0.6 + this.settled * 0.3;\n    \n    ctx.fillStyle = `hsla(${hue}, ${sat}%, ${Math.min(80, light)}%, ${alpha})`;\n    const size = 1.5 + this.settled * 1;\n    ctx.fillRect(this.x - size/2, this.y - size/2, size, size);\n  }\n}\n\nfunction init() {\n  resize();\n  particles.length = 0;\n  for (let i = 0; i < NUM_PARTICLES; i++) {\n    particles.push(new Particle());\n  }\n}\n\nfunction drawPlate() {\n  // Plate edge glow\n  const gradient = ctx.createRadialGradient(centerX, centerY, plateRadius * 0.9, centerX, centerY, plateRadius * 1.05);\n  gradient.addColorStop(0, 'rgba(138, 43, 226, 0)');\n  gradient.addColorStop(0.7, 'rgba(138, 43, 226, 0.1)');\n  gradient.addColorStop(1, 'rgba(138, 43, 226, 0)');\n  \n  ctx.fillStyle = gradient;\n  ctx.beginPath();\n  ctx.arc(centerX, centerY, plateRadius * 1.05, 0, Math.PI * 2);\n  ctx.fill();\n  \n  // Plate surface (subtle)\n  ctx.strokeStyle = `rgba(0, 255, 255, ${0.1 + amplitude * 0.2})`;\n  ctx.lineWidth = 2;\n  ctx.beginPath();\n  ctx.arc(centerX, centerY, plateRadius, 0, Math.PI * 2);\n  ctx.stroke();\n  \n  // Vibration visualization - concentric rings when active\n  if (amplitude > 0.05) {\n    const time = Date.now() / 100;\n    for (let i = 1; i <= 3; i++) {\n      const r = plateRadius * (0.3 + i * 0.2);\n      const a = amplitude * 0.15 * (1 - i * 0.2);\n      ctx.strokeStyle = `rgba(255, 105, 180, ${a})`;\n      ctx.lineWidth = 1;\n      ctx.beginPath();\n      ctx.arc(centerX, centerY, r + Math.sin(time * 2 + i) * 3 * amplitude, 0, Math.PI * 2);\n      ctx.stroke();\n    }\n  }\n}\n\nfunction drawModeIndicator() {\n  ctx.fillStyle = `rgba(0, 255, 255, 0.5)`;\n  ctx.font = '14px monospace';\n  ctx.fillText(`mode (${Math.round(m)}, ${Math.round(n)})`, 20, 30);\n  ctx.fillText(`${Math.round(frequency)} Hz`, 20, 50);\n}\n\nfunction animate() {\n  // Fade\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Smoothly transition modes\n  m += (targetM - m) * 0.05;\n  n += (targetN - n) * 0.05;\n  \n  // Decay amplitude\n  amplitude *= decayRate;\n  if (amplitude < 0.001) amplitude = 0;\n  \n  // Update audio\n  if (audioCtx && amplitude > 0) {\n    playTone(frequency, amplitude);\n  } else if (audioCtx) {\n    gainNode.gain.setTargetAtTime(0, audioCtx.currentTime, 0.1);\n  }\n  \n  drawPlate();\n  \n  // Update and draw particles\n  for (const p of particles) {\n    p.update();\n    p.draw();\n  }\n  \n  drawModeIndicator();\n  \n  requestAnimationFrame(animate);\n}\n\n// Strike the plate\nfunction strike(intensity = 1) {\n  initAudio();\n  amplitude = maxAmplitude * intensity;\n  \n  // Calculate frequency based on mode (simplified)\n  frequency = 110 * Math.sqrt(m * m + n * n);\n  \n  // Add some chaos to particles\n  for (const p of particles) {\n    const dist = Math.sqrt((p.x - centerX) ** 2 + (p.y - centerY) ** 2);\n    if (dist < plateRadius) {\n      p.vx += (Math.random() - 0.5) * 5 * intensity;\n      p.vy += (Math.random() - 0.5) * 5 * intensity;\n      p.settled = 0;\n    }\n  }\n}\n\n// Mouse controls\nlet isDragging = false;\nlet lastX, lastY;\n\ncanvas.addEventListener('mousedown', (e) => {\n  isDragging = true;\n  lastX = e.clientX;\n  lastY = e.clientY;\n  strike(0.8);\n});\n\ncanvas.addEventListener('mousemove', (e) => {\n  if (!isDragging) return;\n  \n  const dx = e.clientX - lastX;\n  const dy = e.clientY - lastY;\n  \n  // Change mode based on drag\n  targetM = Math.max(1, Math.min(8, targetM + dx * 0.02));\n  targetN = Math.max(1, Math.min(8, targetN + dy * 0.02));\n  \n  // Keep vibrating while dragging\n  amplitude = Math.max(amplitude, 0.5);\n  frequency = 110 * Math.sqrt(targetM * targetM + targetN * targetN);\n  \n  lastX = e.clientX;\n  lastY = e.clientY;\n});\n\ncanvas.addEventListener('mouseup', () => {\n  isDragging = false;\n});\n\ncanvas.addEventListener('mouseleave', () => {\n  isDragging = false;\n});\n\n// Keyboard\ndocument.addEventListener('keydown', (e) => {\n  if (e.code === 'Space') {\n    e.preventDefault();\n    // Random mode\n    targetM = 1 + Math.floor(Math.random() * 7);\n    targetN = 1 + Math.floor(Math.random() * 7);\n    strike(1);\n  }\n});\n\n// Touch support\ncanvas.addEventListener('touchstart', (e) => {\n  e.preventDefault();\n  const touch = e.touches[0];\n  lastX = touch.clientX;\n  lastY = touch.clientY;\n  isDragging = true;\n  strike(0.8);\n});\n\ncanvas.addEventListener('touchmove', (e) => {\n  e.preventDefault();\n  if (!isDragging) return;\n  const touch = e.touches[0];\n  const dx = touch.clientX - lastX;\n  const dy = touch.clientY - lastY;\n  targetM = Math.max(1, Math.min(8, targetM + dx * 0.02));\n  targetN = Math.max(1, Math.min(8, targetN + dy * 0.02));\n  amplitude = Math.max(amplitude, 0.5);\n  frequency = 110 * Math.sqrt(targetM * targetM + targetN * targetN);\n  lastX = touch.clientX;\n  lastY = touch.clientY;\n});\n\ncanvas.addEventListener('touchend', () => {\n  isDragging = false;\n});\n\nwindow.addEventListener('resize', resize);\n\ninit();\nanimate();\n\n// Initial gentle strike after a moment\nsetTimeout(() => strike(0.6), 500);\n</script>\n</body>\n</html>\n"
