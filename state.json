  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>murmuration</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  cursor: none;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: rgba(255, 100, 200, 0.3);\n  font-family: monospace;\n  font-size: 11px;\n  pointer-events: none;\n}\n</style>\n</head>\n<body>\n<canvas id=\"canvas\"></canvas>\n<div id=\"info\">move to guide · click to scatter</div>\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// Mouse state\nconst mouse = { x: W/2, y: H/2, active: false, scary: false };\ncanvas.addEventListener('mousemove', e => {\n  mouse.x = e.clientX;\n  mouse.y = e.clientY;\n  mouse.active = true;\n});\ncanvas.addEventListener('mouseleave', () => mouse.active = false);\ncanvas.addEventListener('mousedown', () => mouse.scary = true);\ncanvas.addEventListener('mouseup', () => mouse.scary = false);\n\n// Boid class\nclass Boid {\n  constructor() {\n    this.x = Math.random() * W;\n    this.y = Math.random() * H;\n    this.vx = (Math.random() - 0.5) * 4;\n    this.vy = (Math.random() - 0.5) * 4;\n    this.history = [];\n    this.maxHistory = 8;\n  }\n  \n  update(boids) {\n    // Flocking forces\n    let alignX = 0, alignY = 0, alignCount = 0;\n    let cohesionX = 0, cohesionY = 0, cohesionCount = 0;\n    let separationX = 0, separationY = 0;\n    \n    const perceptionRadius = 80;\n    const separationRadius = 25;\n    \n    for (const other of boids) {\n      if (other === this) continue;\n      \n      const dx = other.x - this.x;\n      const dy = other.y - this.y;\n      const dist = Math.sqrt(dx * dx + dy * dy);\n      \n      if (dist < perceptionRadius) {\n        // Alignment\n        alignX += other.vx;\n        alignY += other.vy;\n        alignCount++;\n        \n        // Cohesion\n        cohesionX += other.x;\n        cohesionY += other.y;\n        cohesionCount++;\n      }\n      \n      if (dist < separationRadius && dist > 0) {\n        // Separation\n        separationX -= dx / dist;\n        separationY -= dy / dist;\n      }\n    }\n    \n    // Apply alignment\n    if (alignCount > 0) {\n      alignX /= alignCount;\n      alignY /= alignCount;\n      const alignMag = Math.sqrt(alignX * alignX + alignY * alignY);\n      if (alignMag > 0) {\n        alignX = (alignX / alignMag) * 3 - this.vx;\n        alignY = (alignY / alignMag) * 3 - this.vy;\n      }\n    }\n    \n    // Apply cohesion\n    if (cohesionCount > 0) {\n      cohesionX = cohesionX / cohesionCount - this.x;\n      cohesionY = cohesionY / cohesionCount - this.y;\n      const cohMag = Math.sqrt(cohesionX * cohesionX + cohesionY * cohesionY);\n      if (cohMag > 0) {\n        cohesionX = (cohesionX / cohMag) * 3 - this.vx;\n        cohesionY = (cohesionY / cohMag) * 3 - this.vy;\n      }\n    }\n    \n    // Weight the forces\n    this.vx += alignX * 0.05 + cohesionX * 0.03 + separationX * 0.15;\n    this.vy += alignY * 0.05 + cohesionY * 0.03 + separationY * 0.15;\n    \n    // Mouse interaction\n    if (mouse.active) {\n      const mdx = mouse.x - this.x;\n      const mdy = mouse.y - this.y;\n      const mDist = Math.sqrt(mdx * mdx + mdy * mdy);\n      \n      if (mDist < 200) {\n        const force = (200 - mDist) / 200;\n        if (mouse.scary) {\n          // Flee!\n          this.vx -= (mdx / mDist) * force * 2;\n          this.vy -= (mdy / mDist) * force * 2;\n        } else {\n          // Gentle attraction\n          this.vx += (mdx / mDist) * force * 0.3;\n          this.vy += (mdy / mDist) * force * 0.3;\n        }\n      }\n    }\n    \n    // Speed limits\n    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);\n    const maxSpeed = 5;\n    const minSpeed = 1.5;\n    if (speed > maxSpeed) {\n      this.vx = (this.vx / speed) * maxSpeed;\n      this.vy = (this.vy / speed) * maxSpeed;\n    } else if (speed < minSpeed) {\n      this.vx = (this.vx / speed) * minSpeed;\n      this.vy = (this.vy / speed) * minSpeed;\n    }\n    \n    // Update position\n    this.x += this.vx;\n    this.y += this.vy;\n    \n    // Wrap around edges (with soft margin)\n    const margin = 50;\n    if (this.x < -margin) this.x = W + margin;\n    if (this.x > W + margin) this.x = -margin;\n    if (this.y < -margin) this.y = H + margin;\n    if (this.y > H + margin) this.y = -margin;\n    \n    // Store history for trails\n    this.history.push({ x: this.x, y: this.y });\n    if (this.history.length > this.maxHistory) {\n      this.history.shift();\n    }\n  }\n  \n  draw() {\n    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);\n    const angle = Math.atan2(this.vy, this.vx);\n    \n    // Color based on direction\n    const hueBase = (angle + Math.PI) / (Math.PI * 2);\n    // Map to cyan-pink-purple range\n    const hue = 280 + hueBase * 100; // 280-380 (wraps to pink-purple-cyan)\n    \n    // Draw trail\n    if (this.history.length > 1) {\n      ctx.beginPath();\n      ctx.moveTo(this.history[0].x, this.history[0].y);\n      for (let i = 1; i < this.history.length; i++) {\n        ctx.lineTo(this.history[i].x, this.history[i].y);\n      }\n      ctx.strokeStyle = `hsla(${hue}, 80%, 60%, ${0.1 + speed * 0.02})`;\n      ctx.lineWidth = 1;\n      ctx.stroke();\n    }\n    \n    // Draw boid as small triangle\n    ctx.save();\n    ctx.translate(this.x, this.y);\n    ctx.rotate(angle);\n    \n    ctx.beginPath();\n    ctx.moveTo(6, 0);\n    ctx.lineTo(-4, 3);\n    ctx.lineTo(-4, -3);\n    ctx.closePath();\n    \n    ctx.fillStyle = `hsl(${hue}, 80%, ${55 + speed * 5}%)`;\n    ctx.fill();\n    \n    ctx.restore();\n  }\n}\n\n// Create flock\nconst boids = [];\nconst numBoids = Math.min(250, Math.floor((W * H) / 8000)); // Scale with screen\nfor (let i = 0; i < numBoids; i++) {\n  boids.push(new Boid());\n}\n\n// Background fade canvas\nconst fadeCanvas = document.createElement('canvas');\nconst fadeCtx = fadeCanvas.getContext('2d');\nfadeCanvas.width = W;\nfadeCanvas.height = H;\n\nwindow.addEventListener('resize', () => {\n  fadeCanvas.width = W;\n  fadeCanvas.height = H;\n});\n\n// Animation loop\nfunction animate() {\n  // Subtle fade for motion blur\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Update and draw all boids\n  for (const boid of boids) {\n    boid.update(boids);\n  }\n  for (const boid of boids) {\n    boid.draw();\n  }\n  \n  // Draw mouse glow when active\n  if (mouse.active) {\n    const gradient = ctx.createRadialGradient(\n      mouse.x, mouse.y, 0,\n      mouse.x, mouse.y, mouse.scary ? 100 : 60\n    );\n    if (mouse.scary) {\n      gradient.addColorStop(0, 'rgba(255, 50, 100, 0.2)');\n      gradient.addColorStop(1, 'rgba(255, 50, 100, 0)');\n    } else {\n      gradient.addColorStop(0, 'rgba(0, 255, 255, 0.15)');\n      gradient.addColorStop(1, 'rgba(0, 255, 255, 0)');\n    }\n    ctx.fillStyle = gradient;\n    ctx.fillRect(0, 0, W, H);\n  }\n  \n  requestAnimationFrame(animate);\n}\n\n// Initial background\nctx.fillStyle = '#0a0a0f';\nctx.fillRect(0, 0, W, H);\n\nanimate();\n</script>\n</body>\n</html>\n"
}
