  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>tension</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  cursor: crosshair;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: rgba(255,100,180,0.6);\n  font: 12px/1.4 'Courier New', monospace;\n  pointer-events: none;\n  text-shadow: 0 0 10px rgba(255,100,180,0.3);\n}\n</style>\n</head>\n<body>\n<canvas id=\"c\"></canvas>\n<div id=\"info\">hold still to build tension<br>move to release<br>click to force snap</div>\n<script>\nconst canvas = document.getElementById('c');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nconst GRID = 24;\nlet cols, rows;\nlet tension = [];\nlet velocity = [];\nlet mouse = { x: -1000, y: -1000, px: -1000, py: -1000 };\nlet mouseStill = 0;\nlet globalTension = 0;\n\n// Web Audio\nlet audioCtx, masterGain, droneOsc, droneGain, noiseNode, noiseGain;\nlet audioStarted = false;\n\nfunction initAudio() {\n  if (audioStarted) return;\n  audioStarted = true;\n  \n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  masterGain = audioCtx.createGain();\n  masterGain.gain.value = 0.3;\n  masterGain.connect(audioCtx.destination);\n  \n  // Tension drone - low rumbling\n  droneOsc = audioCtx.createOscillator();\n  droneOsc.type = 'sawtooth';\n  droneOsc.frequency.value = 55;\n  droneGain = audioCtx.createGain();\n  droneGain.gain.value = 0;\n  \n  const droneFilter = audioCtx.createBiquadFilter();\n  droneFilter.type = 'lowpass';\n  droneFilter.frequency.value = 200;\n  \n  droneOsc.connect(droneFilter);\n  droneFilter.connect(droneGain);\n  droneGain.connect(masterGain);\n  droneOsc.start();\n  \n  // Second drone for thickness\n  const droneOsc2 = audioCtx.createOscillator();\n  droneOsc2.type = 'sawtooth';\n  droneOsc2.frequency.value = 55.5; // slight detune\n  droneOsc2.connect(droneFilter);\n  droneOsc2.start();\n  \n  // Noise for texture\n  const bufferSize = audioCtx.sampleRate * 2;\n  const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);\n  const output = noiseBuffer.getChannelData(0);\n  for (let i = 0; i < bufferSize; i++) {\n    output[i] = Math.random() * 2 - 1;\n  }\n  noiseNode = audioCtx.createBufferSource();\n  noiseNode.buffer = noiseBuffer;\n  noiseNode.loop = true;\n  \n  noiseGain = audioCtx.createGain();\n  noiseGain.gain.value = 0;\n  \n  const noiseFilter = audioCtx.createBiquadFilter();\n  noiseFilter.type = 'bandpass';\n  noiseFilter.frequency.value = 400;\n  noiseFilter.Q.value = 2;\n  \n  noiseNode.connect(noiseFilter);\n  noiseFilter.connect(noiseGain);\n  noiseGain.connect(masterGain);\n  noiseNode.start();\n}\n\nfunction playRelease(intensity) {\n  if (!audioCtx) return;\n  \n  // Release whoosh\n  const osc = audioCtx.createOscillator();\n  osc.type = 'sine';\n  osc.frequency.value = 300 + intensity * 200;\n  \n  const gain = audioCtx.createGain();\n  gain.gain.value = Math.min(0.4, intensity * 0.3);\n  \n  const filter = audioCtx.createBiquadFilter();\n  filter.type = 'lowpass';\n  filter.frequency.value = 800;\n  \n  osc.connect(filter);\n  filter.connect(gain);\n  gain.connect(masterGain);\n  \n  osc.frequency.exponentialRampToValueAtTime(80, audioCtx.currentTime + 0.3);\n  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.5);\n  \n  osc.start();\n  osc.stop(audioCtx.currentTime + 0.5);\n  \n  // Snap click\n  const click = audioCtx.createOscillator();\n  click.type = 'square';\n  click.frequency.value = 1200;\n  const clickGain = audioCtx.createGain();\n  clickGain.gain.value = intensity * 0.2;\n  click.connect(clickGain);\n  clickGain.connect(masterGain);\n  clickGain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);\n  click.start();\n  click.stop(audioCtx.currentTime + 0.05);\n}\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n  cols = Math.ceil(W / GRID) + 1;\n  rows = Math.ceil(H / GRID) + 1;\n  \n  // Initialize/resize arrays\n  tension = [];\n  velocity = [];\n  for (let i = 0; i < cols * rows; i++) {\n    tension[i] = tension[i] || 0;\n    velocity[i] = velocity[i] || 0;\n  }\n}\n\nfunction idx(x, y) {\n  return y * cols + x;\n}\n\nfunction update() {\n  // Check mouse movement\n  const dx = mouse.x - mouse.px;\n  const dy = mouse.y - mouse.py;\n  const movement = Math.sqrt(dx * dx + dy * dy);\n  \n  if (movement < 2) {\n    mouseStill = Math.min(mouseStill + 1, 300);\n  } else {\n    // Movement releases tension around mouse\n    const mx = Math.floor(mouse.x / GRID);\n    const my = Math.floor(mouse.y / GRID);\n    const releaseRadius = 4 + movement * 0.1;\n    \n    for (let y = 0; y < rows; y++) {\n      for (let x = 0; x < cols; x++) {\n        const dist = Math.sqrt((x - mx) ** 2 + (y - my) ** 2);\n        if (dist < releaseRadius) {\n          const factor = 1 - dist / releaseRadius;\n          const released = tension[idx(x, y)] * factor * 0.3;\n          tension[idx(x, y)] -= released;\n          if (released > 0.1) {\n            velocity[idx(x, y)] -= released * 0.5;\n          }\n        }\n      }\n    }\n    mouseStill = Math.max(0, mouseStill - 10);\n  }\n  \n  mouse.px = mouse.x;\n  mouse.py = mouse.y;\n  \n  // Build tension where mouse hovers (when still)\n  if (mouseStill > 30 && mouse.x > 0) {\n    const mx = Math.floor(mouse.x / GRID);\n    const my = Math.floor(mouse.y / GRID);\n    const buildRadius = 3 + mouseStill * 0.02;\n    const buildRate = 0.01 + mouseStill * 0.0005;\n    \n    for (let y = 0; y < rows; y++) {\n      for (let x = 0; x < cols; x++) {\n        const dist = Math.sqrt((x - mx) ** 2 + (y - my) ** 2);\n        if (dist < buildRadius) {\n          const factor = 1 - dist / buildRadius;\n          tension[idx(x, y)] += buildRate * factor;\n        }\n      }\n    }\n  }\n  \n  // Natural tension diffusion and buildup\n  const newTension = [...tension];\n  globalTension = 0;\n  \n  for (let y = 0; y < rows; y++) {\n    for (let x = 0; x < cols; x++) {\n      const i = idx(x, y);\n      \n      // Slight ambient tension buildup\n      tension[i] += 0.0003;\n      \n      // Apply velocity\n      tension[i] += velocity[i];\n      velocity[i] *= 0.95;\n      \n      // Diffuse to neighbors\n      let sum = 0;\n      let count = 0;\n      if (x > 0) { sum += tension[idx(x-1, y)]; count++; }\n      if (x < cols-1) { sum += tension[idx(x+1, y)]; count++; }\n      if (y > 0) { sum += tension[idx(x, y-1)]; count++; }\n      if (y < rows-1) { sum += tension[idx(x, y+1)]; count++; }\n      \n      const avg = sum / count;\n      newTension[i] = tension[i] * 0.98 + avg * 0.02;\n      \n      // Check for snap\n      if (tension[i] > 1) {\n        const excess = tension[i] - 0.2;\n        newTension[i] = 0.2;\n        velocity[i] = -excess * 0.3;\n        \n        // Propagate release to neighbors\n        if (x > 0) velocity[idx(x-1, y)] -= excess * 0.1;\n        if (x < cols-1) velocity[idx(x+1, y)] -= excess * 0.1;\n        if (y > 0) velocity[idx(x, y-1)] -= excess * 0.1;\n        if (y < rows-1) velocity[idx(x, y+1)] -= excess * 0.1;\n        \n        playRelease(excess);\n      }\n      \n      // Clamp\n      newTension[i] = Math.max(0, Math.min(1.5, newTension[i]));\n      globalTension += tension[i];\n    }\n  }\n  \n  tension = newTension;\n  globalTension /= (cols * rows);\n  \n  // Update audio based on global tension\n  if (audioCtx && droneGain) {\n    droneGain.gain.value = globalTension * 0.4;\n    noiseGain.gain.value = globalTension * 0.15;\n    droneOsc.frequency.value = 55 + globalTension * 30;\n  }\n}\n\nfunction draw() {\n  // Clear with subtle fade for trails\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.3)';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Draw tension field\n  for (let y = 0; y < rows - 1; y++) {\n    for (let x = 0; x < cols - 1; x++) {\n      const t = tension[idx(x, y)];\n      const t_right = tension[idx(x + 1, y)];\n      const t_down = tension[idx(x, y + 1)];\n      const t_diag = tension[idx(x + 1, y + 1)];\n      const avgT = (t + t_right + t_down + t_diag) / 4;\n      \n      if (avgT > 0.05) {\n        const px = x * GRID;\n        const py = y * GRID;\n        \n        // Color based on tension level\n        const r = Math.floor(80 + avgT * 175);\n        const g = Math.floor(20 + avgT * 30);\n        const b = Math.floor(120 + avgT * 80);\n        const a = Math.min(1, avgT * 1.5);\n        \n        // Draw cell\n        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${a * 0.6})`;\n        ctx.fillRect(px, py, GRID, GRID);\n        \n        // Draw stress lines where tension is high\n        if (avgT > 0.4) {\n          ctx.strokeStyle = `rgba(${r + 50}, ${g + 50}, ${b + 50}, ${a * 0.8})`;\n          ctx.lineWidth = avgT * 2;\n          \n          // Connect to neighbors with visible tension\n          ctx.beginPath();\n          ctx.moveTo(px + GRID/2, py + GRID/2);\n          \n          if (t_right > 0.3) {\n            ctx.lineTo(px + GRID * 1.5, py + GRID/2);\n            ctx.moveTo(px + GRID/2, py + GRID/2);\n          }\n          if (t_down > 0.3) {\n            ctx.lineTo(px + GRID/2, py + GRID * 1.5);\n          }\n          ctx.stroke();\n        }\n        \n        // Critical tension glow\n        if (avgT > 0.7) {\n          const glow = ctx.createRadialGradient(\n            px + GRID/2, py + GRID/2, 0,\n            px + GRID/2, py + GRID/2, GRID * (avgT + 0.5)\n          );\n          glow.addColorStop(0, `rgba(255, 100, 200, ${(avgT - 0.7) * 2})`);\n          glow.addColorStop(0.5, `rgba(180, 50, 255, ${(avgT - 0.7)})`);\n          glow.addColorStop(1, 'rgba(100, 200, 255, 0)');\n          ctx.fillStyle = glow;\n          ctx.fillRect(px - GRID, py - GRID, GRID * 3, GRID * 3);\n        }\n      }\n    }\n  }\n  \n  // Draw release ripples (negative velocity = release)\n  for (let y = 0; y < rows; y++) {\n    for (let x = 0; x < cols; x++) {\n      const v = velocity[idx(x, y)];\n      if (v < -0.05) {\n        const px = x * GRID + GRID/2;\n        const py = y * GRID + GRID/2;\n        const intensity = Math.abs(v);\n        \n        ctx.beginPath();\n        ctx.arc(px, py, GRID * intensity * 3, 0, Math.PI * 2);\n        ctx.strokeStyle = `rgba(100, 220, 255, ${intensity})`;\n        ctx.lineWidth = 2;\n        ctx.stroke();\n      }\n    }\n  }\n  \n  // Mouse indicator when building tension\n  if (mouseStill > 30 && mouse.x > 0) {\n    const radius = 10 + mouseStill * 0.1;\n    const glow = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, radius);\n    glow.addColorStop(0, `rgba(255, 100, 180, ${mouseStill / 300})`);\n    glow.addColorStop(1, 'rgba(255, 100, 180, 0)');\n    ctx.fillStyle = glow;\n    ctx.beginPath();\n    ctx.arc(mouse.x, mouse.y, radius, 0, Math.PI * 2);\n    ctx.fill();\n    \n    // Pulsing ring\n    const pulse = Math.sin(Date.now() * 0.01) * 5;\n    ctx.beginPath();\n    ctx.arc(mouse.x, mouse.y, radius + pulse, 0, Math.PI * 2);\n    ctx.strokeStyle = `rgba(180, 50, 255, ${mouseStill / 400})`;\n    ctx.lineWidth = 1;\n    ctx.stroke();\n  }\n  \n  // Global tension indicator\n  const barWidth = 100;\n  const barHeight = 4;\n  const barX = W - barWidth - 20;\n  const barY = 20;\n  \n  ctx.fillStyle = 'rgba(50, 30, 60, 0.5)';\n  ctx.fillRect(barX, barY, barWidth, barHeight);\n  \n  const tensionColor = globalTension < 0.3 ? 'rgba(100, 200, 220, 0.8)' : \n                       globalTension < 0.6 ? 'rgba(180, 100, 220, 0.8)' : \n                       'rgba(255, 100, 180, 0.8)';\n  ctx.fillStyle = tensionColor;\n  ctx.fillRect(barX, barY, barWidth * Math.min(1, globalTension / 0.8), barHeight);\n}\n\nfunction forceSnap() {\n  // Find highest tension point and trigger snap\n  let maxT = 0;\n  let maxI = 0;\n  for (let i = 0; i < tension.length; i++) {\n    if (tension[i] > maxT) {\n      maxT = tension[i];\n      maxI = i;\n    }\n  }\n  \n  if (maxT > 0.2) {\n    tension[maxI] = 1.2; // Force it over threshold\n  } else {\n    // Add tension at mouse position\n    const mx = Math.floor(mouse.x / GRID);\n    const my = Math.floor(mouse.y / GRID);\n    if (mx >= 0 && mx < cols && my >= 0 && my < rows) {\n      tension[idx(mx, my)] = 1.2;\n    }\n  }\n}\n\nfunction loop() {\n  update();\n  draw();\n  requestAnimationFrame(loop);\n}\n\n// Events\nwindow.addEventListener('resize', resize);\n\ncanvas.addEventListener('mousemove', e => {\n  initAudio();\n  mouse.x = e.clientX;\n  mouse.y = e.clientY;\n});\n\ncanvas.addEventListener('touchmove', e => {\n  initAudio();\n  e.preventDefault();\n  mouse.x = e.touches[0].clientX;\n  mouse.y = e.touches[0].clientY;\n});\n\ncanvas.addEventListener('click', () => {\n  initAudio();\n  forceSnap();\n});\n\ncanvas.addEventListener('touchstart', e => {\n  initAudio();\n  mouse.x = e.touches[0].clientX;\n  mouse.y = e.touches[0].clientY;\n});\n\n// Init\nresize();\nloop();\n</script>\n</body>\n</html>\n"
}
