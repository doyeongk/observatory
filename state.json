  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>pulse</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0a; \n  overflow: hidden; \n  cursor: crosshair;\n}\ncanvas { display: block; }\n#start-overlay {\n  position: fixed;\n  top: 0; left: 0; right: 0; bottom: 0;\n  background: rgba(10, 10, 10, 0.95);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 100;\n  cursor: pointer;\n}\n#start-overlay span {\n  color: #ff66b2;\n  font-family: monospace;\n  font-size: 14px;\n  letter-spacing: 2px;\n  opacity: 0.7;\n  animation: pulse-text 2s ease-in-out infinite;\n}\n@keyframes pulse-text {\n  0%, 100% { opacity: 0.4; }\n  50% { opacity: 0.9; }\n}\n</style>\n</head>\n<body>\n<div id=\"start-overlay\"><span>click to feel the pulse</span></div>\n<canvas id=\"canvas\"></canvas>\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nconst overlay = document.getElementById('start-overlay');\n\nlet width, height, centerX, centerY;\nlet audioCtx, gainNode;\nlet heartRate = 72; // BPM\nlet lastBeat = 0;\nlet beatPhase = 0;\nlet mouseX = 0, mouseY = 0;\nlet audioStarted = false;\n\n// Arterial network\nlet arteries = [];\nlet pulseWaves = [];\n\nfunction resize() {\n  width = canvas.width = window.innerWidth;\n  height = canvas.height = window.innerHeight;\n  centerX = width / 2;\n  centerY = height / 2;\n  generateArteries();\n}\n\n// Generate branching arterial tree\nfunction generateArteries() {\n  arteries = [];\n  const numBranches = 6;\n  \n  for (let i = 0; i < numBranches; i++) {\n    const angle = (i / numBranches) * Math.PI * 2 + Math.random() * 0.3;\n    generateBranch(centerX, centerY, angle, 180, 8, 0);\n  }\n}\n\nfunction generateBranch(x, y, angle, length, thickness, depth) {\n  if (depth > 6 || length < 15) return;\n  \n  const segments = [];\n  let cx = x, cy = y;\n  const segmentLength = length / 8;\n  \n  for (let i = 0; i < 8; i++) {\n    const wobble = (Math.random() - 0.5) * 0.15;\n    cx += Math.cos(angle + wobble) * segmentLength;\n    cy += Math.sin(angle + wobble) * segmentLength;\n    segments.push({ x: cx, y: cy });\n  }\n  \n  arteries.push({\n    startX: x,\n    startY: y,\n    segments,\n    thickness,\n    depth,\n    pulseOffset: Math.random() * Math.PI * 2,\n    hue: depth < 2 ? 330 : (depth < 4 ? 280 : 190) // pink -> purple -> cyan\n  });\n  \n  // Branch\n  const endX = segments[segments.length - 1].x;\n  const endY = segments[segments.length - 1].y;\n  \n  if (Math.random() > 0.3) {\n    generateBranch(endX, endY, angle + 0.4 + Math.random() * 0.3, length * 0.7, thickness * 0.7, depth + 1);\n  }\n  if (Math.random() > 0.3) {\n    generateBranch(endX, endY, angle - 0.4 - Math.random() * 0.3, length * 0.7, thickness * 0.7, depth + 1);\n  }\n}\n\n// Audio synthesis for heartbeat\nfunction initAudio() {\n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  gainNode = audioCtx.createGain();\n  gainNode.connect(audioCtx.destination);\n  gainNode.gain.value = 0;\n}\n\nfunction playHeartbeat() {\n  if (!audioCtx) return;\n  \n  const now = audioCtx.currentTime;\n  \n  // First thump (lub)\n  createThump(now, 55, 0.12, 0.4);\n  \n  // Second thump (dub) - slightly higher, quieter\n  createThump(now + 0.12, 45, 0.08, 0.25);\n}\n\nfunction createThump(time, freq, duration, volume) {\n  const osc = audioCtx.createOscillator();\n  const gain = audioCtx.createGain();\n  const filter = audioCtx.createBiquadFilter();\n  \n  osc.type = 'sine';\n  osc.frequency.setValueAtTime(freq, time);\n  osc.frequency.exponentialRampToValueAtTime(freq * 0.5, time + duration);\n  \n  filter.type = 'lowpass';\n  filter.frequency.value = 150;\n  \n  gain.gain.setValueAtTime(0, time);\n  gain.gain.linearRampToValueAtTime(volume, time + 0.015);\n  gain.gain.exponentialRampToValueAtTime(0.001, time + duration);\n  \n  osc.connect(filter);\n  filter.connect(gain);\n  gain.connect(audioCtx.destination);\n  \n  osc.start(time);\n  osc.stop(time + duration + 0.1);\n}\n\nfunction update(time) {\n  // Mouse distance from center affects heart rate\n  const dx = mouseX - centerX;\n  const dy = mouseY - centerY;\n  const dist = Math.sqrt(dx * dx + dy * dy);\n  const maxDist = Math.min(width, height) / 2;\n  \n  // Close to center = calm (60 BPM), far = anxious (120 BPM)\n  const targetRate = 60 + (dist / maxDist) * 60;\n  heartRate += (targetRate - heartRate) * 0.02;\n  \n  const beatInterval = 60000 / heartRate;\n  \n  if (time - lastBeat > beatInterval) {\n    lastBeat = time;\n    beatPhase = 1;\n    \n    if (audioStarted) {\n      playHeartbeat();\n    }\n    \n    // Spawn pulse wave\n    pulseWaves.push({\n      radius: 0,\n      maxRadius: maxDist * 1.5,\n      alpha: 1,\n      birth: time\n    });\n  }\n  \n  // Decay beat phase\n  beatPhase *= 0.92;\n  \n  // Update pulse waves\n  pulseWaves = pulseWaves.filter(wave => {\n    wave.radius += 8 + heartRate / 20;\n    wave.alpha = 1 - (wave.radius / wave.maxRadius);\n    return wave.alpha > 0;\n  });\n}\n\nfunction draw(time) {\n  // Dark fade with slight persistence\n  ctx.fillStyle = 'rgba(10, 10, 10, 0.15)';\n  ctx.fillRect(0, 0, width, height);\n  \n  // Draw pulse waves\n  pulseWaves.forEach(wave => {\n    const gradient = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, wave.radius);\n    gradient.addColorStop(0, `rgba(255, 102, 178, 0)`);\n    gradient.addColorStop(0.7, `rgba(255, 102, 178, ${wave.alpha * 0.05})`);\n    gradient.addColorStop(1, `rgba(255, 102, 178, 0)`);\n    \n    ctx.beginPath();\n    ctx.arc(centerX, centerY, wave.radius, 0, Math.PI * 2);\n    ctx.fillStyle = gradient;\n    ctx.fill();\n  });\n  \n  // Draw arteries\n  arteries.forEach(artery => {\n    const pulseProgress = Math.sin(time * 0.003 * (heartRate / 72) + artery.pulseOffset);\n    const expansion = 1 + beatPhase * 0.4 * (1 - artery.depth / 7);\n    const thickness = artery.thickness * expansion;\n    \n    // Blood flow glow\n    const flowIntensity = 0.3 + beatPhase * 0.7;\n    \n    ctx.beginPath();\n    ctx.moveTo(artery.startX, artery.startY);\n    \n    artery.segments.forEach((seg, i) => {\n      const wobble = Math.sin(time * 0.002 + i + artery.pulseOffset) * (2 - artery.depth * 0.2);\n      ctx.lineTo(seg.x + wobble, seg.y + wobble);\n    });\n    \n    // Outer glow\n    ctx.strokeStyle = `hsla(${artery.hue}, 100%, 60%, ${flowIntensity * 0.3})`;\n    ctx.lineWidth = thickness * 3;\n    ctx.lineCap = 'round';\n    ctx.lineJoin = 'round';\n    ctx.stroke();\n    \n    // Core\n    ctx.strokeStyle = `hsla(${artery.hue}, 100%, 70%, ${flowIntensity * 0.8})`;\n    ctx.lineWidth = thickness;\n    ctx.stroke();\n    \n    // Bright center\n    ctx.strokeStyle = `hsla(${artery.hue}, 50%, 90%, ${flowIntensity * 0.5})`;\n    ctx.lineWidth = thickness * 0.3;\n    ctx.stroke();\n  });\n  \n  // Central heart\n  const heartSize = 30 + beatPhase * 25;\n  const heartGlow = 60 + beatPhase * 40;\n  \n  // Outer glow\n  const gradient = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, heartGlow);\n  gradient.addColorStop(0, `rgba(255, 102, 178, ${0.4 + beatPhase * 0.4})`);\n  gradient.addColorStop(0.5, `rgba(180, 50, 180, ${0.2 + beatPhase * 0.2})`);\n  gradient.addColorStop(1, 'rgba(100, 0, 100, 0)');\n  \n  ctx.beginPath();\n  ctx.arc(centerX, centerY, heartGlow, 0, Math.PI * 2);\n  ctx.fillStyle = gradient;\n  ctx.fill();\n  \n  // Heart core\n  ctx.beginPath();\n  ctx.arc(centerX, centerY, heartSize, 0, Math.PI * 2);\n  ctx.fillStyle = `rgba(255, 102, 178, ${0.8 + beatPhase * 0.2})`;\n  ctx.fill();\n  \n  // Inner bright spot\n  ctx.beginPath();\n  ctx.arc(centerX, centerY, heartSize * 0.4, 0, Math.PI * 2);\n  ctx.fillStyle = `rgba(255, 200, 230, ${0.6 + beatPhase * 0.4})`;\n  ctx.fill();\n  \n  // BPM display\n  ctx.font = '12px monospace';\n  ctx.fillStyle = `rgba(0, 255, 255, ${0.3 + beatPhase * 0.3})`;\n  ctx.textAlign = 'center';\n  ctx.fillText(`${Math.round(heartRate)} BPM`, centerX, height - 30);\n}\n\nfunction animate(time) {\n  update(time);\n  draw(time);\n  requestAnimationFrame(animate);\n}\n\n// Event listeners\nwindow.addEventListener('resize', resize);\n\ndocument.addEventListener('mousemove', e => {\n  mouseX = e.clientX;\n  mouseY = e.clientY;\n});\n\ndocument.addEventListener('click', () => {\n  if (!audioStarted) {\n    overlay.style.display = 'none';\n    initAudio();\n    audioStarted = true;\n    // Force immediate beat\n    lastBeat = 0;\n  }\n});\n\n// Touch support\ndocument.addEventListener('touchmove', e => {\n  if (e.touches.length > 0) {\n    mouseX = e.touches[0].clientX;\n    mouseY = e.touches[0].clientY;\n  }\n});\n\ndocument.addEventListener('touchstart', () => {\n  if (!audioStarted) {\n    overlay.style.display = 'none';\n    initAudio();\n    audioStarted = true;\n    lastBeat = 0;\n  }\n});\n\n// Initialize\nresize();\nmouseX = centerX;\nmouseY = centerY;\nrequestAnimationFrame(animate);\n</script>\n</body>\n</html>\n"
}
