  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>double</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  font-family: monospace;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: rgba(255, 100, 200, 0.6);\n  font-size: 12px;\n  pointer-events: none;\n}\n</style>\n</head>\n<body>\n<canvas id=\"canvas\"></canvas>\n<div id=\"info\">click to spawn · drag to disturb</div>\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H, cx, cy;\nconst g = 9.81;\nconst dt = 0.016;\nconst substeps = 8;\n\n// Audio context\nlet audioCtx = null;\nlet oscillators = [];\nlet gainNodes = [];\n\nfunction initAudio() {\n  if (audioCtx) return;\n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  \n  // Create oscillators for each pendulum\n  for (let i = 0; i < 4; i++) {\n    const osc = audioCtx.createOscillator();\n    const gain = audioCtx.createGain();\n    const filter = audioCtx.createBiquadFilter();\n    \n    osc.type = 'sine';\n    osc.frequency.value = 100 + i * 50;\n    filter.type = 'lowpass';\n    filter.frequency.value = 400;\n    filter.Q.value = 2;\n    gain.gain.value = 0;\n    \n    osc.connect(filter);\n    filter.connect(gain);\n    gain.connect(audioCtx.destination);\n    osc.start();\n    \n    oscillators.push(osc);\n    gainNodes.push(gain);\n  }\n}\n\nclass DoublePendulum {\n  constructor(x, y, l1, l2, m1, m2, a1, a2, hue) {\n    this.ox = x;\n    this.oy = y;\n    this.l1 = l1;\n    this.l2 = l2;\n    this.m1 = m1;\n    this.m2 = m2;\n    this.a1 = a1;\n    this.a2 = a2;\n    this.v1 = 0;\n    this.v2 = 0;\n    this.hue = hue;\n    this.trail = [];\n    this.maxTrail = 800;\n  }\n\n  update() {\n    for (let i = 0; i < substeps; i++) {\n      const subDt = dt / substeps;\n      \n      // Double pendulum equations of motion\n      const { l1, l2, m1, m2, a1, a2, v1, v2 } = this;\n      \n      const num1 = -g * (2 * m1 + m2) * Math.sin(a1);\n      const num2 = -m2 * g * Math.sin(a1 - 2 * a2);\n      const num3 = -2 * Math.sin(a1 - a2) * m2;\n      const num4 = v2 * v2 * l2 + v1 * v1 * l1 * Math.cos(a1 - a2);\n      const den = l1 * (2 * m1 + m2 - m2 * Math.cos(2 * a1 - 2 * a2));\n      const acc1 = (num1 + num2 + num3 * num4) / den;\n\n      const num5 = 2 * Math.sin(a1 - a2);\n      const num6 = v1 * v1 * l1 * (m1 + m2);\n      const num7 = g * (m1 + m2) * Math.cos(a1);\n      const num8 = v2 * v2 * l2 * m2 * Math.cos(a1 - a2);\n      const den2 = l2 * (2 * m1 + m2 - m2 * Math.cos(2 * a1 - 2 * a2));\n      const acc2 = (num5 * (num6 + num7 + num8)) / den2;\n\n      this.v1 += acc1 * subDt;\n      this.v2 += acc2 * subDt;\n      this.a1 += this.v1 * subDt;\n      this.a2 += this.v2 * subDt;\n\n      // Damping\n      this.v1 *= 0.9999;\n      this.v2 *= 0.9999;\n    }\n\n    // Calculate end positions\n    const x1 = this.ox + this.l1 * Math.sin(this.a1);\n    const y1 = this.oy + this.l1 * Math.cos(this.a1);\n    const x2 = x1 + this.l2 * Math.sin(this.a2);\n    const y2 = y1 + this.l2 * Math.cos(this.a2);\n\n    this.x1 = x1;\n    this.y1 = y1;\n    this.x2 = x2;\n    this.y2 = y2;\n\n    // Add to trail\n    this.trail.push({ x: x2, y: y2, v: Math.abs(this.v2) });\n    if (this.trail.length > this.maxTrail) {\n      this.trail.shift();\n    }\n  }\n\n  draw() {\n    // Draw trail with gradient based on velocity and age\n    if (this.trail.length > 1) {\n      for (let i = 1; i < this.trail.length; i++) {\n        const p1 = this.trail[i - 1];\n        const p2 = this.trail[i];\n        const age = i / this.trail.length;\n        const vel = Math.min(p2.v * 0.1, 1);\n        \n        ctx.beginPath();\n        ctx.moveTo(p1.x, p1.y);\n        ctx.lineTo(p2.x, p2.y);\n        \n        // Color shifts based on velocity and hue\n        const h = (this.hue + vel * 60) % 360;\n        const alpha = age * 0.8 * (0.3 + vel * 0.7);\n        ctx.strokeStyle = `hsla(${h}, 100%, 65%, ${alpha})`;\n        ctx.lineWidth = 1 + vel * 2;\n        ctx.stroke();\n      }\n    }\n\n    // Draw arms\n    ctx.beginPath();\n    ctx.moveTo(this.ox, this.oy);\n    ctx.lineTo(this.x1, this.y1);\n    ctx.lineTo(this.x2, this.y2);\n    ctx.strokeStyle = `hsla(${this.hue}, 60%, 50%, 0.4)`;\n    ctx.lineWidth = 2;\n    ctx.stroke();\n\n    // Draw pivot\n    ctx.beginPath();\n    ctx.arc(this.ox, this.oy, 4, 0, Math.PI * 2);\n    ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, 0.8)`;\n    ctx.fill();\n\n    // Draw joints with glow\n    ctx.shadowBlur = 15;\n    ctx.shadowColor = `hsla(${this.hue}, 100%, 60%, 0.8)`;\n    \n    ctx.beginPath();\n    ctx.arc(this.x1, this.y1, 6, 0, Math.PI * 2);\n    ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, 0.9)`;\n    ctx.fill();\n\n    ctx.beginPath();\n    ctx.arc(this.x2, this.y2, 8, 0, Math.PI * 2);\n    ctx.fillStyle = `hsla(${(this.hue + 30) % 360}, 100%, 70%, 1)`;\n    ctx.fill();\n    \n    ctx.shadowBlur = 0;\n  }\n\n  perturb(mx, my, strength) {\n    const dx1 = this.x1 - mx;\n    const dy1 = this.y1 - my;\n    const dx2 = this.x2 - mx;\n    const dy2 = this.y2 - my;\n    const d1 = Math.sqrt(dx1 * dx1 + dy1 * dy1);\n    const d2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);\n    \n    if (d1 < 150) {\n      this.v1 += (Math.random() - 0.5) * strength * (1 - d1 / 150);\n    }\n    if (d2 < 150) {\n      this.v2 += (Math.random() - 0.5) * strength * (1 - d2 / 150);\n    }\n  }\n}\n\nlet pendulums = [];\n\nfunction spawnPendulum(x, y) {\n  const scale = Math.min(W, H) * 0.15;\n  const l1 = scale * (0.8 + Math.random() * 0.4);\n  const l2 = scale * (0.8 + Math.random() * 0.4);\n  const a1 = Math.PI * (0.5 + Math.random());\n  const a2 = Math.PI * (0.5 + Math.random());\n  \n  // Palette: cyan (180), pink (320), purple (280)\n  const hues = [180, 300, 320, 260];\n  const hue = hues[pendulums.length % hues.length];\n  \n  const p = new DoublePendulum(x, y, l1, l2, 10, 10, a1, a2, hue);\n  pendulums.push(p);\n  \n  if (pendulums.length > 6) {\n    pendulums.shift();\n  }\n}\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n  cx = W / 2;\n  cy = H / 2;\n}\n\nfunction updateAudio() {\n  if (!audioCtx || pendulums.length === 0) return;\n  \n  pendulums.forEach((p, i) => {\n    if (i >= gainNodes.length) return;\n    \n    // Map angular velocity to pitch and volume\n    const energy = Math.abs(p.v1) + Math.abs(p.v2);\n    const freq = 80 + energy * 30;\n    const vol = Math.min(energy * 0.02, 0.08);\n    \n    oscillators[i].frequency.setTargetAtTime(freq, audioCtx.currentTime, 0.1);\n    gainNodes[i].gain.setTargetAtTime(vol, audioCtx.currentTime, 0.1);\n  });\n}\n\nlet mouseX = 0, mouseY = 0, mouseDown = false;\n\nfunction animate() {\n  // Fade trail\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.08)';\n  ctx.fillRect(0, 0, W, H);\n\n  // Update and draw pendulums\n  pendulums.forEach(p => {\n    if (mouseDown) {\n      p.perturb(mouseX, mouseY, 0.3);\n    }\n    p.update();\n    p.draw();\n  });\n\n  updateAudio();\n  requestAnimationFrame(animate);\n}\n\n// Event listeners\nwindow.addEventListener('resize', resize);\n\ncanvas.addEventListener('click', (e) => {\n  initAudio();\n  spawnPendulum(e.clientX, e.clientY);\n});\n\ncanvas.addEventListener('mousedown', (e) => {\n  initAudio();\n  mouseDown = true;\n  mouseX = e.clientX;\n  mouseY = e.clientY;\n});\n\ncanvas.addEventListener('mouseup', () => mouseDown = false);\ncanvas.addEventListener('mouseleave', () => mouseDown = false);\n\ncanvas.addEventListener('mousemove', (e) => {\n  mouseX = e.clientX;\n  mouseY = e.clientY;\n});\n\n// Touch support\ncanvas.addEventListener('touchstart', (e) => {\n  e.preventDefault();\n  initAudio();\n  const touch = e.touches[0];\n  spawnPendulum(touch.clientX, touch.clientY);\n  mouseDown = true;\n  mouseX = touch.clientX;\n  mouseY = touch.clientY;\n});\n\ncanvas.addEventListener('touchmove', (e) => {\n  const touch = e.touches[0];\n  mouseX = touch.clientX;\n  mouseY = touch.clientY;\n});\n\ncanvas.addEventListener('touchend', () => mouseDown = false);\n\n// Initialize\nresize();\n\n// Spawn initial pendulums showing chaos divergence\nsetTimeout(() => {\n  const baseAngle = Math.PI * 0.75;\n  for (let i = 0; i < 3; i++) {\n    const scale = Math.min(W, H) * 0.18;\n    const offset = (i - 1) * 80;\n    // Tiny differences in initial angle\n    const a1 = baseAngle + i * 0.001;\n    const a2 = baseAngle + i * 0.001;\n    const hues = [180, 300, 320];\n    const p = new DoublePendulum(cx + offset, cy - 100, scale, scale, 10, 10, a1, a2, hues[i]);\n    pendulums.push(p);\n  }\n}, 100);\n\nanimate();\n</script>\n</body>\n</html>\n"
}
