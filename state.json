ke-dasharray: 12 88; }\n    \n    @keyframes flow {\n      to { stroke-dashoffset: 0; }\n    }\n    \n    /* Components */\n    .chip {\n      position: absolute;\n      background: #111;\n      border: 2px solid #222;\n      border-radius: 4px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-size: 8px;\n      color: #444;\n      box-shadow: \n        inset 0 1px 0 rgba(255,255,255,0.05),\n        0 4px 8px rgba(0,0,0,0.5);\n    }\n    \n    .chip::before {\n      content: '';\n      position: absolute;\n      top: 4px;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 6px;\n      height: 6px;\n      border-radius: 50%;\n      background: radial-gradient(circle, #1a1a1a 40%, #0a0a0a 100%);\n    }\n    \n    .chip-main {\n      width: 80px;\n      height: 80px;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n    }\n    \n    .chip-main .label {\n      font-size: 10px;\n      color: #0ff;\n      text-shadow: 0 0 10px #0ff;\n      animation: pulse 2s ease-in-out infinite;\n    }\n    \n    .chip-sm {\n      width: 40px;\n      height: 25px;\n    }\n    \n    .chip-1 { top: 20%; left: 15%; }\n    .chip-2 { top: 15%; right: 20%; }\n    .chip-3 { bottom: 25%; left: 20%; }\n    .chip-4 { bottom: 20%; right: 15%; }\n    \n    /* Via holes */\n    .via {\n      position: absolute;\n      width: 8px;\n      height: 8px;\n      border-radius: 50%;\n      background: #0a0a0a;\n      border: 2px solid;\n      animation: via-glow 2s ease-in-out infinite;\n    }\n    \n    .via-cyan { border-color: #0ff; animation-delay: 0s; }\n    .via-pink { border-color: #ff2d95; animation-delay: 0.5s; }\n    .via-teal { border-color: #00ffa3; animation-delay: 1s; }\n    \n    @keyframes via-glow {\n      0%, 100% { box-shadow: 0 0 5px currentColor; }\n      50% { box-shadow: 0 0 15px currentColor, 0 0 25px currentColor; }\n    }\n    \n    @keyframes pulse {\n      0%, 100% { opacity: 0.7; }\n      50%