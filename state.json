  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>strange loop</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  font-family: monospace;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: rgba(0, 255, 255, 0.4);\n  font-size: 11px;\n  pointer-events: none;\n  text-transform: lowercase;\n}\n</style>\n</head>\n<body>\n<canvas id=\"c\"></canvas>\n<div id=\"info\">click to perturb · drag to rotate</div>\n<script>\nconst canvas = document.getElementById('c');\nconst ctx = canvas.getContext('2d');\n\nlet W, H;\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// Lorenz system parameters\nconst sigma = 10;\nconst rho = 28;\nconst beta = 8/3;\nconst dt = 0.003;\n\n// Multiple particles to show the butterfly effect\nclass Particle {\n  constructor(x, y, z, hue) {\n    this.x = x;\n    this.y = y;\n    this.z = z;\n    this.hue = hue;\n    this.trail = [];\n    this.maxTrail = 400;\n  }\n  \n  step() {\n    const dx = sigma * (this.y - this.x);\n    const dy = this.x * (rho - this.z) - this.y;\n    const dz = this.x * this.y - beta * this.z;\n    \n    this.x += dx * dt;\n    this.y += dy * dt;\n    this.z += dz * dt;\n    \n    this.trail.push({ x: this.x, y: this.y, z: this.z });\n    if (this.trail.length > this.maxTrail) {\n      this.trail.shift();\n    }\n  }\n}\n\n// Create particles with tiny differences (butterfly effect)\nlet particles = [];\nfunction initParticles() {\n  particles = [];\n  const baseX = 0.1 + Math.random() * 0.1;\n  const baseY = 0.1 + Math.random() * 0.1;\n  const baseZ = 0.1 + Math.random() * 0.1;\n  \n  // Cyan primary\n  particles.push(new Particle(baseX, baseY, baseZ, 180));\n  // Pink — nearly identical starting point\n  particles.push(new Particle(baseX + 0.0001, baseY, baseZ, 320));\n  // Purple — another tiny variation\n  particles.push(new Particle(baseX, baseY + 0.0001, baseZ, 280));\n}\ninitParticles();\n\n// Camera rotation\nlet rotX = 0.3;\nlet rotY = 0;\nlet autoRotate = true;\nlet isDragging = false;\nlet lastMouse = { x: 0, y: 0 };\n\ncanvas.addEventListener('mousedown', (e) => {\n  isDragging = true;\n  autoRotate = false;\n  lastMouse = { x: e.clientX, y: e.clientY };\n});\n\ncanvas.addEventListener('mousemove', (e) => {\n  if (isDragging) {\n    const dx = e.clientX - lastMouse.x;\n    const dy = e.clientY - lastMouse.y;\n    rotY += dx * 0.005;\n    rotX += dy * 0.005;\n    lastMouse = { x: e.clientX, y: e.clientY };\n  }\n});\n\ncanvas.addEventListener('mouseup', () => {\n  isDragging = false;\n  setTimeout(() => { autoRotate = true; }, 3000);\n});\n\ncanvas.addEventListener('click', (e) => {\n  // Perturb — restart with new initial conditions\n  initParticles();\n  perturbFlash = 1;\n});\n\n// Touch support\ncanvas.addEventListener('touchstart', (e) => {\n  isDragging = true;\n  autoRotate = false;\n  lastMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };\n});\n\ncanvas.addEventListener('touchmove', (e) => {\n  if (isDragging && e.touches.length === 1) {\n    const dx = e.touches[0].clientX - lastMouse.x;\n    const dy = e.touches[0].clientY - lastMouse.y;\n    rotY += dx * 0.005;\n    rotX += dy * 0.005;\n    lastMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };\n  }\n});\n\ncanvas.addEventListener('touchend', () => {\n  isDragging = false;\n  setTimeout(() => { autoRotate = true; }, 3000);\n});\n\nlet perturbFlash = 0;\n\n// 3D to 2D projection with rotation\nfunction project(x, y, z) {\n  // Center the attractor (it orbits around ~0,0,25)\n  const cx = x;\n  const cy = y;\n  const cz = z - 25;\n  \n  // Rotate around Y axis\n  const x1 = cx * Math.cos(rotY) - cz * Math.sin(rotY);\n  const z1 = cx * Math.sin(rotY) + cz * Math.cos(rotY);\n  \n  // Rotate around X axis\n  const y2 = cy * Math.cos(rotX) - z1 * Math.sin(rotX);\n  const z2 = cy * Math.sin(rotX) + z1 * Math.cos(rotX);\n  \n  // Perspective projection\n  const scale = 12;\n  const perspective = 200;\n  const factor = perspective / (perspective + z2);\n  \n  return {\n    x: W/2 + x1 * scale * factor,\n    y: H/2 + y2 * scale * factor,\n    z: z2,\n    factor: factor\n  };\n}\n\n// Web Audio — ethereal drone based on particle positions\nlet audioCtx, gainNode, oscillators = [];\nlet audioInitialized = false;\n\nfunction initAudio() {\n  if (audioInitialized) return;\n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  gainNode = audioCtx.createGain();\n  gainNode.gain.value = 0.03;\n  gainNode.connect(audioCtx.destination);\n  \n  // Create oscillators for each particle\n  for (let i = 0; i < 3; i++) {\n    const osc = audioCtx.createOscillator();\n    const oscGain = audioCtx.createGain();\n    oscGain.gain.value = 0.3;\n    osc.type = 'sine';\n    osc.frequency.value = 200 + i * 50;\n    osc.connect(oscGain);\n    oscGain.connect(gainNode);\n    osc.start();\n    oscillators.push({ osc, gain: oscGain });\n  }\n  \n  audioInitialized = true;\n}\n\ndocument.addEventListener('click', initAudio, { once: true });\ndocument.addEventListener('touchstart', initAudio, { once: true });\n\nfunction updateAudio() {\n  if (!audioInitialized) return;\n  \n  particles.forEach((p, i) => {\n    if (oscillators[i]) {\n      // Map position to frequency (pentatonic-ish for pleasantness)\n      const baseFreq = 100 + (p.z / 50) * 200;\n      const freq = baseFreq * (1 + p.x / 100);\n      oscillators[i].osc.frequency.setTargetAtTime(\n        Math.max(50, Math.min(800, freq)), \n        audioCtx.currentTime, \n        0.1\n      );\n      \n      // Map velocity to volume\n      const speed = Math.sqrt(p.x*p.x + p.y*p.y) / 50;\n      oscillators[i].gain.gain.setTargetAtTime(\n        Math.min(0.4, speed * 0.2),\n        audioCtx.currentTime,\n        0.1\n      );\n    }\n  });\n}\n\nfunction draw() {\n  // Fade effect for trails\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.08)';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Flash on perturbation\n  if (perturbFlash > 0) {\n    ctx.fillStyle = `rgba(0, 255, 255, ${perturbFlash * 0.1})`;\n    ctx.fillRect(0, 0, W, H);\n    perturbFlash *= 0.9;\n  }\n  \n  // Auto-rotate slowly\n  if (autoRotate) {\n    rotY += 0.002;\n  }\n  \n  // Step the simulation multiple times per frame for smoothness\n  for (let i = 0; i < 8; i++) {\n    particles.forEach(p => p.step());\n  }\n  \n  // Update audio\n  updateAudio();\n  \n  // Draw trails\n  particles.forEach((particle, pIdx) => {\n    const trail = particle.trail;\n    if (trail.length < 2) return;\n    \n    ctx.beginPath();\n    \n    for (let i = 1; i < trail.length; i++) {\n      const p0 = project(trail[i-1].x, trail[i-1].y, trail[i-1].z);\n      const p1 = project(trail[i].x, trail[i].y, trail[i].z);\n      \n      // Age-based alpha\n      const age = i / trail.length;\n      const alpha = age * 0.8 * p1.factor;\n      \n      // Depth-based lightness\n      const lightness = 40 + p1.factor * 30;\n      \n      ctx.strokeStyle = `hsla(${particle.hue}, 80%, ${lightness}%, ${alpha})`;\n      ctx.lineWidth = 1.5 * p1.factor;\n      \n      ctx.beginPath();\n      ctx.moveTo(p0.x, p0.y);\n      ctx.lineTo(p1.x, p1.y);\n      ctx.stroke();\n    }\n    \n    // Draw current position as a glowing point\n    const current = trail[trail.length - 1];\n    const pc = project(current.x, current.y, current.z);\n    \n    const gradient = ctx.createRadialGradient(pc.x, pc.y, 0, pc.x, pc.y, 8 * pc.factor);\n    gradient.addColorStop(0, `hsla(${particle.hue}, 100%, 80%, 0.9)`);\n    gradient.addColorStop(0.5, `hsla(${particle.hue}, 80%, 50%, 0.4)`);\n    gradient.addColorStop(1, 'transparent');\n    \n    ctx.fillStyle = gradient;\n    ctx.beginPath();\n    ctx.arc(pc.x, pc.y, 8 * pc.factor, 0, Math.PI * 2);\n    ctx.fill();\n  });\n  \n  // Draw faint attractor skeleton (the equilibrium points)\n  const eq1 = project(Math.sqrt(beta * (rho - 1)), Math.sqrt(beta * (rho - 1)), rho - 1);\n  const eq2 = project(-Math.sqrt(beta * (rho - 1)), -Math.sqrt(beta * (rho - 1)), rho - 1);\n  \n  ctx.fillStyle = 'rgba(255, 255, 255, 0.1)';\n  ctx.beginPath();\n  ctx.arc(eq1.x, eq1.y, 3, 0, Math.PI * 2);\n  ctx.fill();\n  ctx.beginPath();\n  ctx.arc(eq2.x, eq2.y, 3, 0, Math.PI * 2);\n  ctx.fill();\n  \n  requestAnimationFrame(draw);\n}\n\ndraw();\n</script>\n</body>\n</html>\n"
}
