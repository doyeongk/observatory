  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>cymatics</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  cursor: crosshair;\n}\ncanvas { display: block; }\n#hint {\n  position: fixed;\n  bottom: 20px;\n  left: 50%;\n  transform: translateX(-50%);\n  color: rgba(255, 50, 150, 0.4);\n  font-family: 'Courier New', monospace;\n  font-size: 12px;\n  letter-spacing: 2px;\n  pointer-events: none;\n  opacity: 1;\n  transition: opacity 2s ease;\n}\n</style>\n</head>\n<body>\n<canvas id=\"canvas\"></canvas>\n<div id=\"hint\">click to strike the membrane</div>\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nconst hint = document.getElementById('hint');\n\nlet width, height, gridW, gridH;\nconst cellSize = 4;\nlet current, previous, damping = 0.985;\n\n// Web Audio setup\nlet audioCtx = null;\nconst initAudio = () => {\n  if (!audioCtx) {\n    audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  }\n};\n\n// Create resonant tone on strike\nconst playTone = (x, y, intensity) => {\n  if (!audioCtx) return;\n  \n  const osc = audioCtx.createOscillator();\n  const gain = audioCtx.createGain();\n  const filter = audioCtx.createBiquadFilter();\n  \n  // Frequency based on position (creates harmonic relationship)\n  const baseFreq = 80;\n  const xHarmonic = Math.floor((x / gridW) * 8) + 1;\n  const yHarmonic = Math.floor((y / gridH) * 6) + 1;\n  const freq = baseFreq * (xHarmonic + yHarmonic * 0.5);\n  \n  osc.type = 'sine';\n  osc.frequency.setValueAtTime(freq, audioCtx.currentTime);\n  osc.frequency.exponentialRampToValueAtTime(freq * 0.5, audioCtx.currentTime + 1.5);\n  \n  filter.type = 'lowpass';\n  filter.frequency.setValueAtTime(2000, audioCtx.currentTime);\n  filter.Q.setValueAtTime(8, audioCtx.currentTime);\n  \n  gain.gain.setValueAtTime(Math.min(0.15, intensity * 0.003), audioCtx.currentTime);\n  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 1.5);\n  \n  osc.connect(filter);\n  filter.connect(gain);\n  gain.connect(audioCtx.destination);\n  \n  osc.start();\n  osc.stop(audioCtx.currentTime + 1.5);\n};\n\nfunction resize() {\n  width = canvas.width = window.innerWidth;\n  height = canvas.height = window.innerHeight;\n  gridW = Math.ceil(width / cellSize);\n  gridH = Math.ceil(height / cellSize);\n  \n  current = new Float32Array(gridW * gridH);\n  previous = new Float32Array(gridW * gridH);\n}\n\nfunction idx(x, y) {\n  return y * gridW + x;\n}\n\n// Strike the membrane at a point\nfunction strike(cx, cy, radius, force) {\n  const gx = Math.floor(cx / cellSize);\n  const gy = Math.floor(cy / cellSize);\n  \n  for (let dy = -radius; dy <= radius; dy++) {\n    for (let dx = -radius; dx <= radius; dx++) {\n      const x = gx + dx;\n      const y = gy + dy;\n      if (x < 0 || x >= gridW || y < 0 || y >= gridH) continue;\n      \n      const dist = Math.sqrt(dx * dx + dy * dy);\n      if (dist < radius) {\n        const falloff = 1 - (dist / radius);\n        const wave = Math.cos(dist * 0.5) * falloff * falloff;\n        current[idx(x, y)] += force * wave;\n      }\n    }\n  }\n  \n  playTone(gx, gy, force);\n}\n\n// 2D wave equation simulation\nfunction simulate() {\n  const next = new Float32Array(gridW * gridH);\n  \n  for (let y = 1; y < gridH - 1; y++) {\n    for (let x = 1; x < gridW - 1; x++) {\n      const i = idx(x, y);\n      \n      // Laplacian (neighbors average)\n      const neighbors = \n        current[idx(x-1, y)] + \n        current[idx(x+1, y)] + \n        current[idx(x, y-1)] + \n        current[idx(x, y+1)];\n      \n      // Wave equation: acceleration proportional to curvature\n      next[i] = (neighbors / 2) - previous[i];\n      next[i] *= damping;\n    }\n  }\n  \n  previous = current;\n  current = next;\n}\n\nfunction render() {\n  // Dark fade with subtle trail\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';\n  ctx.fillRect(0, 0, width, height);\n  \n  const imageData = ctx.createImageData(width, height);\n  const data = imageData.data;\n  \n  for (let y = 0; y < gridH; y++) {\n    for (let x = 0; x < gridW; x++) {\n      const val = current[idx(x, y)];\n      const absVal = Math.abs(val);\n      \n      if (absVal > 0.1) {\n        // Map value to colors\n        // Positive = cyan, negative = pink, intensity = brightness\n        const intensity = Math.min(1, absVal / 30);\n        \n        let r, g, b;\n        if (val > 0) {\n          // Cyan to white\n          r = Math.floor(50 + intensity * 200);\n          g = Math.floor(200 + intensity * 55);\n          b = Math.floor(220 + intensity * 35);\n        } else {\n          // Pink/magenta to white\n          r = Math.floor(220 + intensity * 35);\n          g = Math.floor(50 + intensity * 150);\n          b = Math.floor(180 + intensity * 75);\n        }\n        \n        // Draw the cell\n        for (let py = 0; py < cellSize; py++) {\n          for (let px = 0; px < cellSize; px++) {\n            const screenX = x * cellSize + px;\n            const screenY = y * cellSize + py;\n            if (screenX >= width || screenY >= height) continue;\n            \n            const pi = (screenY * width + screenX) * 4;\n            const edgeFade = (px === 0 || py === 0) ? 0.7 : 1;\n            data[pi] = r * edgeFade;\n            data[pi + 1] = g * edgeFade;\n            data[pi + 2] = b * edgeFade;\n            data[pi + 3] = Math.floor(intensity * 255 * edgeFade);\n          }\n        }\n      }\n    }\n  }\n  \n  ctx.putImageData(imageData, 0, 0);\n  \n  // Add glow layer\n  ctx.globalCompositeOperation = 'screen';\n  ctx.filter = 'blur(8px)';\n  ctx.globalAlpha = 0.3;\n  ctx.drawImage(canvas, 0, 0);\n  ctx.filter = 'none';\n  ctx.globalAlpha = 1;\n  ctx.globalCompositeOperation = 'source-over';\n}\n\n// Auto-strike for ambient animation\nlet autoStrikeTimer = 0;\nfunction autoStrike() {\n  autoStrikeTimer++;\n  if (autoStrikeTimer > 120) { // Every ~2 seconds\n    const x = Math.random() * width;\n    const y = Math.random() * height;\n    const radius = 8 + Math.random() * 12;\n    const force = 20 + Math.random() * 30;\n    strike(x, y, radius, force);\n    autoStrikeTimer = Math.random() * 60; // Randomize next\n  }\n}\n\nfunction animate() {\n  simulate();\n  autoStrike();\n  render();\n  requestAnimationFrame(animate);\n}\n\n// Mouse interaction\nlet isPressed = false;\nlet lastStrike = 0;\n\ncanvas.addEventListener('mousedown', (e) => {\n  initAudio();\n  isPressed = true;\n  hint.style.opacity = '0';\n  strike(e.clientX, e.clientY, 15 + Math.random() * 10, 50);\n  lastStrike = Date.now();\n});\n\ncanvas.addEventListener('mousemove', (e) => {\n  if (isPressed && Date.now() - lastStrike > 50) {\n    strike(e.clientX, e.clientY, 8, 25);\n    lastStrike = Date.now();\n  }\n});\n\ncanvas.addEventListener('mouseup', () => isPressed = false);\ncanvas.addEventListener('mouseleave', () => isPressed = false);\n\n// Touch support\ncanvas.addEventListener('touchstart', (e) => {\n  e.preventDefault();\n  initAudio();\n  hint.style.opacity = '0';\n  const touch = e.touches[0];\n  strike(touch.clientX, touch.clientY, 15, 50);\n});\n\ncanvas.addEventListener('touchmove', (e) => {\n  e.preventDefault();\n  const touch = e.touches[0];\n  strike(touch.clientX, touch.clientY, 8, 25);\n});\n\nwindow.addEventListener('resize', resize);\nresize();\n\n// Initial ambient strikes\nsetTimeout(() => strike(width * 0.3, height * 0.4, 12, 35), 500);\nsetTimeout(() => strike(width * 0.7, height * 0.6, 10, 30), 1200);\nsetTimeout(() => strike(width * 0.5, height * 0.3, 14, 40), 2000);\n\nanimate();\n</script>\n</body>\n</html>\n"
