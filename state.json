  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>fracture</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { \n      background: #0a0a0f; \n      overflow: hidden; \n      cursor: crosshair;\n    }\n    canvas { display: block; }\n    #hint {\n      position: fixed;\n      bottom: 20px;\n      left: 50%;\n      transform: translateX(-50%);\n      color: rgba(255, 0, 127, 0.4);\n      font-family: 'Courier New', monospace;\n      font-size: 12px;\n      letter-spacing: 2px;\n      pointer-events: none;\n      transition: opacity 2s;\n    }\n  </style>\n</head>\n<body>\n  <canvas id=\"canvas\"></canvas>\n  <div id=\"hint\">click to fracture</div>\n  <script>\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n    const hint = document.getElementById('hint');\n    \n    let W, H;\n    const cracks = [];\n    const maxDepth = 7;\n    let clickCount = 0;\n    \n    // Colors from palette\n    const colors = {\n      cyan: '#00ffff',\n      pink: '#ff0080',\n      purple: '#8b00ff',\n      white: '#ffffff'\n    };\n    \n    function resize() {\n      W = canvas.width = window.innerWidth;\n      H = canvas.height = window.innerHeight;\n      redraw();\n    }\n    \n    class Crack {\n      constructor(x, y, angle, depth, parent) {\n        this.x = x;\n        this.y = y;\n        this.angle = angle;\n        this.depth = depth;\n        this.parent = parent;\n        this.length = 0;\n        this.maxLength = (80 + Math.random() * 120) * Math.pow(0.7, depth);\n        this.speed = (3 + Math.random() * 4) * Math.pow(0.85, depth);\n        this.branched = false;\n        this.done = false;\n        this.segments = [{x, y}];\n        this.branchChance = 0.02 + depth * 0.005;\n        this.wobble = (Math.random() - 0.5) * 0.3;\n        \n        // Color based on depth\n        const t = depth / maxDepth;\n        if (t < 0.3) {\n          this.color = colors.cyan;\n          this.glow = colors.cyan;\n        } else if (t < 0.6) {\n          this.color = colors.pink;\n          this.glow = colors.pink;\n        } else {\n          this.color = colors.purple;\n          this.glow = colors.purple;\n        }\n        this.alpha = 1 - (depth * 0.1);\n      }\n      \n      update() {\n        if (this.done) return;\n        \n        // Grow\n        const prevX = this.segments[this.segments.length - 1].x;\n        const prevY = this.segments[this.segments.length - 1].y;\n        \n        // Slight angle wobble\n        this.angle += (Math.random() - 0.5) * 0.15 + this.wobble * 0.02;\n        \n        const newX = prevX + Math.cos(this.angle) * this.speed;\n        const newY = prevY + Math.sin(this.angle) * this.speed;\n        \n        this.segments.push({x: newX, y: newY});\n        this.length += this.speed;\n        \n        // Branch chance increases as we grow\n        if (!this.branched && this.depth < maxDepth && this.length > 20) {\n          if (Math.random() < this.branchChance) {\n            this.branch();\n          }\n        }\n        \n        // Done conditions\n        if (this.length >= this.maxLength || \n            newX < -50 || newX > W + 50 || \n            newY < -50 || newY > H + 50) {\n          this.done = true;\n        }\n      }\n      \n      branch() {\n        this.branched = true;\n        const lastSeg = this.segments[this.segments.length - 1];\n        \n        // Create 1-2 branches\n        const numBranches = Math.random() < 0.4 ? 2 : 1;\n        \n        for (let i = 0; i < numBranches; i++) {\n          const branchAngle = this.angle + (Math.random() - 0.5) * Math.PI * 0.8;\n          cracks.push(new Crack(\n            lastSeg.x, \n            lastSeg.y, \n            branchAngle, \n            this.depth + 1,\n            this\n          ));\n        }\n        \n        // Maybe branch again later\n        if (Math.random() < 0.3) {\n          this.branched = false;\n        }\n      }\n      \n      draw() {\n        if (this.segments.length < 2) return;\n        \n        const lineWidth = Math.max(0.5, 3 - this.depth * 0.4);\n        \n        // Glow layer\n        ctx.save();\n        ctx.strokeStyle = this.glow;\n        ctx.lineWidth = lineWidth + 4;\n        ctx.globalAlpha = this.alpha * 0.15;\n        ctx.lineCap = 'round';\n        ctx.lineJoin = 'round';\n        ctx.shadowColor = this.glow;\n        ctx.shadowBlur = 15;\n        \n        ctx.beginPath();\n        ctx.moveTo(this.segments[0].x, this.segments[0].y);\n        for (let i = 1; i < this.segments.length; i++) {\n          ctx.lineTo(this.segments[i].x, this.segments[i].y);\n        }\n        ctx.stroke();\n        ctx.restore();\n        \n        // Main line\n        ctx.save();\n        ctx.strokeStyle = this.color;\n        ctx.lineWidth = lineWidth;\n        ctx.globalAlpha = this.alpha * 0.9;\n        ctx.lineCap = 'round';\n        ctx.lineJoin = 'round';\n        \n        ctx.beginPath();\n        ctx.moveTo(this.segments[0].x, this.segments[0].y);\n        for (let i = 1; i < this.segments.length; i++) {\n          ctx.lineTo(this.segments[i].x, this.segments[i].y);\n        }\n        ctx.stroke();\n        ctx.restore();\n        \n        // Bright core for fresh segments\n        if (!this.done && this.segments.length > 1) {\n          const tip = this.segments[this.segments.length - 1];\n          ctx.save();\n          ctx.fillStyle = '#ffffff';\n          ctx.globalAlpha = 0.8;\n          ctx.shadowColor = this.color;\n          ctx.shadowBlur = 10;\n          ctx.beginPath();\n          ctx.arc(tip.x, tip.y, lineWidth * 0.8, 0, Math.PI * 2);\n          ctx.fill();\n          ctx.restore();\n        }\n      }\n    }\n    \n    function spawnFracture(x, y) {\n      // Spawn 3-5 initial cracks from impact point\n      const numCracks = 3 + Math.floor(Math.random() * 3);\n      const baseAngle = Math.random() * Math.PI * 2;\n      \n      for (let i = 0; i < numCracks; i++) {\n        const angle = baseAngle + (i / numCracks) * Math.PI * 2 + (Math.random() - 0.5) * 0.5;\n        cracks.push(new Crack(x, y, angle, 0, null));\n      }\n      \n      // Impact flash\n      ctx.save();\n      ctx.fillStyle = colors.cyan;\n      ctx.globalAlpha = 0.6;\n      ctx.shadowColor = colors.cyan;\n      ctx.shadowBlur = 30;\n      ctx.beginPath();\n      ctx.arc(x, y, 8, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.restore();\n      \n      clickCount++;\n      if (clickCount === 1) {\n        hint.style.opacity = '0';\n      }\n    }\n    \n    function redraw() {\n      // Clear with slight trail\n      ctx.fillStyle = 'rgba(10, 10, 15, 1)';\n      ctx.fillRect(0, 0, W, H);\n      \n      // Draw all cracks\n      for (const crack of cracks) {\n        crack.draw();\n      }\n    }\n    \n    function animate() {\n      // Very subtle fade for the growing tips\n      ctx.fillStyle = 'rgba(10, 10, 15, 0.03)';\n      ctx.fillRect(0, 0, W, H);\n      \n      // Redraw all (cracks are permanent)\n      for (const crack of cracks) {\n        crack.draw();\n      }\n      \n      // Update growing cracks\n      let anyActive = false;\n      for (const crack of cracks) {\n        if (!crack.done) {\n          crack.update();\n          anyActive = true;\n        }\n      }\n      \n      requestAnimationFrame(animate);\n    }\n    \n    // Auto-spawn initial fractures for visual interest\n    function autoSpawn() {\n      if (cracks.length === 0) {\n        // First auto-spawn after 3 seconds if no clicks\n        setTimeout(() => {\n          if (clickCount === 0) {\n            spawnFracture(W * 0.3 + Math.random() * W * 0.4, H * 0.3 + Math.random() * H * 0.4);\n          }\n        }, 3000);\n      }\n    }\n    \n    // Events\n    window.addEventListener('resize', resize);\n    \n    canvas.addEventListener('click', (e) => {\n      spawnFracture(e.clientX, e.clientY);\n    });\n    \n    canvas.addEventListener('touchstart', (e) => {\n      e.preventDefault();\n      const touch = e.touches[0];\n      spawnFracture(touch.clientX, touch.clientY);\n    }, { passive: false });\n    \n    // Keyboard: spacebar to clear and restart\n    window.addEventListener('keydown', (e) => {\n      if (e.code === 'Space') {\n        cracks.length = 0;\n        redraw();\n      }\n    });\n    \n    // Init\n    resize();\n    autoSpawn();\n    animate();\n  </script>\n</body>\n</html>\n"
}
