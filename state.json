  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>supernova</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { background: #000; overflow: hidden; cursor: crosshair; }\n    canvas { display: block; }\n    #hint {\n      position: fixed;\n      bottom: 20px;\n      left: 50%;\n      transform: translateX(-50%);\n      color: rgba(255,100,180,0.4);\n      font-family: monospace;\n      font-size: 12px;\n      pointer-events: none;\n      transition: opacity 2s;\n    }\n  </style>\n</head>\n<body>\n  <canvas id=\"c\"></canvas>\n  <div id=\"hint\">click to collapse</div>\n  <script>\nconst canvas = document.getElementById('c');\nconst ctx = canvas.getContext('2d');\nlet W, H, cx, cy;\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n  cx = W / 2;\n  cy = H / 2;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// Audio context\nlet audioCtx = null;\nfunction initAudio() {\n  if (audioCtx) return;\n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n}\n\nfunction playRumble(duration, intensity) {\n  if (!audioCtx) return;\n  const bufferSize = audioCtx.sampleRate * duration;\n  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);\n  const data = buffer.getChannelData(0);\n  for (let i = 0; i < bufferSize; i++) {\n    const t = i / bufferSize;\n    const env = Math.sin(t * Math.PI) * intensity;\n    data[i] = (Math.random() * 2 - 1) * env * 0.3;\n  }\n  const source = audioCtx.createBufferSource();\n  source.buffer = buffer;\n  const filter = audioCtx.createBiquadFilter();\n  filter.type = 'lowpass';\n  filter.frequency.value = 150;\n  const gain = audioCtx.createGain();\n  gain.gain.value = 0.5;\n  source.connect(filter);\n  filter.connect(gain);\n  gain.connect(audioCtx.destination);\n  source.start();\n}\n\nfunction playBoom() {\n  if (!audioCtx) return;\n  const osc = audioCtx.createOscillator();\n  const gain = audioCtx.createGain();\n  osc.type = 'sine';\n  osc.frequency.setValueAtTime(80, audioCtx.currentTime);\n  osc.frequency.exponentialRampToValueAtTime(20, audioCtx.currentTime + 1.5);\n  gain.gain.setValueAtTime(0.6, audioCtx.currentTime);\n  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 2);\n  osc.connect(gain);\n  gain.connect(audioCtx.destination);\n  osc.start();\n  osc.stop(audioCtx.currentTime + 2);\n  \n  // noise burst\n  const bufferSize = audioCtx.sampleRate * 0.5;\n  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);\n  const data = buffer.getChannelData(0);\n  for (let i = 0; i < bufferSize; i++) {\n    const t = i / bufferSize;\n    data[i] = (Math.random() * 2 - 1) * Math.exp(-t * 8) * 0.4;\n  }\n  const noise = audioCtx.createBufferSource();\n  noise.buffer = buffer;\n  const noiseGain = audioCtx.createGain();\n  noiseGain.gain.value = 0.7;\n  noise.connect(noiseGain);\n  noiseGain.connect(audioCtx.destination);\n  noise.start();\n}\n\n// Star state\nconst STATES = { STABLE: 0, UNSTABLE: 1, COLLAPSE: 2, EXPLODE: 3, DEBRIS: 4, REFORM: 5 };\nlet state = STATES.STABLE;\nlet stateTime = 0;\nlet starRadius = 60;\nlet pulsePhase = 0;\nlet instability = 0;\nlet mouseX = cx, mouseY = cy;\n\n// Debris particles\nlet debris = [];\nlet shockwave = { radius: 0, active: false, alpha: 0 };\nlet protoStars = [];\n\nclass Debris {\n  constructor(x, y, vx, vy, size, hue) {\n    this.x = x;\n    this.y = y;\n    this.vx = vx;\n    this.vy = vy;\n    this.size = size;\n    this.hue = hue;\n    this.life = 1;\n    this.decay = 0.002 + Math.random() * 0.003;\n    this.rotation = Math.random() * Math.PI * 2;\n    this.rotSpeed = (Math.random() - 0.5) * 0.1;\n  }\n  \n  update() {\n    this.x += this.vx;\n    this.y += this.vy;\n    this.vx *= 0.995;\n    this.vy *= 0.995;\n    this.rotation += this.rotSpeed;\n    this.life -= this.decay;\n  }\n  \n  draw() {\n    ctx.save();\n    ctx.translate(this.x, this.y);\n    ctx.rotate(this.rotation);\n    ctx.fillStyle = `hsla(${this.hue}, 100%, 70%, ${this.life * 0.8})`;\n    ctx.shadowColor = `hsla(${this.hue}, 100%, 60%, ${this.life})`;\n    ctx.shadowBlur = this.size * 2;\n    ctx.fillRect(-this.size/2, -this.size/2, this.size, this.size);\n    ctx.restore();\n  }\n}\n\nclass ProtoStar {\n  constructor(x, y) {\n    this.x = x;\n    this.y = y;\n    this.radius = 0;\n    this.targetRadius = 5 + Math.random() * 15;\n    this.hue = 280 + Math.random() * 60; // purple to pink\n    this.pulse = Math.random() * Math.PI * 2;\n    this.life = 1;\n  }\n  \n  update() {\n    this.radius += (this.targetRadius - this.radius) * 0.02;\n    this.pulse += 0.05;\n  }\n  \n  draw() {\n    const r = this.radius + Math.sin(this.pulse) * this.radius * 0.1;\n    const gradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, r * 2);\n    gradient.addColorStop(0, `hsla(${this.hue}, 100%, 90%, 0.9)`);\n    gradient.addColorStop(0.3, `hsla(${this.hue}, 100%, 70%, 0.6)`);\n    gradient.addColorStop(0.7, `hsla(${this.hue + 30}, 100%, 50%, 0.2)`);\n    gradient.addColorStop(1, 'transparent');\n    ctx.fillStyle = gradient;\n    ctx.beginPath();\n    ctx.arc(this.x, this.y, r * 2, 0, Math.PI * 2);\n    ctx.fill();\n  }\n}\n\n// Background stars\nconst bgStars = [];\nfor (let i = 0; i < 200; i++) {\n  bgStars.push({\n    x: Math.random() * 2000 - 500,\n    y: Math.random() * 2000 - 500,\n    size: Math.random() * 1.5 + 0.5,\n    twinkle: Math.random() * Math.PI * 2\n  });\n}\n\nfunction drawBackground() {\n  ctx.fillStyle = '#000';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Stars\n  for (const star of bgStars) {\n    star.twinkle += 0.02;\n    const alpha = 0.3 + Math.sin(star.twinkle) * 0.2;\n    ctx.fillStyle = `rgba(200, 180, 255, ${alpha})`;\n    ctx.beginPath();\n    ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);\n    ctx.fill();\n  }\n}\n\nfunction drawStar() {\n  const pulseAmount = state === STATES.UNSTABLE ? instability * 20 : 5;\n  const currentRadius = starRadius + Math.sin(pulsePhase) * pulseAmount;\n  \n  // Core glow layers\n  const layers = [\n    { radius: currentRadius * 3, color: 'rgba(255, 50, 150, 0.05)' },\n    { radius: currentRadius * 2, color: 'rgba(255, 100, 200, 0.1)' },\n    { radius: currentRadius * 1.5, color: 'rgba(255, 150, 220, 0.2)' },\n    { radius: currentRadius, color: 'rgba(255, 200, 240, 0.5)' },\n    { radius: currentRadius * 0.7, color: 'rgba(255, 255, 255, 0.8)' },\n  ];\n  \n  // Instability color shift\n  const hueShift = state === STATES.UNSTABLE ? Math.sin(pulsePhase * 3) * 30 : 0;\n  \n  for (const layer of layers) {\n    const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, layer.radius);\n    gradient.addColorStop(0, layer.color);\n    gradient.addColorStop(1, 'transparent');\n    ctx.fillStyle = gradient;\n    ctx.beginPath();\n    ctx.arc(cx, cy, layer.radius, 0, Math.PI * 2);\n    ctx.fill();\n  }\n  \n  // Corona flares\n  if (state <= STATES.UNSTABLE) {\n    ctx.save();\n    ctx.translate(cx, cy);\n    const flareCount = 8;\n    for (let i = 0; i < flareCount; i++) {\n      const angle = (i / flareCount) * Math.PI * 2 + pulsePhase * 0.2;\n      const length = currentRadius * (1.5 + Math.sin(pulsePhase + i) * 0.5 * (1 + instability));\n      \n      ctx.save();\n      ctx.rotate(angle);\n      const gradient = ctx.createLinearGradient(0, 0, length, 0);\n      gradient.addColorStop(0, `hsla(${320 + hueShift}, 100%, 80%, 0.6)`);\n      gradient.addColorStop(1, 'transparent');\n      ctx.fillStyle = gradient;\n      ctx.beginPath();\n      ctx.moveTo(currentRadius * 0.8, 0);\n      ctx.lineTo(length, -3 - instability * 5);\n      ctx.lineTo(length, 3 + instability * 5);\n      ctx.closePath();\n      ctx.fill();\n      ctx.restore();\n    }\n    ctx.restore();\n  }\n}\n\nfunction drawCollapse() {\n  const progress = Math.min(stateTime / 60, 1);\n  const collapseRadius = starRadius * (1 - progress * 0.9);\n  \n  // Imploding glow\n  const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, collapseRadius * 2);\n  gradient.addColorStop(0, `rgba(255, 255, 255, ${0.9 + progress * 0.1})`);\n  gradient.addColorStop(0.5, `rgba(200, 100, 255, ${0.5 - progress * 0.3})`);\n  gradient.addColorStop(1, 'transparent');\n  ctx.fillStyle = gradient;\n  ctx.beginPath();\n  ctx.arc(cx, cy, collapseRadius * 2, 0, Math.PI * 2);\n  ctx.fill();\n  \n  // Inward streaks\n  for (let i = 0; i < 20; i++) {\n    const angle = (i / 20) * Math.PI * 2 + stateTime * 0.1;\n    const innerR = collapseRadius;\n    const outerR = starRadius * 2 * (1 - progress * 0.5);\n    \n    ctx.save();\n    ctx.translate(cx, cy);\n    ctx.rotate(angle);\n    ctx.strokeStyle = `rgba(0, 255, 255, ${0.3 * (1 - progress)})`;\n    ctx.lineWidth = 2;\n    ctx.beginPath();\n    ctx.moveTo(innerR, 0);\n    ctx.lineTo(outerR, 0);\n    ctx.stroke();\n    ctx.restore();\n  }\n  \n  if (progress >= 1) {\n    state = STATES.EXPLODE;\n    stateTime = 0;\n    triggerExplosion();\n  }\n}\n\nfunction triggerExplosion() {\n  playBoom();\n  shockwave = { radius: 0, active: true, alpha: 1 };\n  \n  // Create debris\n  const debrisCount = 150;\n  for (let i = 0; i < debrisCount; i++) {\n    const angle = Math.random() * Math.PI * 2;\n    const speed = 3 + Math.random() * 8;\n    const hue = Math.random() < 0.5 ? 320 + Math.random() * 40 : 180 + Math.random() * 30;\n    debris.push(new Debris(\n      cx, cy,\n      Math.cos(angle) * speed,\n      Math.sin(angle) * speed,\n      3 + Math.random() * 8,\n      hue\n    ));\n  }\n}\n\nfunction drawExplosion() {\n  const progress = Math.min(stateTime / 30, 1);\n  \n  // Central flash\n  if (progress < 0.3) {\n    const flashAlpha = 1 - progress / 0.3;\n    const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, 200 * progress * 3);\n    gradient.addColorStop(0, `rgba(255, 255, 255, ${flashAlpha})`);\n    gradient.addColorStop(0.5, `rgba(255, 200, 255, ${flashAlpha * 0.5})`);\n    gradient.addColorStop(1, 'transparent');\n    ctx.fillStyle = gradient;\n    ctx.beginPath();\n    ctx.arc(cx, cy, 200 * progress * 3, 0, Math.PI * 2);\n    ctx.fill();\n  }\n  \n  if (progress >= 1) {\n    state = STATES.DEBRIS;\n    stateTime = 0;\n  }\n}\n\nfunction drawShockwave() {\n  if (!shockwave.active) return;\n  \n  shockwave.radius += 8;\n  shockwave.alpha *= 0.985;\n  \n  if (shockwave.alpha < 0.01) {\n    shockwave.active = false;\n    return;\n  }\n  \n  // Double ring\n  ctx.strokeStyle = `rgba(0, 255, 255, ${shockwave.alpha})`;\n  ctx.lineWidth = 3;\n  ctx.beginPath();\n  ctx.arc(cx, cy, shockwave.radius, 0, Math.PI * 2);\n  ctx.stroke();\n  \n  ctx.strokeStyle = `rgba(255, 100, 200, ${shockwave.alpha * 0.7})`;\n  ctx.lineWidth = 2;\n  ctx.beginPath();\n  ctx.arc(cx, cy, shockwave.radius - 15, 0, Math.PI * 2);\n  ctx.stroke();\n  \n  // Spawn proto-stars at shockwave edge occasionally\n  if (state === STATES.DEBRIS && Math.random() < 0.03 && protoStars.length < 12) {\n    const angle = Math.random() * Math.PI * 2;\n    const dist = shockwave.radius + (Math.random() - 0.5) * 50;\n    protoStars.push(new ProtoStar(\n      cx + Math.cos(angle) * dist,\n      cy + Math.sin(angle) * dist\n    ));\n  }\n}\n\nfunction drawDebris() {\n  debris = debris.filter(d => d.life > 0);\n  for (const d of debris) {\n    d.update();\n    d.draw();\n  }\n  \n  // After debris fades, reform\n  if (stateTime > 300 && debris.length < 20) {\n    state = STATES.REFORM;\n    stateTime = 0;\n  }\n}\n\nfunction drawProtoStars() {\n  for (const ps of protoStars) {\n    ps.update();\n    ps.draw();\n  }\n}\n\nfunction drawReform() {\n  const progress = Math.min(stateTime / 180, 1);\n  \n  // New star forming at center\n  const newRadius = starRadius * progress * 0.7;\n  const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, newRadius * 2);\n  gradient.addColorStop(0, `rgba(200, 150, 255, ${progress * 0.8})`);\n  gradient.addColorStop(0.5, `rgba(150, 100, 200, ${progress * 0.4})`);\n  gradient.addColorStop(1, 'transparent');\n  ctx.fillStyle = gradient;\n  ctx.beginPath();\n  ctx.arc(cx, cy, newRadius * 2, 0, Math.PI * 2);\n  ctx.fill();\n  \n  if (progress >= 1) {\n    state = STATES.STABLE;\n    stateTime = 0;\n    instability = 0;\n    protoStars = [];\n    document.getElementById('hint').style.opacity = '1';\n  }\n}\n\nfunction update() {\n  stateTime++;\n  pulsePhase += 0.05;\n  \n  // Mouse proximity affects instability when stable\n  if (state === STATES.STABLE) {\n    const dx = mouseX - cx;\n    const dy = mouseY - cy;\n    const dist = Math.sqrt(dx * dx + dy * dy);\n    const maxDist = Math.min(W, H) / 2;\n    const targetInstability = Math.max(0, 1 - dist / maxDist) * 0.5;\n    instability += (targetInstability - instability) * 0.02;\n    \n    if (instability > 0.3) {\n      state = STATES.UNSTABLE;\n      playRumble(2, instability);\n    }\n  }\n  \n  // Unstable star grows more chaotic\n  if (state === STATES.UNSTABLE) {\n    const dx = mouseX - cx;\n    const dy = mouseY - cy;\n    const dist = Math.sqrt(dx * dx + dy * dy);\n    const maxDist = Math.min(W, H) / 2;\n    instability += (1 - dist / maxDist) * 0.01;\n    instability = Math.min(instability, 1.5);\n    \n    if (dist > maxDist * 0.8) {\n      instability -= 0.01;\n      if (instability < 0.1) {\n        state = STATES.STABLE;\n        instability = 0;\n      }\n    }\n  }\n}\n\nfunction draw() {\n  drawBackground();\n  \n  switch (state) {\n    case STATES.STABLE:\n    case STATES.UNSTABLE:\n      drawStar();\n      break;\n    case STATES.COLLAPSE:\n      drawCollapse();\n      break;\n    case STATES.EXPLODE:\n      drawExplosion();\n      drawShockwave();\n      drawDebris();\n      break;\n    case STATES.DEBRIS:\n      drawShockwave();\n      drawDebris();\n      drawProtoStars();\n      break;\n    case STATES.REFORM:\n      drawProtoStars();\n      drawReform();\n      break;\n  }\n}\n\nfunction loop() {\n  update();\n  draw();\n  requestAnimationFrame(loop);\n}\n\ncanvas.addEventListener('mousemove', (e) => {\n  mouseX = e.clientX;\n  mouseY = e.clientY;\n});\n\ncanvas.addEventListener('click', () => {\n  initAudio();\n  if (state === STATES.STABLE || state === STATES.UNSTABLE) {\n    state = STATES.COLLAPSE;\n    stateTime = 0;\n    document.getElementById('hint').style.opacity = '0';\n    playRumble(1, 1);\n  }\n});\n\n// Hide hint after a while\nsetTimeout(() => {\n  if (state === STATES.STABLE) {\n    document.getElementById('hint').style.opacity = '0.2';\n  }\n}, 5000);\n\nloop();\n  </script>\n</body>\n</html>\n"
