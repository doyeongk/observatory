  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>automaton</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #0a0a0f; \n  overflow: hidden; \n  font-family: monospace;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: #00ffff;\n  font-size: 14px;\n  opacity: 0.7;\n  text-shadow: 0 0 10px #00ffff;\n  pointer-events: none;\n  z-index: 10;\n}\n#rule-display {\n  position: fixed;\n  top: 20px;\n  right: 20px;\n  color: #ff66b2;\n  font-size: 24px;\n  font-weight: bold;\n  text-shadow: 0 0 20px #ff66b2;\n  pointer-events: none;\n  z-index: 10;\n}\n</style>\n</head>\n<body>\n<canvas id=\"canvas\"></canvas>\n<div id=\"info\">click: mutate · space: new rule · ←→: browse rules</div>\n<div id=\"rule-display\">RULE <span id=\"rule-num\">110</span></div>\n\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nconst ruleNumEl = document.getElementById('rule-num');\n\nlet W, H, cellSize, cols, rows;\nlet currentRule = 110;\nlet ruleSet = [];\nlet grid = [];\nlet generation = 0;\nlet scrollOffset = 0;\nlet mouseX = 0, mouseY = 0;\nlet audioCtx = null;\nlet lastSoundTime = 0;\n\n// Interesting rules to cycle through\nconst interestingRules = [30, 45, 54, 60, 73, 90, 105, 110, 150, 182, 225];\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n  cellSize = Math.max(2, Math.floor(Math.min(W, H) / 200));\n  cols = Math.floor(W / cellSize);\n  rows = Math.floor(H / cellSize) + 50; // buffer for scrolling\n  initGrid();\n}\n\nfunction initGrid() {\n  grid = [];\n  for (let y = 0; y < rows; y++) {\n    grid[y] = new Array(cols).fill(0);\n  }\n  // Start with single cell in center\n  grid[0][Math.floor(cols / 2)] = 1;\n  // Add some random seeds for visual interest\n  for (let i = 0; i < 5; i++) {\n    grid[0][Math.floor(Math.random() * cols)] = 1;\n  }\n  generation = 0;\n  scrollOffset = 0;\n  computeRuleSet(currentRule);\n}\n\nfunction computeRuleSet(ruleNumber) {\n  ruleSet = [];\n  for (let i = 0; i < 8; i++) {\n    ruleSet[i] = (ruleNumber >> i) & 1;\n  }\n  ruleNumEl.textContent = ruleNumber;\n}\n\nfunction applyRule(left, center, right) {\n  const index = (left << 2) | (center << 1) | right;\n  return ruleSet[index];\n}\n\nfunction nextGeneration() {\n  if (generation >= rows - 1) {\n    // Scroll everything up\n    for (let y = 0; y < rows - 1; y++) {\n      grid[y] = grid[y + 1].slice();\n    }\n    grid[rows - 1] = new Array(cols).fill(0);\n    scrollOffset++;\n  } else {\n    generation++;\n  }\n  \n  const y = Math.min(generation, rows - 1);\n  const prevY = y - 1;\n  \n  if (prevY >= 0) {\n    for (let x = 0; x < cols; x++) {\n      const left = grid[prevY][(x - 1 + cols) % cols];\n      const center = grid[prevY][x];\n      const right = grid[prevY][(x + 1) % cols];\n      grid[y][x] = applyRule(left, center, right);\n    }\n  }\n  \n  // Count alive cells for sound\n  let alive = 0;\n  for (let x = 0; x < cols; x++) {\n    if (grid[y][x]) alive++;\n  }\n  \n  // Occasional click sounds based on pattern density\n  if (audioCtx && Date.now() - lastSoundTime > 50) {\n    const density = alive / cols;\n    if (Math.random() < density * 0.3) {\n      playTick(density);\n      lastSoundTime = Date.now();\n    }\n  }\n}\n\nfunction playTick(density) {\n  if (!audioCtx) return;\n  const osc = audioCtx.createOscillator();\n  const gain = audioCtx.createGain();\n  \n  osc.type = 'sine';\n  osc.frequency.value = 200 + density * 800 + Math.random() * 200;\n  \n  gain.gain.setValueAtTime(0.03, audioCtx.currentTime);\n  gain.gain.exponentialDecayTo?.(0.001, audioCtx.currentTime + 0.1) ||\n    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);\n  \n  osc.connect(gain);\n  gain.connect(audioCtx.destination);\n  \n  osc.start();\n  osc.stop(audioCtx.currentTime + 0.1);\n}\n\nfunction getColor(x, y, alive) {\n  if (!alive) return null;\n  \n  // Age-based coloring (newer = cyan, older = pink)\n  const age = (generation + scrollOffset) - (y + scrollOffset);\n  const normalizedAge = Math.min(age / 30, 1);\n  \n  // Distance from mouse affects brightness\n  const dx = (x * cellSize) - mouseX;\n  const dy = (y * cellSize) - mouseY;\n  const dist = Math.sqrt(dx * dx + dy * dy);\n  const mouseFactor = Math.max(0, 1 - dist / 300);\n  \n  const r = Math.floor(100 + normalizedAge * 155 + mouseFactor * 50);\n  const g = Math.floor(255 - normalizedAge * 155);\n  const b = Math.floor(255 - normalizedAge * 77 + mouseFactor * 50);\n  \n  return `rgb(${Math.min(255, r)}, ${Math.min(255, g)}, ${Math.min(255, b)})`;\n}\n\nfunction draw() {\n  // Slight fade for trail effect\n  ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Draw cells\n  for (let y = 0; y < Math.min(generation + 1, rows); y++) {\n    for (let x = 0; x < cols; x++) {\n      if (grid[y][x]) {\n        const color = getColor(x, y, true);\n        if (color) {\n          ctx.fillStyle = color;\n          \n          // Glow effect near mouse\n          const dx = (x * cellSize) - mouseX;\n          const dy = (y * cellSize) - mouseY;\n          const dist = Math.sqrt(dx * dx + dy * dy);\n          \n          if (dist < 100) {\n            ctx.shadowColor = '#00ffff';\n            ctx.shadowBlur = 10 * (1 - dist / 100);\n          } else {\n            ctx.shadowBlur = 0;\n          }\n          \n          ctx.fillRect(x * cellSize, y * cellSize, cellSize - 1, cellSize - 1);\n        }\n      }\n    }\n  }\n  ctx.shadowBlur = 0;\n  \n  // Draw rule visualization at top\n  drawRuleViz();\n}\n\nfunction drawRuleViz() {\n  const vizSize = 20;\n  const startX = 20;\n  const startY = 20;\n  \n  ctx.globalAlpha = 0.5;\n  for (let i = 7; i >= 0; i--) {\n    const pattern = i;\n    const result = ruleSet[i];\n    const x = startX + (7 - i) * (vizSize * 4 + 10);\n    \n    // Draw input pattern\n    for (let j = 2; j >= 0; j--) {\n      const bit = (pattern >> j) & 1;\n      ctx.fillStyle = bit ? '#ff66b2' : '#1a1a2e';\n      ctx.fillRect(x + (2 - j) * vizSize, startY, vizSize - 2, vizSize - 2);\n    }\n    \n    // Draw output\n    ctx.fillStyle = result ? '#00ffff' : '#1a1a2e';\n    ctx.fillRect(x + vizSize, startY + vizSize + 5, vizSize - 2, vizSize - 2);\n  }\n  ctx.globalAlpha = 1;\n}\n\nfunction mutate(x, y) {\n  const gridX = Math.floor(x / cellSize);\n  const gridY = Math.floor(y / cellSize);\n  \n  // Flip cells in a small radius\n  for (let dy = -2; dy <= 2; dy++) {\n    for (let dx = -2; dx <= 2; dx++) {\n      const gx = (gridX + dx + cols) % cols;\n      const gy = gridY + dy;\n      if (gy >= 0 && gy < rows && Math.random() < 0.5) {\n        grid[gy][gx] = grid[gy][gx] ? 0 : 1;\n      }\n    }\n  }\n  \n  // Play mutation sound\n  if (audioCtx) {\n    const osc = audioCtx.createOscillator();\n    const gain = audioCtx.createGain();\n    osc.type = 'square';\n    osc.frequency.value = 150;\n    gain.gain.setValueAtTime(0.05, audioCtx.currentTime);\n    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.2);\n    osc.connect(gain);\n    gain.connect(audioCtx.destination);\n    osc.start();\n    osc.stop(audioCtx.currentTime + 0.2);\n  }\n}\n\nfunction changeRule(delta) {\n  const currentIndex = interestingRules.indexOf(currentRule);\n  let newIndex;\n  \n  if (currentIndex === -1) {\n    newIndex = 0;\n  } else {\n    newIndex = (currentIndex + delta + interestingRules.length) % interestingRules.length;\n  }\n  \n  currentRule = interestingRules[newIndex];\n  computeRuleSet(currentRule);\n  \n  // Don't reset - let the new rule propagate from current state\n  // This creates interesting transitions\n}\n\nfunction randomRule() {\n  currentRule = Math.floor(Math.random() * 256);\n  initGrid();\n  \n  // Dramatic sound for rule change\n  if (audioCtx) {\n    const osc = audioCtx.createOscillator();\n    const gain = audioCtx.createGain();\n    osc.type = 'sawtooth';\n    osc.frequency.setValueAtTime(400, audioCtx.currentTime);\n    osc.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 0.3);\n    gain.gain.setValueAtTime(0.08, audioCtx.currentTime);\n    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);\n    osc.connect(gain);\n    gain.connect(audioCtx.destination);\n    osc.start();\n    osc.stop(audioCtx.currentTime + 0.3);\n  }\n}\n\n// Event listeners\nwindow.addEventListener('resize', resize);\n\ncanvas.addEventListener('mousemove', (e) => {\n  mouseX = e.clientX;\n  mouseY = e.clientY;\n});\n\ncanvas.addEventListener('click', (e) => {\n  // Init audio on first click\n  if (!audioCtx) {\n    audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  }\n  mutate(e.clientX, e.clientY);\n});\n\nwindow.addEventListener('keydown', (e) => {\n  if (!audioCtx) {\n    audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n  }\n  \n  if (e.code === 'Space') {\n    e.preventDefault();\n    randomRule();\n  } else if (e.code === 'ArrowLeft') {\n    changeRule(-1);\n  } else if (e.code === 'ArrowRight') {\n    changeRule(1);\n  }\n});\n\n// Animation loop\nlet frameCount = 0;\nfunction animate() {\n  frameCount++;\n  \n  // Advance generation every few frames for readable speed\n  if (frameCount % 3 === 0) {\n    nextGeneration();\n  }\n  \n  draw();\n  requestAnimationFrame(animate);\n}\n\n// Start\nresize();\nanimate();\n</script>\n</body>\n</html>\n"
}
