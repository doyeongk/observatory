  "canvas": {
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>pulsar</title>\n<style>\n* { margin: 0; padding: 0; box-sizing: border-box; }\nbody { \n  background: #000; \n  overflow: hidden; \n  cursor: crosshair;\n}\ncanvas { display: block; }\n#info {\n  position: fixed;\n  bottom: 20px;\n  left: 20px;\n  color: rgba(0, 255, 255, 0.4);\n  font-family: 'Courier New', monospace;\n  font-size: 11px;\n  letter-spacing: 1px;\n  pointer-events: none;\n}\n</style>\n</head>\n<body>\n<canvas id=\"canvas\"></canvas>\n<div id=\"info\">PSR J0437−4715 · click to toggle wavelength</div>\n<script>\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\n\nlet W, H, cx, cy;\nlet audioCtx = null;\nlet lastPulseTime = 0;\n\n// Pulsar state\nlet rotation = 0;\nlet rotationSpeed = 2.5; // radians per second\nlet targetSpeed = 2.5;\nlet wavelengthMode = 0; // 0 = radio, 1 = x-ray\nlet mouseX = 0, mouseY = 0;\nlet beamAngle1 = 0;\nlet beamAngle2 = Math.PI;\n\n// Particles in the magnetosphere\nconst particles = [];\nconst PARTICLE_COUNT = 300;\n\n// Field line points\nconst fieldLines = [];\nconst FIELD_LINE_COUNT = 12;\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n  cx = W / 2;\n  cy = H / 2;\n}\n\nfunction initParticles() {\n  particles.length = 0;\n  for (let i = 0; i < PARTICLE_COUNT; i++) {\n    particles.push(createParticle());\n  }\n}\n\nfunction createParticle() {\n  const angle = Math.random() * Math.PI * 2;\n  const dist = 50 + Math.random() * 200;\n  return {\n    angle: angle,\n    dist: dist,\n    speed: 0.3 + Math.random() * 0.7,\n    size: 1 + Math.random() * 2,\n    brightness: 0.3 + Math.random() * 0.7,\n    zOffset: (Math.random() - 0.5) * 0.5\n  };\n}\n\nfunction initFieldLines() {\n  fieldLines.length = 0;\n  for (let i = 0; i < FIELD_LINE_COUNT; i++) {\n    const baseAngle = (i / FIELD_LINE_COUNT) * Math.PI * 2;\n    fieldLines.push({\n      baseAngle: baseAngle,\n      points: generateFieldLine(baseAngle)\n    });\n  }\n}\n\nfunction generateFieldLine(baseAngle) {\n  const points = [];\n  const steps = 40;\n  for (let i = 0; i <= steps; i++) {\n    const t = i / steps;\n    const r = 30 + Math.pow(t, 0.6) * 180;\n    const theta = baseAngle + t * 0.8 * Math.sin(baseAngle * 2);\n    points.push({ r, theta: theta - baseAngle, t });\n  }\n  return points;\n}\n\nfunction initAudio() {\n  if (audioCtx) return;\n  audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n}\n\nfunction playPulse() {\n  if (!audioCtx) return;\n  \n  const now = audioCtx.currentTime;\n  \n  // Create the characteristic pulsar click\n  const osc = audioCtx.createOscillator();\n  const gain = audioCtx.createGain();\n  const filter = audioCtx.createBiquadFilter();\n  \n  filter.type = 'bandpass';\n  filter.frequency.value = wavelengthMode === 0 ? 800 : 2000;\n  filter.Q.value = 5;\n  \n  osc.type = 'sawtooth';\n  osc.frequency.value = wavelengthMode === 0 ? 60 : 120;\n  \n  gain.gain.setValueAtTime(0.15, now);\n  gain.gain.exponentialDecayTo ? \n    gain.gain.exponentialDecayTo(0.001, now + 0.08) :\n    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.08);\n  \n  osc.connect(filter);\n  filter.connect(gain);\n  gain.connect(audioCtx.destination);\n  \n  osc.start(now);\n  osc.stop(now + 0.1);\n  \n  // Add noise burst\n  const bufferSize = audioCtx.sampleRate * 0.05;\n  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);\n  const data = buffer.getChannelData(0);\n  for (let i = 0; i < bufferSize; i++) {\n    data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (bufferSize * 0.2));\n  }\n  \n  const noise = audioCtx.createBufferSource();\n  const noiseGain = audioCtx.createGain();\n  const noiseFilter = audioCtx.createBiquadFilter();\n  \n  noiseFilter.type = 'highpass';\n  noiseFilter.frequency.value = 1000;\n  \n  noise.buffer = buffer;\n  noiseGain.gain.value = 0.08;\n  \n  noise.connect(noiseFilter);\n  noiseFilter.connect(noiseGain);\n  noiseGain.connect(audioCtx.destination);\n  noise.start(now);\n}\n\nfunction drawStar() {\n  // Neutron star core - tiny but incredibly bright\n  const coreRadius = 8;\n  \n  // Core glow\n  const gradient = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreRadius * 8);\n  gradient.addColorStop(0, wavelengthMode === 0 ? 'rgba(0, 255, 255, 1)' : 'rgba(255, 100, 255, 1)');\n  gradient.addColorStop(0.2, wavelengthMode === 0 ? 'rgba(0, 200, 255, 0.8)' : 'rgba(255, 50, 200, 0.8)');\n  gradient.addColorStop(0.5, wavelengthMode === 0 ? 'rgba(100, 0, 200, 0.3)' : 'rgba(200, 0, 100, 0.3)');\n  gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');\n  \n  ctx.fillStyle = gradient;\n  ctx.beginPath();\n  ctx.arc(cx, cy, coreRadius * 8, 0, Math.PI * 2);\n  ctx.fill();\n  \n  // Hard core\n  ctx.fillStyle = wavelengthMode === 0 ? '#00ffff' : '#ff66ff';\n  ctx.beginPath();\n  ctx.arc(cx, cy, coreRadius, 0, Math.PI * 2);\n  ctx.fill();\n  \n  // Surface hotspots (magnetic poles)\n  const hotspotOffset = coreRadius * 0.6;\n  ctx.fillStyle = '#ffffff';\n  ctx.beginPath();\n  ctx.arc(\n    cx + Math.cos(rotation) * hotspotOffset, \n    cy + Math.sin(rotation) * hotspotOffset * 0.3, \n    3, 0, Math.PI * 2\n  );\n  ctx.fill();\n  ctx.beginPath();\n  ctx.arc(\n    cx - Math.cos(rotation) * hotspotOffset, \n    cy - Math.sin(rotation) * hotspotOffset * 0.3, \n    3, 0, Math.PI * 2\n  );\n  ctx.fill();\n}\n\nfunction drawBeams() {\n  const beamLength = Math.max(W, H);\n  const beamWidth = 0.15; // radians\n  \n  for (let i = 0; i < 2; i++) {\n    const angle = rotation + (i * Math.PI);\n    \n    // Check if beam is \"facing\" us (create pulse effect)\n    const facingThreshold = 0.3;\n    const facing = Math.abs(Math.cos(angle)) > Math.cos(facingThreshold);\n    \n    if (facing && Date.now() - lastPulseTime > 100) {\n      lastPulseTime = Date.now();\n      playPulse();\n    }\n    \n    // Beam gradient\n    const gradient = ctx.createRadialGradient(cx, cy, 10, cx, cy, beamLength * 0.8);\n    const baseColor = wavelengthMode === 0 ? [0, 255, 255] : [255, 100, 255];\n    gradient.addColorStop(0, `rgba(${baseColor.join(',')}, 0.9)`);\n    gradient.addColorStop(0.3, `rgba(${baseColor.join(',')}, 0.4)`);\n    gradient.addColorStop(0.6, `rgba(${baseColor[0]}, ${Math.floor(baseColor[1]*0.5)}, ${baseColor[2]}, 0.15)`);\n    gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');\n    \n    ctx.save();\n    ctx.translate(cx, cy);\n    ctx.rotate(angle);\n    \n    // Draw cone beam\n    ctx.beginPath();\n    ctx.moveTo(0, 0);\n    ctx.lineTo(beamLength * Math.cos(beamWidth), beamLength * Math.sin(beamWidth));\n    ctx.lineTo(beamLength * Math.cos(-beamWidth), beamLength * Math.sin(-beamWidth));\n    ctx.closePath();\n    \n    ctx.fillStyle = gradient;\n    ctx.fill();\n    \n    // Beam edge glow\n    ctx.strokeStyle = `rgba(${baseColor.join(',')}, 0.3)`;\n    ctx.lineWidth = 2;\n    ctx.stroke();\n    \n    ctx.restore();\n  }\n}\n\nfunction drawFieldLines() {\n  ctx.lineWidth = 1.5;\n  \n  for (const line of fieldLines) {\n    ctx.beginPath();\n    \n    for (let i = 0; i < line.points.length; i++) {\n      const p = line.points[i];\n      const angle = line.baseAngle + rotation + p.theta;\n      const x = cx + Math.cos(angle) * p.r;\n      const y = cy + Math.sin(angle) * p.r * 0.4; // Flatten for perspective\n      \n      if (i === 0) {\n        ctx.moveTo(x, y);\n      } else {\n        ctx.lineTo(x, y);\n      }\n    }\n    \n    // Mirror the line\n    for (let i = line.points.length - 1; i >= 0; i--) {\n      const p = line.points[i];\n      const angle = line.baseAngle + rotation + Math.PI + p.theta;\n      const x = cx + Math.cos(angle) * p.r;\n      const y = cy + Math.sin(angle) * p.r * 0.4;\n      ctx.lineTo(x, y);\n    }\n    \n    const hue = wavelengthMode === 0 ? 180 : 300;\n    const alpha = 0.15 + Math.sin(line.baseAngle * 3 + rotation) * 0.1;\n    ctx.strokeStyle = `hsla(${hue}, 100%, 60%, ${alpha})`;\n    ctx.stroke();\n  }\n}\n\nfunction drawParticles() {\n  for (const p of particles) {\n    // Particles follow field lines approximately\n    p.angle += p.speed * rotationSpeed * 0.02;\n    \n    // Spiral inward slightly\n    p.dist -= 0.1;\n    if (p.dist < 30) {\n      Object.assign(p, createParticle());\n      p.dist = 150 + Math.random() * 100;\n    }\n    \n    const worldAngle = p.angle + rotation;\n    const x = cx + Math.cos(worldAngle) * p.dist;\n    const y = cy + Math.sin(worldAngle) * p.dist * (0.3 + p.zOffset);\n    \n    // Check if in beam\n    const inBeam = Math.abs(Math.cos(worldAngle - rotation)) > 0.95;\n    \n    const baseHue = wavelengthMode === 0 ? 180 : 300;\n    const hue = inBeam ? (wavelengthMode === 0 ? 60 : 330) : baseHue;\n    const brightness = inBeam ? p.brightness * 2 : p.brightness;\n    \n    ctx.fillStyle = `hsla(${hue}, 100%, ${50 + brightness * 30}%, ${brightness * 0.8})`;\n    ctx.beginPath();\n    ctx.arc(x, y, p.size * (inBeam ? 1.5 : 1), 0, Math.PI * 2);\n    ctx.fill();\n  }\n}\n\nfunction drawPulseRing() {\n  // Expanding pulse rings when beam faces viewer\n  const pulseAge = (Date.now() - lastPulseTime) / 1000;\n  if (pulseAge < 0.5) {\n    const radius = 50 + pulseAge * 400;\n    const alpha = 0.3 * (1 - pulseAge * 2);\n    \n    ctx.strokeStyle = wavelengthMode === 0 ? \n      `rgba(0, 255, 255, ${alpha})` : \n      `rgba(255, 100, 255, ${alpha})`;\n    ctx.lineWidth = 3 - pulseAge * 4;\n    ctx.beginPath();\n    ctx.arc(cx, cy, radius, 0, Math.PI * 2);\n    ctx.stroke();\n  }\n}\n\nfunction drawBackground() {\n  // Distant stars\n  ctx.fillStyle = '#000';\n  ctx.fillRect(0, 0, W, H);\n  \n  // Static starfield (seeded random)\n  const seed = 42;\n  for (let i = 0; i < 200; i++) {\n    const x = ((seed * (i + 1) * 9301 + 49297) % 233280) / 233280 * W;\n    const y = ((seed * (i + 1) * 49297 + 9301) % 233280) / 233280 * H;\n    const size = ((seed * (i + 1) * 1234 + 5678) % 100) / 100;\n    const twinkle = Math.sin(Date.now() * 0.001 + i) * 0.3 + 0.7;\n    \n    ctx.fillStyle = `rgba(255, 255, 255, ${size * 0.5 * twinkle})`;\n    ctx.beginPath();\n    ctx.arc(x, y, size * 1.5, 0, Math.PI * 2);\n    ctx.fill();\n  }\n}\n\nfunction drawPeriodIndicator() {\n  // Visual period meter\n  const period = (Math.PI * 2) / rotationSpeed;\n  const barWidth = 100;\n  const barHeight = 4;\n  const x = W - barWidth - 20;\n  const y = 20;\n  \n  ctx.fillStyle = 'rgba(100, 100, 100, 0.3)';\n  ctx.fillRect(x, y, barWidth, barHeight);\n  \n  const phase = (rotation % (Math.PI * 2)) / (Math.PI * 2);\n  const pulseX = x + phase * barWidth;\n  \n  ctx.fillStyle = wavelengthMode === 0 ? '#00ffff' : '#ff66ff';\n  ctx.fillRect(pulseX - 2, y - 2, 4, barHeight + 4);\n  \n  ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';\n  ctx.font = '10px Courier New';\n  ctx.fillText(`P = ${period.toFixed(2)}s`, x, y + 20);\n}\n\nlet lastTime = performance.now();\n\nfunction animate(currentTime) {\n  const dt = (currentTime - lastTime) / 1000;\n  lastTime = currentTime;\n  \n  // Mouse influence on rotation speed\n  const dx = mouseX - cx;\n  const dy = mouseY - cy;\n  const dist = Math.sqrt(dx * dx + dy * dy);\n  const maxDist = Math.min(W, H) / 2;\n  targetSpeed = 1.5 + (dist / maxDist) * 6;\n  \n  // Smooth speed transition\n  rotationSpeed += (targetSpeed - rotationSpeed) * 0.05;\n  \n  // Update rotation\n  rotation += rotationSpeed * dt;\n  \n  // Draw everything\n  drawBackground();\n  drawFieldLines();\n  drawParticles();\n  drawBeams();\n  drawStar();\n  drawPulseRing();\n  drawPeriodIndicator();\n  \n  requestAnimationFrame(animate);\n}\n\n// Event listeners\nwindow.addEventListener('resize', resize);\n\ncanvas.addEventListener('mousemove', (e) => {\n  mouseX = e.clientX;\n  mouseY = e.clientY;\n});\n\ncanvas.addEventListener('click', () => {\n  initAudio();\n  wavelengthMode = 1 - wavelengthMode;\n  document.getElementById('info').textContent = \n    wavelengthMode === 0 ? \n      'PSR J0437−4715 · radio wavelength' : \n      'PSR J0437−4715 · x-ray wavelength';\n});\n\ncanvas.addEventListener('touchstart', (e) => {\n  e.preventDefault();\n  initAudio();\n  wavelengthMode = 1 - wavelengthMode;\n});\n\n// Initialize\nresize();\ninitParticles();\ninitFieldLines();\nrequestAnimationFrame(animate);\n</script>\n</body>\n</html>\n"
}
